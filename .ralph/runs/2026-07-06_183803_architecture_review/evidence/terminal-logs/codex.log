  const roleTitle = ROLE_CONTEXT_LABELS[summary.role_context];
  const roleSubtitle = ROLE_CONTEXT_SUBTITLES[summary.role_context];

  return (
    <>
      <div>
        <h2 className="section-title mb-3">{roleTitle}</h2>
