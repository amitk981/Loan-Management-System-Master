    expect(fetchMock).toHaveBeenCalledWith(
      'http://127.0.0.1:8000/api/v1/dashboard/',
      expect.objectContaining({
        method: 'GET',
        headers: expect.objectContaining({
          Accept: 'application/json',
          Authorization: 'Bearer access-token-1',
        }),
      }),
    );
