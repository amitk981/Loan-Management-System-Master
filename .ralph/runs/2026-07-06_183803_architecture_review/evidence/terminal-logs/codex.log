      code: 'applications_pending_completeness',
      label: 'Applications pending completeness',
      count: 7,
      link: '/applications?status=pending_completeness',
    });
    expect(summary.tasks).toEqual([]);
  });

  it.each([
    ['AUTH_REQUIRED', 401],
    ['PERMISSION_DENIED', 403],
