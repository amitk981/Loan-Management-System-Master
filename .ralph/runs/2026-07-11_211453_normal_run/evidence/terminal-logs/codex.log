+import { fireEvent, render, screen, waitFor } from '@testing-library/react';
+import { beforeEach, describe, expect, it, vi } from 'vitest';
+import AppraisalWorkbench from './AppraisalWorkbench';
+import * as credit from '../../services/creditAssessmentApi';
+import * as intake from '../../services/applicationIntakeApi';
+
+vi.mock('../../contexts/RoleContext', () => ({ useRole: () => ({ currentUser: { permissions: ['credit.eligibility.run'], roleCodes: ['deputy_manager_finance'] } }) }));
+vi.mock('../../services/applicationIntakeApi', async importOriginal => ({ ...(await importOriginal<typeof import('../../services/applicationIntakeApi')>()), fetchStaffApplications: vi.fn() }));
+vi.mock('../../services/creditAssessmentApi', async importOriginal => ({
+  ...(await importOriginal<typeof import('../../services/creditAssessmentApi')>()),
+  fetchEligibilityAssessment: vi.fn(), fetchLoanLimitAssessment: vi.fn(), fetchAppraisal: vi.fn(), fetchSanctionCase: vi.fn(), runEligibilityAssessment: vi.fn(),
+}));
+
+const application = { loan_application_id: 'application-1', application_reference_number: 'LO000001', member: { member_id: 'member-1', display_name: 'API Borrower', member_type: 'individual', folio_number: 'FO-1' }, application_date: '2026-07-10', required_loan_amount: '250000.00', purpose_category: 'crop_production', application_status: 'reference_generated', current_stage: 'credit_assessment', completeness_status: 'complete' } as intake.StaffApplication;
+const action = { action_code: 'credit.eligibility.run', label: 'Run Eligibility Assessment', enabled: true, disabled_reason: null, required_permission: 'credit.eligibility.run', required_role: null };
+const eligibility = { eligibility_assessment_id: 'eligibility-1', loan_application_id: 'application-1', member_active_check: 'pass', default_check: 'no_default', document_check: 'complete', terms_acceptance_check: 'accepted', purpose_check: 'agriculture_aligned', nominee_check: 'valid', overall_result: 'eligible', assessment_notes: 'Canonical refreshed assessment.', assessed_by_user_id: 'user-1', assessed_at: '2026-07-10T10:00:00+05:30', available_actions: [action] } as credit.EligibilityAssessment;
+
+describe('default AppraisalWorkbench HTTP interaction boundary', () => {
+  beforeEach(() => {
+    vi.clearAllMocks();
+    vi.mocked(intake.fetchStaffApplications).mockResolvedValue({ items: [application], pagination: { page: 1, page_size: 100, total_items: 1, total_pages: 1 } });
+    vi.mocked(credit.fetchEligibilityAssessment).mockResolvedValue(eligibility);
+    vi.mocked(credit.fetchLoanLimitAssessment).mockRejectedValue({ status: 404 });
+    vi.mocked(credit.fetchAppraisal).mockRejectedValue({ status: 404 });
+    vi.mocked(credit.fetchSanctionCase).mockRejectedValue({ status: 404 });
+    vi.mocked(credit.runEligibilityAssessment).mockResolvedValue(eligibility);
+  });
+
+  it('executes one mutation and performs the canonical four-read refresh', async () => {
+    render(<AppraisalWorkbench onOpenApplication={vi.fn()} />);
+    fireEvent.click(await screen.findByRole('button', { name: 'Run Eligibility Assessment' }));
+
+    await waitFor(() => expect(credit.runEligibilityAssessment).toHaveBeenCalledTimes(1));
+    expect(credit.runEligibilityAssessment).toHaveBeenCalledWith('application-1');
+    await waitFor(() => {
+      expect(credit.fetchEligibilityAssessment).toHaveBeenCalledTimes(2);
+      expect(credit.fetchLoanLimitAssessment).toHaveBeenCalledTimes(2);
+      expect(credit.fetchAppraisal).toHaveBeenCalledTimes(2);
+      expect(credit.fetchSanctionCase).toHaveBeenCalledTimes(2);
+    });
+    expect(await screen.findByText('Stored server state updated.')).toBeInTheDocument();
+    expect(screen.getByText('Canonical refreshed assessment.')).toBeInTheDocument();
+  });
+});
