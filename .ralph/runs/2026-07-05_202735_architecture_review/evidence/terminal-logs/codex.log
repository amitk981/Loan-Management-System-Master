        )

    def test_activate_requires_evidence_permission_and_writes_version_history_and_audit(self):
        previous_active = self._loan_policy_config(
            policy_version="0.9",
            effective_from="2025-04-01",
            status="active",
            board_approval_reference="BOARD-OLD",
