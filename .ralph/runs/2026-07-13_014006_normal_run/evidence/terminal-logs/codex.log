  const updateDeclaration = (field: keyof typeof borrowerApplication.declarations, value: boolean) => {
    setApplicationDraftSaved(false);
    setApiMessage(null);
    setBorrowerApplication(prev => ({
      ...prev,
      declarations: { ...prev.declarations, [field]: value },
