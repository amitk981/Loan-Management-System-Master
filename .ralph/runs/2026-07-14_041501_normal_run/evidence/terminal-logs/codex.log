 # Execution Plan
 
-Selected slice: 007O-frozen-terminal-decision-and-register-source-closure
+Selected slice: `007O-frozen-terminal-decision-and-register-source-closure`
+
+## Scope and seam
+
+- Keep the existing HTTP interfaces and approval action payloads unchanged.
+- Deepen the existing `approval_case_engine` seam so one locked, canonically validated frozen
+  review package supplies terminal decision/register facts.
+- Remove terminal value reads from mutable application/member/appraisal attributes while retaining
+  their foreign-key ownership links and state transitions.
+- Route General Meeting availability and mutation through `approval_case_is_readable`, preserving
+  the existing legal-audience and permission decisions.
+
+## TDD sequence
+
+1. Add one public action-flow regression that mutates live application, member, appraisal,
+   loan-limit, and risk values between routing and final approval; capture RED, then make the
+   approved decision and register equal the routed frozen package.
+2. Add the equivalent public rejection-flow regression and make the rejected register retain
+   frozen application/borrower/amount/purpose-risk source facts.
+3. Add a public final-action corruption regression that leaves live rows valid but corrupts the
+   frozen package; prove a nondisclosing failure and zero writes across action, decision, register,
+   workflow, audit, notification, and communication ledgers.
+4. Extend the General Meeting behavioral/static matrix to prove availability and mutation use the
+   single canonical readable-case decision with unchanged denial parity; capture RED/GREEN.
+5. Refactor only after focused tests are green, keeping frozen-package validation and extraction
+   local to the approval engine interface.
 
-The selected agent must replace this template with a slice-specific execution plan before editing product code.
+## Verification and delivery
+
+- Run focused approval action/register/General Meeting tests after every red/green cycle using the
+  mandated Ralph virtualenv interpreter.
+- Run Django check, migration-sync check, full backend coverage gate, and all configured frontend
+  build/typecheck/lint/test gates.
+- Save self-contained terminal evidence, changed-files/risk/review/final artifacts, update the Epic
+  007 digest if source extraction needs clarification, sharpen the next one or two eligible
+  Not Started slices using already-opened source material, and update slice/state/progress/handoff.
+- Do not create commits or modify protected/source files.
diff --git a/sfpcl_credit/tests/test_approval_case_routing_api.py b/sfpcl_credit/tests/test_approval_case_routing_api.py
index b1752bdae29f34a806cdfb1ed807ceea00d6660e..394f529f7ea09c38a9f4f424a7b131ea0e45b78d
--- a/sfpcl_credit/tests/test_approval_case_routing_api.py
+++ b/sfpcl_credit/tests/test_approval_case_routing_api.py
@@ -2238,6 +2238,95 @@
             communication_audit.new_value_json["delivery_status"], "pending"
         )
 
+    def test_final_approval_uses_routed_review_package_after_live_owner_mutation(self):
+        frozen_review = self.case.appraisal_facts_json
+        first = self.client.post(
+            f"/api/v1/approval-cases/{self.case.pk}/approve/",
+            {"version": 2, "comments": "First frozen approval."},
+            content_type="application/json",
+            **self._auth(self.cfo),
+        )
+        self.assertEqual(first.status_code, 200, first.json())
+
+        self.application.application_reference_number = "LIVE-MUTATED-REFERENCE"
+        self.application.borrower_type = "fpc"
+        self.application.required_loan_amount = "1.00"
+        self.application.declared_purpose = "Mutable purpose after routing"
+        self.application.purpose_category = "working_capital"
+        self.application.save(
+            update_fields=[
+                "application_reference_number",
+                "borrower_type",
+                "required_loan_amount",
+                "declared_purpose",
+                "purpose_category",
+            ]
+        )
+        self.member.display_name = "Mutable borrower after routing"
+        self.member.member_type = "fpc"
+        self.member.save(update_fields=["display_name", "member_type"])
+        self.note.recommended_amount = "2.00"
+        self.note.recommended_tenure_months = 99
+        self.note.recommended_interest_type = "fixed"
+        self.note.recommended_security_summary = "Mutable security after routing"
+        self.note.loan_limit_snapshot_json = {
+            **self.note.loan_limit_snapshot_json,
+            "final_eligible_loan_amount": "3.00",
+            "policy_name": "Mutable policy after routing",
+        }
+        self.note.save(
+            update_fields=[
+                "recommended_amount",
+                "recommended_tenure_months",
+                "recommended_interest_type",
+                "recommended_security_summary",
+                "loan_limit_snapshot_json",
+            ]
+        )
+        self.risk.overall_risk_rating = "high"
+        self.risk.risk_mitigation_notes = "Mutable risk after routing."
+        self.risk.save(update_fields=["overall_risk_rating", "risk_mitigation_notes"])
+
+        final = self.client.post(
+            f"/api/v1/approval-cases/{self.case.pk}/approve/",
+            {"version": 3, "comments": "Terminal frozen approval."},
+            content_type="application/json",
+            **self._auth(self.director),
+        )
+
+        self.assertEqual(final.status_code, 200, final.json())
+        decision = apps.get_model("approvals", "SanctionDecision").objects.get(
+            approval_case=self.case
+        )
+        self.assertEqual(
+            str(decision.sanctioned_amount),
+            frozen_review["loan_amounts"]["recommended_amount"],
+        )
+        self.assertEqual(decision.sanctioned_tenure_months, 12)
+        self.assertEqual(decision.interest_rate_type, "floating")
+        self.assertEqual(
+            decision.security_required_summary,
+            "Standard member security package.",
+        )
+        entry = apps.get_model(
+            "approvals", "CreditSanctionRegisterEntry"
+        ).objects.get(approval_case=self.case)
+        self.assertEqual(entry.application_number, "LO00000701")
+        self.assertEqual(entry.borrower_name, frozen_review["borrower"]["name"])
+        self.assertEqual(entry.borrower_type, frozen_review["borrower"]["member_type"])
+        self.assertEqual(
+            str(entry.requested_amount),
+            frozen_review["loan_amounts"]["requested_amount"],
+        )
+        self.assertEqual(
+            str(entry.eligible_amount),
+            frozen_review["loan_amounts"]["eligible_amount"],
+        )
+        self.assertEqual(
+            str(entry.recommended_amount),
+            frozen_review["loan_amounts"]["recommended_amount"],
+        )
+
     def test_final_approval_publishes_immutable_register_and_sanction_decision_reads(self):
         sanction_read = self._permission("approvals.sanction.read")
         register_read = self._permission("approvals.sanction_register.read")

