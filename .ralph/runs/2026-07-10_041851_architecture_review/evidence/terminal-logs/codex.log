   671	    latest_by_type = {}
   672	    documents = list_application_documents(application)
   673	    for application_document in documents:
   674	        current = latest_by_type.get(application_document.document_type)
   675	        if current is None or application_document.version_number > current.version_number:
   676	            latest_by_type[application_document.document_type] = application_document
   677	
   678	    items = []
   679	    for document_type in REQUIRED_APPLICATION_DOCUMENT_TYPES:
   680	        latest = latest_by_type.get(document_type)
   681	        if latest is None:
   682	            items.append(
   683	                {
   684	                    "document_type": document_type,
   685	                    "required_flag": True,
   686	                    "submission_status": ApplicationDocument.SUBMISSION_PENDING,
   687	                    "verification_status": ApplicationDocument.VERIFICATION_PENDING,
   688	                    "latest_application_document_id": None,
   689	                    "latest_version_number": None,
   690	                }
   691	            )
   692	            continue
   693	        items.append(
   694	            {
   695	                "document_type": document_type,
   696	                "required_flag": True,
   697	                "submission_status": latest.submission_status,
   698	                "verification_status": latest.verification_status,
   699	                "latest_application_document_id": str(latest.application_document_id),
   700	                "latest_version_number": latest.version_number,
   701	            }
   702	        )
   703	    return {
   704	        "loan_application_id": str(application.loan_application_id),
   705	        "items": items,
   706	    }
   707	
   708	
   709	def build_completeness_workbench(application):
   710	    checklist = build_document_checklist(application)
   711	    required_items = [_completeness_checklist_item(item) for item in checklist["items"]]
   712	    blocking_document_types = [
   713	        item["document_type"] for item in required_items if not item["complete"]
   714	    ]
   715	    return {
   716	        "loan_application_id": str(application.loan_application_id),
   717	        "application_reference_number": application.application_reference_number,
   718	        "application_status": application.application_status,
   719	        "current_stage": application.current_stage,
   720	        "completeness_status": application.completeness_status,
   721	        "member": _member_summary(application.member),
   722	        "required_checklist_items": required_items,
   723	        "blocking_document_types": blocking_document_types,
   724	        "can_generate_reference": (
   725	            application.application_status == LoanApplication.STATUS_SUBMITTED
   726	            and not application.application_reference_number
   727	            and not LoanRequestRegisterEntry.objects.filter(loan_application=application).exists()
   728	            and not blocking_document_types
   729	        ),
   730	    }
