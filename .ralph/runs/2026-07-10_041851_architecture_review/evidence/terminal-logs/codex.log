   155	def evaluate_application_object_access(application, actor, required_permission, actor_permissions=None):
   156	    permissions = actor_permissions or auth_service.effective_permission_codes(actor)
   157	    allow_global = _has_credit_manager_domain_access(application, actor)
   158	    result = evaluate_object_access(
   159	        actor_user_id=actor.user_id,
   160	        actor_team_codes=actor.team_codes(),
   161	        actor_permission_codes=permissions,
   162	        required_permission=required_permission,
   163	        object_owner_user_id=application.created_by_user_id,
   164	        allow_global=allow_global,
   165	    )
   166	    if result.allowed or result.error_code != "OBJECT_ACCESS_DENIED":
   167	        return result
   168	    if (
   169	        application.received_by_user_id
   170	        and application.received_by_user_id != application.created_by_user_id
   171	    ):
   172	        return evaluate_object_access(
   173	            actor_user_id=actor.user_id,
   174	            actor_team_codes=actor.team_codes(),
   175	            actor_permission_codes=permissions,
   176	            required_permission=required_permission,
   177	            object_owner_user_id=application.received_by_user_id,
   178	            allow_global=allow_global,
   179	        )
   180	    return result
