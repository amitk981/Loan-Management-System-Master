   109	                checklist,
   110	                decision.completion_action_item_ids,
   111	                decision.current_submissions.get(item.item_code),
   112	                decision.current_issued_documents.get(item.item_code),
   113	            )
   114	            for item in decision.items
   115	        ],
   116	    }
