    19	def list_for_application(*, application_id, query_params):
    20	    """Return one strict, deterministic, exactly counted application page."""
    21	    unknown = set(query_params.keys()) - _LIST_PARAMS
    22	    if unknown:
    23	        raise ValidationError(
    24	            {field: "Unknown query parameter." for field in sorted(unknown)}
    25	        )
    26	    page = _positive_int("page", query_params.get("page"), 1)
    27	    page_size = min(
    28	        _positive_int("page_size", query_params.get("page_size"), _DEFAULT_PAGE_SIZE),
    29	        _MAX_PAGE_SIZE,
    30	    )
    31	    queryset = (
    32	        LoanDocument.objects.select_related("document", "document_template")
    33	        .filter(loan_application_id=application_id)
    34	        .order_by("-created_at", "-loan_document_id")
    35	    )
    36	    total_count = queryset.count()
    37	    total_pages = ceil(total_count / page_size) if total_count else 1
    38	    page = min(page, total_pages)
    39	    offset = (page - 1) * page_size
    40	    return list(queryset[offset : offset + page_size]), {
    41	        "page": page,
    42	        "page_size": page_size,
    43	        "total_count": total_count,
    44	        "total_pages": total_pages,
    45	        "has_next": page < total_pages,
    46	        "has_previous": page > 1,
    47	    }
