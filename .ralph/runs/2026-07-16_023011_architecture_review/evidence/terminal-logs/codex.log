   265	def upload(*, actor, application_id, action_code, request):
   266	    context = resolve_context(actor=actor, application_id=application_id)
   267	    decision = _resolve_locked_decision(context=context)
   268	    application = decision.application
   269	    if not decision.approved:
   270	        raise PortalDocumentationUnavailable(
   271	            "Documentation uploads require a current sanction approval."
   272	        )
   273	    item = next((row for row in decision.items if row.item_code == action_code), None)
   274	    previous = decision.current_submissions.get(action_code)
   275	    authority = (
   276	        _resolve_action_authority(
   277	            item=item,
   278	            completion_action_item_ids=decision.completion_action_item_ids,
   279	            submission=previous,
   280	        )
   281	        if item is not None
   282	        else None
   283	    )
   284	    if authority is None or not (
   285	        authority.upload_allowed or authority.reupload_allowed
   286	    ):
   287	        raise PortalDocumentationUnavailable(
   288	            "This documentation action is not currently available for upload."
   289	        )
   290	    uploaded_file, notes = _validate_upload_request(request)
   291	    document_version = (
   292	        PortalDocumentationSubmission.objects.filter(
   293	            loan_application=application, action_code=action_code
   294	        ).count()
   295	        + 1
   296	    )
   297	    document = document_services.store_document_upload(
   298	        user=actor,
   299	        request=request,
   300	        uploaded_file=uploaded_file,
   301	        document_category="legal",
   302	        sensitivity_level="confidential",
   303	        related_entity_type="loan_application",
   304	        related_entity_id=application.pk,
   305	        audit_spec=document_services.DocumentAuditSpec(
   306	            action="portal.document.uploaded",
   307	            actor_type="portal_account",
   308	            metadata={
   309	                "portal_account_id": str(context.account.pk),
   310	                "member_id": str(context.account.member_id),
   311	                "loan_application_id": str(application.pk),
   312	                "action_code": action_code,
   313	                "document_version": document_version,
   314	                "document_category": "legal",
   315	                "sensitivity_level": "confidential",
   316	                "reason": "borrower_portal_submission",
   317	                "request_id": request.headers.get("X-Request-ID"),
   318	                "network": {
   319	                    "ip_address": document_services.request_ip(request),
   320	                    "user_agent": document_services.request_user_agent(request),
   321	                },
   322	                "outcome": "accepted",
   323	            },
   324	        ),
   325	    )
   326	    submission = PortalDocumentationSubmission.objects.create(
   327	        loan_application=application,
   328	        action_code=action_code,
   329	        document=document,
   330	        portal_account=context.account,
   331	        uploader_member=context.account.member,
   332	        notes=notes,
   333	        supersedes=previous,
   334	    )
   335	    return {
   336	        "action_code": action_code,
   337	        "status": "submitted",
   338	        "document": {
   339	            "document_id": str(document.pk),
   340	            "file_name": document.file_name,
   341	            "mime_type": document.mime_type,
   342	            "file_size_bytes": document.file_size_bytes,
   343	            "checksum_sha256": document.checksum_sha256,
   344	            "uploaded_at": document.uploaded_at.isoformat().replace("+00:00", "Z"),
   345	        },
   346	    }
   347	def _validate_upload_request(request):
   348	    field_errors = {}
   349	    post_fields = set(request.POST.keys())
   350	    file_fields = set(request.FILES.keys())
   351	    unknown = sorted((post_fields - {"notes"}) | (file_fields - {"file"}))
   352	    if unknown:
   353	        field_errors["unknown_fields"] = f"Unknown fields: {', '.join(unknown)}."
   354	    uploaded_file = request.FILES.get("file")
   355	    if uploaded_file is None:
   356	        field_errors["file"] = "Exactly one file is required."
   357	    elif uploaded_file.size <= 0:
   358	        field_errors["file"] = "File must not be empty."
   359	    elif uploaded_file.size > 5 * 1024 * 1024:
   360	        field_errors["file"] = "File must not exceed 5 MiB."
   361	    if len(request.FILES.getlist("file")) != 1:
   362	        field_errors["file"] = "Exactly one file is required."
   363	    notes = (request.POST.get("notes") or "").strip() or None
   364	    if notes and len(notes) > 4000:
   365	        field_errors["notes"] = "Must not exceed 4000 characters."
   366	    if uploaded_file is not None:
   367	        extension = Path(uploaded_file.name).suffix.lower()
   368	        allowed = {
   369	            ".pdf": "application/pdf",
   370	            ".jpg": "image/jpeg",
   371	            ".jpeg": "image/jpeg",
   372	            ".png": "image/png",
   373	        }
   374	        if extension not in allowed or uploaded_file.content_type != allowed.get(extension):
   375	            field_errors["file"] = "File extension and MIME type must be PDF, JPG, or PNG."
   376	    if field_errors:
   377	        raise ValidationError(field_errors)
   378	    return uploaded_file, notes
   379	@transaction.atomic
   380	def download(*, actor, application_id, action_code, request, storage=None):
   381	    context = resolve_context(actor=actor, application_id=application_id)
   382	    decision = _resolve_locked_decision(context=context)
   383	    application = decision.application
   384	    if (
   385	        not decision.approved
   386	        or action_code not in {"term_sheet", "loan_agreement"}
   387	    ):
   388	        raise PortalDocumentationNotFound
   389	    item = next((row for row in decision.items if row.item_code == action_code), None)
   390	    document = decision.current_issued_documents.get(action_code)
   391	    if (
   392	        item is None
   393	        or not item.required_flag
   394	        or not item.applicable_flag
   395	        or document is None
   396	        or document.document is None
   397	        or document.renderer_validation_status != document.RENDERER_CURRENT_VALIDATED
   398	    ):
   399	        raise PortalDocumentationNotFound
   400	    storage = storage or LocalDocumentStorage()
   401	    scope = {
   402	        "portal_account_id": str(context.account.pk),
   403	        "member_id": str(context.account.member_id),
   404	        "loan_application_id": str(application.pk),
   405	        "action_code": action_code,
   406	        "loan_document_id": str(document.pk),
   407	    }
   408	    if request.GET.get("content") != "1":
   409	        capability = document_services.issue_download_capability(
   410	            document=document.document,
   411	            scope=scope,
   412	        )
   413	        query = urlencode({"content": "1", "token": capability["token"]})
   414	        return {
   415	            "download_url": (
   416	                f"/api/v1/portal/applications/{application.pk}/documentation-actions/"
   417	                f"{action_code}/download/?{query}"
   418	            ),
   419	            "expires_at": capability["expires_at"],
   420	        }
