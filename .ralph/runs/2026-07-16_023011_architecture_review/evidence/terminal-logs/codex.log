    95	    if checklist is None:
    96	        return {
    97	            **base,
    98	            "availability": "blocked",
    99	            "unavailable_reason": "The post-sanction documentation checklist is not available yet.",
   100	            "actions": [],
   101	        }
   102	    return {
   103	        **base,
   104	        "availability": "available",
   105	        "unavailable_reason": None,
   106	        "actions": [
