    35	  return d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) +
    36	    ' at ' + d.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
    37	};
    38	
    39	const formatState = (s: string) => s.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    40	
    41	const roleLabels: Record<string, string> = {
    42	  field_officer: 'Field Officer',
    43	  deputy_manager_finance: 'Deputy Manager – Finance',
    44	  credit_manager: 'Credit Manager',
    45	  compliance_team: 'Compliance Team',
