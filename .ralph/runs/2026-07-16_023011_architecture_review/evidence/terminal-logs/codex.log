-  local file unmet
-  for file in $(find docs/slices -maxdepth 1 -type f -name '*.md' | sort); do
-    [[ "$(ralph_slice_status "$file")" == "Not Started" ]] || continue
-    if unmet="$(ralph_slice_unmet_dependencies "$file")"; then
