+from sfpcl_credit.approvals.models import ApprovalCase
+from sfpcl_credit.approvals.modules import document_checklist_facts
+from sfpcl_credit.tests.test_final_documentation_approval_api import (
+    FinalDocumentationApprovalApiTests,
+)
+from sfpcl_credit.tests.test_portal_deficiency_response_api import (
+    PortalDeficiencyResponseApiTests,
+)
+from sfpcl_credit.workflows.models import WorkflowEvent
+
+
+class BankDecisionTerminalScopeProbe(FinalDocumentationApprovalApiTests):
+    def test_status_label_cannot_replace_canonical_terminal_sanction(self):
+        self._complete_all_applicable_items()
+        prior = self.application.bank_verification_decisions.order_by(
+            "-decision_version"
+        ).first()
+        self.case.current_status = ApprovalCase.STATUS_REJECTED
+        self.case.save(update_fields=["current_status"])
+        self.assertIsNone(
+            document_checklist_facts.resolve_approved_facts(
+                application_id=self.application.pk
+            )
+        )
+        before = self.application.bank_verification_decisions.count()
+
+        response = self.client.post(
+            f"/api/v1/loan-applications/{self.application.pk}/bank-verification-decision/",
+            {
+                "bank_account_id": str(prior.bank_account_id),
+                "cancelled_cheque_id": str(prior.cancelled_cheque_id),
+                "decision_status": "rejected",
+            },
+            content_type="application/json",
+            HTTP_X_REQUEST_ID="architecture-review-nonterminal-sanction",
+            **self.fixture._auth(self.compliance),
+        )
+
+        self.assertEqual(response.status_code, 403, response.content)
+        self.assertEqual(
+            self.application.bank_verification_decisions.count(), before
+        )
+
+
+class DeficiencyWorkflowEvidenceProbe(PortalDeficiencyResponseApiTests):
+    def test_missing_response_workflow_cannot_project_responded_truth(self):
+        token = self._token()
+        upload = self._upload(token, name="statement.pdf")
+        self.assertEqual(upload.status_code, 200, upload.content)
+        response_id = upload.json()["data"]["response"]["deficiency_response_id"]
+        WorkflowEvent.objects.filter(
+            workflow_name="application_deficiency",
+            entity_type="application_deficiency_response",
+            entity_id=response_id,
+        ).delete()
+
+        projection = self.client.get(
+            self._url(), headers={"Authorization": f"Bearer {token}"}
+        )
+
+        self.assertEqual(projection.status_code, 200, projection.content)
+        self.assertNotEqual(
+            projection.json()["data"]["items"][0]["response"]["response_status"],
+            "responded",
+        )
