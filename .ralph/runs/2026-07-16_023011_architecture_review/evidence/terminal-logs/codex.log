    26	def resolve_read_access(*, actor, application_id):
    27	    """Resolve compatibility route and object scope before checklist ORM access."""
    28	    permissions = auth_service.effective_permission_codes(actor)
    29	    legacy_read = LEGACY_READ_PERMISSION in permissions
    30	    if (
    31	        not actor.can_authenticate()
    32	        or (READ_PERMISSION not in permissions and not legacy_read)
    33	    ):
    34	        return ChecklistReadResolution(None, None, "global_permission", "FORBIDDEN")
    35	
    36	    application = (
    37	        LoanApplication.objects.select_related("created_by_user", "received_by_user")
    38	        .filter(pk=application_id)
    39	        .first()
    40	    )
    41	    if application is None:
    42	        if READ_PERMISSION in permissions and "compliance_team_member" in actor.role_codes():
    43	            return ChecklistReadResolution(None, None, "documentation_absent_parent", "NOT_FOUND")
    44	        if legacy_read:
    45	            return ChecklistReadResolution(
    46	                ROUTE_PRE_SANCTION, None, "legacy_application_route"
    47	            )
    48	        return ChecklistReadResolution(
    49	            None, None, "absent_parent_nondisclosure", "OBJECT_ACCESS_DENIED"
    50	        )
    51	    if application.application_status != LoanApplication.STATUS_APPROVED_BY_SANCTION:
    52	        return ChecklistReadResolution(
    53	            ROUTE_PRE_SANCTION, application, "legacy_application_route"
    54	        )
    55	    if READ_PERMISSION not in permissions:
    56	        return ChecklistReadResolution(None, application, "global_permission", "FORBIDDEN")
    57	
    58	    case = (
    59	        application.sanction_approval_cases.prefetch_related("actions")
    60	        .order_by("-cycle_number", "-submitted_at")
    61	        .first()
    62	    )
    63	    if case is None:
    64	        return ChecklistReadResolution(
    65	            None, application, "missing_approval_scope", "OBJECT_ACCESS_DENIED"
    66	        )
    67	    access = _evaluate_post_sanction_scope(
    68	        actor=actor,
    69	        application=application,
    70	        case=case,
    71	        actor_permissions=permissions,
    72	    )
    73	    if not access.allowed:
    74	        return ChecklistReadResolution(
    75	            None, application, access.attribution, "OBJECT_ACCESS_DENIED"
    76	        )
    77	    return ChecklistReadResolution(
    78	        ROUTE_POST_SANCTION, application, access.attribution
    79	    )
