   218	def resolve_referenceable_documents(
   219	    *,
   220	    actor_permissions,
   221	    document_ids_by_field,
   222	    context,
   223	    purpose,
   224	):
   225	    """Resolve document references only when immutable upload provenance proves access."""
   226	    if not document_ids_by_field:
   227	        return {}
   228	    permissions = set(actor_permissions)
   229	    if DOCUMENT_DOWNLOAD_PERMISSION not in permissions:
   230	        raise ValidationError(
   231	            {field: _INACCESSIBLE_REFERENCE_MESSAGE for field in document_ids_by_field}
   232	        )
   233	    general_meeting_context = (
   234	        purpose == GENERAL_MEETING_REFERENCE_PURPOSE
   235	        and context.workflow_scope == GENERAL_MEETING_WORKFLOW_SCOPE
   236	    )
   237	    exception_context = (
   238	        purpose == EXCEPTION_REFERENCE_PURPOSE
   239	        and context.workflow_scope == EXCEPTION_WORKFLOW_SCOPE
   240	    )
   241	    legal_category_access_allowed = (
   242	        bool(
   243	            context.actor_role_codes
   244	            & {"compliance_team_member", "company_secretary", "credit_manager"}
   245	        )
   246	        or context.actor_is_related_case_approver
   247	    )
   248	    documents = DocumentFile.objects.in_bulk(document_ids_by_field.values())
   249	    upload_metadata = {}
   250	    for audit in AuditLog.objects.filter(
   251	        action=DOCUMENT_UPLOAD_AUDIT_ACTION,
   252	        entity_type="document_file",
   253	        entity_id__in=document_ids_by_field.values(),
   254	    ).order_by("-created_at", "-audit_log_id"):
   255	        upload_metadata.setdefault(str(audit.entity_id), audit.new_value_json or {})
   256	
   257	    denied_fields = {}
   258	    for field, document_id in document_ids_by_field.items():
   259	        document = documents.get(document_id)
   260	        metadata = upload_metadata.get(str(document_id), {})
   261	        reference_is_allowed = (
   262	            (general_meeting_context or exception_context)
   263	            and context.related_entity_access_allowed
   264	            and legal_category_access_allowed
   265	            and document is not None
   266	            and metadata.get("document_id") == str(document_id)
   267	            and metadata.get("related_entity_type") == context.related_entity_type
   268	            and metadata.get("related_entity_id") == str(context.related_entity_id)
   269	            and metadata.get("document_category") == "legal"
   270	            and document.sensitivity_level in ALLOWED_SENSITIVITY_LEVELS
   271	            and metadata.get("sensitivity_level") == document.sensitivity_level
   272	        )
   273	        if not reference_is_allowed:
   274	            denied_fields[field] = _INACCESSIBLE_REFERENCE_MESSAGE
   275	    if denied_fields:
   276	        raise ValidationError(denied_fields)
   277	    return {
   278	        field: documents[document_id]
   279	        for field, document_id in document_ids_by_field.items()
   280	    }
