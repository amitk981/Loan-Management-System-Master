   188	def _serialize_item(
   189	    item, checklist, completion_action_item_ids, submission, current_issued_document
   190	):
   191	    section, instruction = _ACTION_PRESENTATION[item.item_code]
   192	    authority = _resolve_action_authority(
   193	        item=item,
   194	        completion_action_item_ids=completion_action_item_ids,
   195	        submission=submission,
   196	    )
   197	    status = (
   198	        "not_required"
   199	        if not item.applicable_flag
   200	        else "complete"
   201	        if authority.reconciled_complete
   202	        else "submitted"
   203	        if submission
   204	        else "pending_borrower"
   205	    )
   206	    return {
   207	        "action_code": item.item_code,
   208	        "label": item.item_label,
   209	        "section": section,
   210	        "required": item.required_flag,
   211	        "applicable": item.applicable_flag,
   212	        "status": status,
   213	        "updated_date": (
   214	            submission.created_at.date().isoformat()
   215	            if submission
   216	            else checklist.updated_at.date().isoformat()
   217	        ),
   218	        "instruction": instruction,
   219	        "note": (
   220	            "This requirement is currently blocked pending canonical applicability facts."
   221	            if item.applicability_blocker
   222	            else None
   223	        ),
   224	        "upload_allowed": authority.upload_allowed,
   225	        "reupload_allowed": authority.reupload_allowed,
   226	        "download": _download_metadata(item, current_issued_document),
   227	    }
