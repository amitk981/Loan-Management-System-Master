     3	from dataclasses import dataclass
     4	
     5	from django.core.exceptions import ValidationError
     6	
     7	from sfpcl_credit.approvals.models import ApprovalCase, SanctionDecision
     8	from sfpcl_credit.approvals.modules import approval_case_engine
     9	
    10	
    11	@dataclass(frozen=True)
    12	class ApprovedChecklistFacts:
    13	    sanction_decision_id: object
    14	    approval_case_id: object
    15	    holding_mode: str | None
    16	    subsidiary_route: bool | None
    17	
    18	
    19	def resolve_approved_facts(*, application_id):
    20	    latest_case = (
    21	        ApprovalCase.objects.filter(loan_application_id=application_id)
    22	        .order_by("-cycle_number", "-submitted_at", "-approval_case_id")
    23	        .first()
    24	    )
    25	    decision = (
    26	        SanctionDecision.objects.select_related("approval_case")
    27	        .filter(loan_application_id=application_id, decision="sanctioned")
    28	        .first()
    29	    )
    30	    if (
    31	        latest_case is None
    32	        or decision is None
    33	        or decision.approval_case_id != latest_case.pk
    34	        or latest_case.current_status != ApprovalCase.STATUS_APPROVED
    35	    ):
    36	        return None
    37	    try:
    38	        terminal_facts = approval_case_engine.validated_frozen_terminal_facts(
    39	            latest_case
    40	        )
    41	    except (KeyError, TypeError, ValidationError):
    42	        return None
    43	    review = terminal_facts["review_facts"]
    44	    shareholding = review.get("shareholding") or {}
    45	    active_member = ((review.get("eligibility") or {}).get("active_member_snapshot") or {})
    46	    subsidiary_route = None
    47	    subsidiary_flags = (
    48	        "supplied_to_subsidiary_flag",
    49	        "supplied_to_stepdown_flag",
    50	    )
    51	    if all(
    52	        key in active_member and isinstance(active_member[key], bool)
    53	        for key in subsidiary_flags
    54	    ):
    55	        subsidiary_route = any(
    56	            active_member[key] for key in subsidiary_flags
