   161	def issue_download_capability(*, document, scope):
   162	    """Issue a signed, short-lived capability bound to one document and caller-owned scope."""
   163	    expires_at = timezone.now() + timedelta(seconds=_DOWNLOAD_CAPABILITY_TTL_SECONDS)
   164	    token = signing.dumps(
   165	        {"document_id": str(document.pk), "scope": scope},
   166	        salt=_DOWNLOAD_CAPABILITY_SALT,
   167	        compress=True,
   168	    )
   169	    return {
   170	        "token": token,
   171	        "expires_at": expires_at.isoformat().replace("+00:00", "Z"),
   172	    }
   173	
   174	
   175	def read_with_download_capability(*, document, scope, token, storage=None):
   176	    """Verify the signed capability before reading checksum-verified retained bytes."""
   177	    try:
   178	        payload = signing.loads(
   179	            token,
   180	            salt=_DOWNLOAD_CAPABILITY_SALT,
   181	            max_age=_DOWNLOAD_CAPABILITY_TTL_SECONDS,
   182	        )
   183	    except (signing.BadSignature, signing.SignatureExpired) as exc:
   184	        raise ValidationError("Document download capability is invalid or expired.") from exc
   185	    if payload != {"document_id": str(document.pk), "scope": scope}:
   186	        raise ValidationError("Document download capability is invalid or expired.")
   187	    storage = storage or LocalDocumentStorage()
   188	    return storage.read_verified(document)
