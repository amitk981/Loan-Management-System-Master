   119	def _resolve_locked_decision(*, context):
   120	    application = LoanApplication.objects.select_for_update().get(
   121	        pk=context.application.pk
   122	    )
   123	    approved = bool(
   124	        application.application_status == LoanApplication.STATUS_APPROVED_BY_SANCTION
   125	        and document_checklist_facts.resolve_approved_facts(application_id=application.pk)
   126	        is not None
   127	    )
   128	    if not approved:
   129	        return PortalActionDecision(
   130	            application=application,
   131	            checklist=None,
   132	            items=(),
   133	            completion_action_item_ids=frozenset(),
   134	            current_submissions={},
   135	            current_issued_documents={},
   136	            approved=False,
   137	        )
   138	    checklist = (
   139	        DocumentChecklist.objects.select_for_update()
   140	        .filter(loan_application=application)
   141	        .first()
   142	    )
   143	    if checklist is None:
   144	        return PortalActionDecision(
   145	            application=application,
   146	            checklist=None,
   147	            items=(),
   148	            completion_action_item_ids=frozenset(),
   149	            current_submissions={},
   150	            current_issued_documents={},
   151	            approved=True,
   152	        )
   153	    items = tuple(
   154	        ChecklistItem.objects.select_for_update()
   155	        .filter(document_checklist=checklist)
   156	        .order_by("display_order", "checklist_item_id")
   157	    )
   158	    submissions = {
   159	        row.action_code: row
   160	        for row in PortalDocumentationSubmission.objects.select_for_update()
   161	        .select_related("document")
   162	        .filter(loan_application=application, successor__isnull=True)
   163	    }
   164	    issued_types = {"term_sheet", "loan_agreement"}
   165	    current_ids = legal_document_selectors.latest_generated_metadata_by_type(
   166	        application_id=application.pk,
   167	        document_types=issued_types,
   168	    )
   169	    current_documents = {
   170	        row.document_type: row
   171	        for row in LoanDocument.objects.select_for_update()
   172	        .select_related("document", "document_template")
   173	        .filter(pk__in=current_ids.values())
   174	    }
   175	    return PortalActionDecision(
   176	        application=application,
   177	        checklist=checklist,
   178	        items=items,
   179	        completion_action_item_ids=frozenset(
   180	            document_checklist_actions.borrower_safe_completed_item_ids(checklist)
   181	        ),
   182	        current_submissions=submissions,
   183	        current_issued_documents=current_documents,
   184	        approved=True,
   185	    )
