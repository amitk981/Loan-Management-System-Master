    88	def _evaluate_post_sanction_scope(*, actor, application, case, actor_permissions):
    89	    """Return the source-attributed application/case scope for a sanctioned package."""
    90	    roles = set(actor.role_codes())
    91	    if "senior_manager_finance" in roles:
    92	        checklist = getattr(application, "legal_document_checklist", None)
    93	        return _PostSanctionScope(
    94	            bool(checklist and checklist.checklist_status == "sanction_approved"),
    95	            "documentation_approved_pending_disbursement_scope",
    96	        )
    97	    if "chief_financial_controller" in roles:
    98	        return _PostSanctionScope(False, "disbursement_readiness_not_yet_available")
    99	    # Source §19.2 defines these roles' application scope as the sanctioned
   100	    # documentation queue itself; the status predicate is their canonical row scope.
   101	    if roles & {
   102	        "compliance_team_member",
   103	        "company_secretary",
   104	        "credit_manager",
   105	        "internal_auditor",
   106	    }:
   107	        return _PostSanctionScope(True, "sanctioned_documentation_application_scope")
   108	    approval_scope = evaluate_approval_case_read_scope(
   109	        actor=actor,
   110	        case=case,
   111	        actor_permissions=actor_permissions,
   112	    )
   113	    if approval_scope.allowed:
   114	        return _PostSanctionScope(True, approval_scope.attribution)
   115	    return _PostSanctionScope(False, "no_checklist_object_scope")
