   229	
   230	def _resolve_action_authority(*, item, completion_action_item_ids, submission):
   231	    reconciled_complete = (
   232	        item.completion_status == ChecklistItem.STATUS_COMPLETE
   233	        and item.pk in completion_action_item_ids
   234	    )
   235	    mutable = bool(
   236	        item.item_code in UPLOAD_ACTION_CODES
   237	        and item.required_flag
   238	        and item.applicable_flag
   239	        and item.completion_status == ChecklistItem.STATUS_PENDING
   240	        and not item.applicability_blocker
   241	        and not reconciled_complete
   242	    )
   243	    return PortalActionAuthority(
   244	        reconciled_complete=reconciled_complete,
   245	        upload_allowed=mutable and submission is None,
   246	        reupload_allowed=mutable and submission is not None,
   247	    )
   248	def _download_metadata(item, document):
   249	    if (
   250	        item.item_code not in {"term_sheet", "loan_agreement"}
   251	        or document is None
   252	        or document.document is None
   253	        or document.renderer_validation_status != document.RENDERER_CURRENT_VALIDATED
   254	    ):
   255	        return None
   256	    return {
   257	        "file_name": document.document.file_name,
   258	        "mime_type": document.document.mime_type,
   259	        "action_url": (
   260	            f"/api/v1/portal/applications/{item.document_checklist.loan_application_id}/"
   261	            f"documentation-actions/{item.item_code}/download/"
   262	        ),
   263	    }
