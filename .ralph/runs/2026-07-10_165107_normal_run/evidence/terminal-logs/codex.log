+            ).entity_id,
+            self.identifiers["loan_limit_id"],
+        )
+
+        self.assertEqual(eligibility_model._meta.db_table, "eligibility_assessments")
+        self.assertEqual(loan_limit_model._meta.db_table, "loan_limit_assessments")
