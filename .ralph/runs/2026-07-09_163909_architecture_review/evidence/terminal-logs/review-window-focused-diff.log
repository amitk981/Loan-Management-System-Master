+function listOk(data: unknown[]): Response {
+  return {
+    ok: true,
+    status: 200,
+    json: async () => ({
+      success: true,
+      data,
+      pagination: {
+        page: 1,
+        page_size: 20,
+        total_count: data.length,
+        total_pages: 1,
+        has_next: false,
+        has_previous: false,
+      },
+      meta: { api_version: 'v1' },
+    }),
+  } as Response;
+}
