   336	    def _user(self, email, password, *permissions):
   337	        role = Role.objects.create(
   338	            role_code=email.split("@")[0].replace(".", "_"),
   339	            role_name=email,
   340	            is_system_role=True,
   341	            status="active",
   342	        )
   343	        for permission in permissions:
   344	            RolePermission.objects.create(role=role, permission=permission)
   345	        user = User.objects.create(full_name=email, email=email, status="active", primary_role=role)
   346	        user.set_password(password)
   347	        user.save()
   348	        return user
