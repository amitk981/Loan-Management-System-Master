   609	    source_reason,
   610	    request_meta=None,
   611	):
   612	    old_snapshot = _linkage_snapshot(old_snapshot)
   613	    new_snapshot = _linkage_snapshot(new_snapshot)
   614	    context = _audit_context(actor, request_meta)
   615	    evidence = {
