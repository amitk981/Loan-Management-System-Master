   149	    def save(self, *args, **kwargs):
   150	        if not self._state.adding:
   151	            update_fields = kwargs.get("update_fields")
   152	            if update_fields is None or set(update_fields).intersection(
   153	                _RENDERER_PROVENANCE_FIELDS
   154	            ):
   155	                retained = (
   156	                    type(self)
   157	                    .objects.filter(pk=self.pk)
   158	                    .values(*_RENDERER_PROVENANCE_FIELDS)
   159	                    .first()
   160	                )
   161	                if retained is not None and any(
   162	                    retained[field] != getattr(self, field)
   163	                    for field in _RENDERER_PROVENANCE_FIELDS
   164	                ):
   165	                    raise ValidationError(
   166	                        {"renderer_provenance": "Renderer provenance is immutable."}
   167	                    )
   168	        return super().save(*args, **kwargs)
