    92	            item_code="bank_verification_letter",
    93	        )
    94	        .first()
    95	    )
    96	    if item is None:
    97	        return
    98	    fact = application_facts.resolve_signature_mismatch_fact(
    99	        legal_signature_rows=legal_signature_rows,
   100	        application_id=application.pk,
   101	        member_id=application.member_id,
   102	    )
   103	    applicable = fact.mismatch is True
   104	    values = {
   105	        "required_flag": applicable,
   106	        "applicable_flag": applicable,
   107	        "applicability_source": fact.source,
   108	        "applicability_blocker": fact.blocker,
   109	    }
   110	    changed = [field for field, value in values.items() if getattr(item, field) != value]
