   419	def _synchronise_items(checklist, specs, document_ids):
   420	    existing = {
   421	        item.item_code: item
   422	        for item in checklist.items.select_for_update().order_by("display_order")
   423	    }
   424	    applicability_changed = False
   425	    linkage_changed = False
   426	    for spec in specs:
   427	        applicability_values = {
   428	            "required_flag": spec.applicable,
   429	            "applicable_flag": spec.applicable,
   430	            "applicability_source": spec.source,
   431	            "applicability_blocker": spec.blocker,
   432	        }
   433	        item = existing.get(spec.code)
   434	        if item is None:
   435	            ChecklistItem.objects.create(
   436	                document_checklist=checklist,
   437	                item_code=spec.code,
   438	                completion_status=(
   439	                    ChecklistItem.STATUS_PENDING
   440	                    if spec.applicable
   441	                    else ChecklistItem.STATUS_NOT_APPLICABLE
   442	                ),
   443	                item_label=spec.label,
   444	                display_order=spec.order,
   445	                loan_document_id=document_ids.get(spec.code),
   446	                **applicability_values,
   447	            )
   448	            applicability_changed = True
   449	            continue
   450	        changed_applicability_fields = [
   451	            field
   452	            for field, value in applicability_values.items()
   453	            if getattr(item, field) != value
   454	        ]
   455	        applicability_flipped = item.applicable_flag != spec.applicable
   456	        if (
   457	            applicability_flipped
   458	            and item.completion_status == ChecklistItem.STATUS_COMPLETE
   459	        ):
   460	            raise ChecklistApplicabilityConflict(
   461	                f"Completed checklist item '{item.item_code}' conflicts with corrected applicability."
   462	            )
   463	        if changed_applicability_fields:
   464	            for field, value in applicability_values.items():
   465	                setattr(item, field, value)
   466	            if applicability_flipped:
   467	                item.completion_status = (
   468	                    ChecklistItem.STATUS_PENDING
   469	                    if spec.applicable
   470	                    else ChecklistItem.STATUS_NOT_APPLICABLE
   471	                )
   472	                changed_applicability_fields.append("completion_status")
   473	            item.save(update_fields=changed_applicability_fields)
   474	            applicability_changed = True
   475	        loan_document_id = document_ids.get(spec.code)
   476	        if item.loan_document_id != loan_document_id:
   477	            item.loan_document_id = loan_document_id
   478	            item.save(update_fields=["loan_document"])
   479	            linkage_changed = True
   480	    return SynchronisationResult(
   481	        applicability_changed=applicability_changed,
   482	        linkage_changed=linkage_changed,
   483	    )
   484	
