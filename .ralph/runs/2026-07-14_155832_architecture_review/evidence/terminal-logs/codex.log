   242	def _validate_resolution(payload):
   243	    _exact_fields(payload, RESOLUTION_FIELDS)
   244	    errors = {}
   245	    resolution_type = payload.get("mismatch_resolution_type")
   246	    if resolution_type not in SignatureRecord.RESOLUTION_TYPES:
   247	        errors["mismatch_resolution_type"] = (
   248	            "Must be one of bank_verification_letter, borrower_declaration."
   249	        )
   250	    document_id = _uuid_or_none(
   251	        "mismatch_resolution_document_id",
   252	        payload.get("mismatch_resolution_document_id"),
   253	        errors,
   254	    )
   255	    if document_id is None and "mismatch_resolution_document_id" not in errors:
   256	        errors["mismatch_resolution_document_id"] = "A document id is required."
   257	    remarks = _nullable_text("remarks", payload.get("remarks"), 4000, errors)
   258	    if errors:
   259	        raise ValidationError(errors)
   260	    return {
   261	        "mismatch_resolution_type": resolution_type,
   262	        "mismatch_resolution_document_id": document_id,
   263	        "remarks": remarks,
   264	    }
