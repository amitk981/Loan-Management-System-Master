   511	    def _user(self, role_code, *permission_codes):
   512	        role, _ = Role.objects.get_or_create(
   513	            role_code=role_code,
   514	            defaults={
   515	                "role_name": role_code.replace("_", " ").title(),
   516	                "status": "active",
   517	            },
   518	        )
   519	        for code in permission_codes:
   520	            permission, _ = Permission.objects.get_or_create(
   521	                permission_code=code,
   522	                defaults={
   523	                    "permission_name": code,
   524	                    "module_name": "documents",
   525	                    "risk_level": "high",
   526	                },
   527	            )
   528	            RolePermission.objects.get_or_create(role=role, permission=permission)
   529	        user = User.objects.create(
   530	            full_name=role.role_name,
   531	            email=f"signature-{User.objects.count() + 1}@example.com",
   532	            status="active",
   533	            primary_role=role,
   534	        )
   535	        user.set_password(self.password)
   536	        user.save(update_fields=["password_hash"])
   537	        return user
   538	
   539	    def _auth(self, user):
   540	        response = self.client.post(
   541	            "/api/v1/auth/login/",
   542	            {"email": user.email, "password": self.password},
   543	            content_type="application/json",
   544	        )
   545	        self.assertEqual(response.status_code, 200, response.content)
   546	        return {"HTTP_AUTHORIZATION": f"Bearer {response.json()['data']['access_token']}"}
