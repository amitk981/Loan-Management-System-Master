   136	    @property
   137	    def renderer_validation_status(self):
   138	        if (
   139	            self.renderer_contract_version == self.RENDERER_CONTRACT_V1
   140	            and self.renderer_validated_document_id == self.document_id
   141	            and self.renderer_validated_checksum_sha256
   142	            and self.document_id
   143	            and self.document.checksum_sha256
   144	            == self.renderer_validated_checksum_sha256
   145	        ):
   146	            return self.RENDERER_CURRENT_VALIDATED
   147	        return self.RENDERER_LEGACY_UNVERIFIED
