   389	def _signature_mismatch(application):
   390	    from sfpcl_credit.legal_documents.models import SignatureRecord
   391	
   392	    rows = SignatureRecord.objects.filter(
   393	        loan_document__loan_application=application
   394	    ).values(
   395	        "signature_status",
   396	        "verified_by_user_id",
   397	        "verified_at",
   398	        "mismatch_resolution_type",
   399	    )
   400	    fact = application_facts.resolve_signature_mismatch_fact(
   401	        legal_signature_rows=rows,
   402	        application_id=application.pk,
   403	        member_id=application.member_id,
   404	    )
   405	    return fact.mismatch is True, fact.source, fact.blocker
