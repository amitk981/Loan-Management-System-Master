   122	def resolve_mismatch(*, actor, signature_record_id, payload, metadata):
   123	    document_authority.require_mutation_actor(actor=actor, permission=RESOLVE_PERMISSION)
   124	    if "company_secretary" not in actor.role_codes():
   125	        raise AccessDenied
   126	    cleaned = _validate_resolution(payload)
   127	    with transaction.atomic():
   128	        signature_record = (
   129	            SignatureRecord.objects.select_for_update()
   130	            .select_related("loan_document__loan_application", "mismatch_resolution_document")
   131	            .filter(pk=signature_record_id)
   132	            .first()
   133	        )
   134	        if signature_record is None:
   135	            raise NotFound
   136	        loan_document = document_authority.resolve_current_stage4_target(
   137	            actor=actor,
   138	            permission=RESOLVE_PERMISSION,
   139	            loan_document_id=signature_record.loan_document_id,
   140	            for_update=True,
   141	        )
   142	        evidence = _resolve_evidence(
   143	            application_id=loan_document.loan_application_id,
   144	            resolution_type=cleaned["mismatch_resolution_type"],
   145	            document_id=cleaned["mismatch_resolution_document_id"],
   146	        )
   147	        requested = {
   148	            "mismatch_resolution_type": cleaned["mismatch_resolution_type"],
   149	            "mismatch_resolution_document_id": str(evidence.document_id),
   150	            "remarks": cleaned["remarks"],
   151	        }
   152	        current = {
   153	            "mismatch_resolution_type": signature_record.mismatch_resolution_type,
   154	            "mismatch_resolution_document_id": (
   155	                str(signature_record.mismatch_resolution_document_id)
   156	                if signature_record.mismatch_resolution_document_id
