   538	        entity_type="document_checklist",
   539	        entity_id=checklist.pk,
   540	        old_value_json={},
   541	        new_value_json=evidence,
   542	        ip_address=(request_meta or {}).get("ip_address", ""),
   543	        user_agent=(request_meta or {}).get("user_agent", ""),
   544	    )
   545	    record_workflow_event(
   546	        actor=actor,
   547	        workflow_name="documentation_checklist",
   548	        entity_type="document_checklist",
   549	        entity_id=checklist.pk,
   550	        from_state=None,
   551	        to_state=checklist.checklist_status,
   552	        trigger_reason="Created automatically from approved sanction facts.",
   553	        action_code=CREATED_ACTION,
   554	        metadata=evidence,
