   580	        entity_type="document_checklist",
   581	        entity_id=checklist.pk,
   582	        old_value_json={"items": old_snapshot},
   583	        new_value_json={
   584	            "items": new_snapshot,
   585	            **evidence,
   586	        },
   587	        ip_address=(request_meta or {}).get("ip_address", ""),
