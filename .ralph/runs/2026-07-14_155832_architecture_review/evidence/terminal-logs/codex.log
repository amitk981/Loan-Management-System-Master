    19	            {field: "Unknown query parameter." for field in sorted(unknown)}
    20	        )
    21	    page = _positive_int("page", query_params.get("page"), 1)
    22	    page_size = min(
    23	        _positive_int("page_size", query_params.get("page_size"), _DEFAULT_PAGE_SIZE),
    24	        _MAX_PAGE_SIZE,
    25	    )
