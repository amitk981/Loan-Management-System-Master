     1	"""Application-owned cancelled-cheque facts exposed to downstream checklists."""
     2	
     3	from dataclasses import dataclass
     4	
     5	from sfpcl_credit.members.models import CancelledCheque
     6	
     7	
     8	@dataclass(frozen=True)
     9	class SignatureMismatchFact:
    10	    mismatch: bool | None
    11	    source: str
    12	    blocker: str | None
    13	
    14	
    15	def resolve_cancelled_cheque_signature_fact(*, application_id, member_id):
    16	    """Return a decision only when every related cheque row is valid and verified."""
    17	    rows = list(
    18	        CancelledCheque.objects.filter(
    19	            loan_application_id=application_id,
    20	            member_id=member_id,
    21	        ).values("verification_status", "signature_mismatch_flag")
    22	    )
    23	    if not rows:
    24	        return SignatureMismatchFact(
    25	            None,
    26	            "signature_mismatch_source_missing",
    27	            "signature_mismatch_source_missing",
    28	        )
    29	    valid_statuses = CancelledCheque.VERIFICATION_STATUSES
    30	    if any(row["verification_status"] not in valid_statuses for row in rows):
    31	        return SignatureMismatchFact(
    32	            None,
    33	            "signature_mismatch_source_malformed",
    34	            "signature_mismatch_source_malformed",
    35	        )
    36	    if any(row["verification_status"] != "verified" for row in rows):
    37	        return SignatureMismatchFact(
    38	            None,
    39	            "signature_mismatch_source_unverified",
    40	            "signature_mismatch_source_unverified",
    41	        )
    42	    decisions = {row["signature_mismatch_flag"] for row in rows}
    43	    if decisions == {True}:
    44	        return SignatureMismatchFact(True, "persisted_signature_mismatch", None)
    45	    if decisions == {False}:
    46	        return SignatureMismatchFact(False, "persisted_signature_match", None)
    47	    return SignatureMismatchFact(
    48	        None,
    49	        "persisted_signature_mismatch_conflict",
    50	        "signature_mismatch_conflicting",
    51	    )
    52	
    53	
    54	def resolve_signature_mismatch_fact(*, legal_signature_rows, application_id, member_id):
    55	    """Prefer unanimous verified legal-owner decisions over intake cheque facts.
    56	
    57	    The caller owns retrieval of legal rows; this application-owned seam owns the meaning of
    58	    downstream mismatch truth and therefore avoids an applications-to-legal ORM dependency.
    59	    """
    60	    unresolved_mismatch = False
    61	    resolved_mismatch = False
    62	    for row in legal_signature_rows:
    63	        if not row.get("verified_by_user_id") or not row.get("verified_at"):
    64	            continue
    65	        if row.get("signature_status") != "mismatch":
    66	            continue
    67	        if row.get("mismatch_resolution_type"):
    68	            resolved_mismatch = True
    69	        else:
    70	            unresolved_mismatch = True
    71	    if unresolved_mismatch:
    72	        return SignatureMismatchFact(True, "verified_signature_mismatch", None)
    73	    if resolved_mismatch:
    74	        return SignatureMismatchFact(False, "verified_signature_match_or_resolution", None)
    75	    return resolve_cancelled_cheque_signature_fact(
    76	        application_id=application_id,
    77	        member_id=member_id,
    78	    )
     1	"""Single owner-facing authority boundary for document-checklist reads."""
     2	
     3	from dataclasses import dataclass
     4	
     5	from sfpcl_credit.applications.models import LoanApplication
     6	from sfpcl_credit.applications.modules.application_authority import (
     7	    evaluate_application_object_access,
     8	)
     9	from sfpcl_credit.approvals.modules.read_scope import (
    10	    evaluate_approval_case_read_scope,
    11	)
    12	from sfpcl_credit.identity.modules import auth_service
    13	
    14	
    15	READ_PERMISSION = "documents.checklist.read"
    16	LEGACY_READ_PERMISSION = "applications.loan_application.read"
    17	ROUTE_POST_SANCTION = "post_sanction"
    18	ROUTE_PRE_SANCTION = "pre_sanction"
    19	
    20	
    21	@dataclass(frozen=True)
    22	class ChecklistReadResolution:
    23	    route: str | None
    24	    application: LoanApplication | None
    25	    attribution: str
    26	    error_code: str | None = None
    27	
    28	
    29	def resolve_read_access(*, actor, application_id):
    30	    """Resolve compatibility route and object scope before checklist ORM access."""
    31	    permissions = auth_service.effective_permission_codes(actor)
    32	    legacy_read = LEGACY_READ_PERMISSION in permissions
    33	    if (
    34	        not actor.can_authenticate()
    35	        or (READ_PERMISSION not in permissions and not legacy_read)
    36	    ):
    37	        return ChecklistReadResolution(None, None, "global_permission", "FORBIDDEN")
    38	
    39	    application = (
    40	        LoanApplication.objects.select_related("created_by_user", "received_by_user")
    41	        .filter(pk=application_id)
    42	        .first()
    43	    )
    44	    if application is None:
    45	        if READ_PERMISSION in permissions and "compliance_team_member" in actor.role_codes():
    46	            return ChecklistReadResolution(None, None, "documentation_absent_parent", "NOT_FOUND")
    47	        if legacy_read:
    48	            return ChecklistReadResolution(
    49	                ROUTE_PRE_SANCTION, None, "legacy_application_route"
    50	            )
    51	        return ChecklistReadResolution(
    52	            None, None, "absent_parent_nondisclosure", "OBJECT_ACCESS_DENIED"
    53	        )
    54	    if application.application_status != LoanApplication.STATUS_APPROVED_BY_SANCTION:
    55	        return ChecklistReadResolution(
    56	            ROUTE_PRE_SANCTION, application, "legacy_application_route"
    57	        )
    58	    if READ_PERMISSION not in permissions:
    59	        return ChecklistReadResolution(None, application, "global_permission", "FORBIDDEN")
    60	
    61	    case = (
    62	        application.sanction_approval_cases.prefetch_related("actions")
    63	        .order_by("-cycle_number", "-submitted_at")
    64	        .first()
    65	    )
    66	    if case is None:
    67	        return ChecklistReadResolution(
    68	            None, application, "missing_approval_scope", "OBJECT_ACCESS_DENIED"
    69	        )
