   203	def _validate_capture(payload):
   204	    _exact_fields(payload, CAPTURE_FIELDS)
   205	    errors = {}
   206	    party_type = payload.get("signer_party_type")
   207	    method = payload.get("signature_method")
   208	    status = payload.get("signature_status")
   209	    mismatch = payload.get("signature_mismatch_flag")
   210	    if party_type not in SignatureRecord.PARTY_TYPES:
   211	        errors["signer_party_type"] = "Must be one of borrower, nominee, witness, user."
   212	    if method not in SignatureRecord.METHODS:
   213	        errors["signature_method"] = "Must be one of wet_ink, digital, scanned."
   214	    if status not in SignatureRecord.STATUSES:
   215	        errors["signature_status"] = "Must be one of pending, signed, mismatch."
   216	    if not isinstance(mismatch, bool):
   217	        errors["signature_mismatch_flag"] = "Must be a boolean."
   218	    signer_name = _required_text(
   219	        "signer_name_snapshot", payload.get("signer_name_snapshot"), 255, errors
   220	    )
   221	    signer_id = _uuid_or_none("signer_party_id", payload.get("signer_party_id"), errors)
   222	    signed_at = _datetime_or_none("signed_at", payload.get("signed_at"), errors)
   223	    if status == "pending" and (signed_at is not None or mismatch is not False):
   224	        errors["signature_status"] = "Pending signature cannot carry signed or mismatch facts."
   225	    if status == "signed" and (signed_at is None or mismatch is not False):
   226	        errors["signature_status"] = "Signed signature requires signed_at and no mismatch."
   227	    if status == "mismatch" and mismatch is not True:
   228	        errors["signature_mismatch_flag"] = "Mismatch status requires a true mismatch flag."
   229	    if errors:
   230	        raise ValidationError(errors)
   231	    return {
   232	        "signer_party_type": party_type,
   233	        "signer_party_id": signer_id,
   234	        "signer_name_snapshot": signer_name,
   235	        "signature_method": method,
   236	        "signature_status": status,
   237	        "signed_at": signed_at,
   238	        "signature_mismatch_flag": mismatch,
   239	    }
