   258	def _validate_request(payload):
   259	    errors = {
   260	        field: "Unknown field." for field in sorted(set(payload.keys()) - _REQUEST_FIELDS)
   261	    }
   262	    cleaned = {}
   263	    for field in ("document_type", "template_id", "output_format"):
   264	        value = str(payload.get(field) or "").strip()
   265	        if not value:
   266	            errors[field] = "This field is required."
   267	        cleaned[field] = value
   268	    cleaned["output_format"] = cleaned["output_format"].lower()
   269	    if cleaned["output_format"] and cleaned["output_format"] not in ALLOWED_FORMATS:
   270	        errors["output_format"] = "Must be pdf or docx."
