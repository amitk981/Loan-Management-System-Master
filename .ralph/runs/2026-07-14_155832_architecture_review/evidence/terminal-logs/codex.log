   168	        if "company_secretary" not in actor.role_codes():
   169	            errors["status"] = "Only Company Secretary authority may record completed status."
   170	    if errors:
   171	        raise ValidationError(errors)
   172	    if cleaned["evidence_document_id"]:
   173	        try:
