   434	def _exact_fields(payload, allowed):
   435	    if not isinstance(payload, dict):
   436	        raise ValidationError({"body": "A JSON object is required."})
   437	    unknown = set(payload) - allowed
   438	    missing = allowed - set(payload)
   439	    if unknown or missing:
   440	        raise ValidationError(
   441	            {
   442	                **{field: "Unknown field." for field in sorted(unknown)},
   443	                **{field: "This field is required." for field in sorted(missing)},
   444	            }
   445	        )
   446	
   447	
   448	def _required_text(field, value, maximum, errors):
   449	    if not isinstance(value, str) or not value.strip():
   450	        errors[field] = "A non-empty string is required."
   451	        return ""
   452	    value = value.strip()
   453	    if len(value) > maximum:
   454	        errors[field] = f"Must be at most {maximum} characters."
   455	    return value
   456	
   457	
   458	def _nullable_text(field, value, maximum, errors):
   459	    if value is None:
   460	        return None
   461	    if not isinstance(value, str):
   462	        errors[field] = "Must be a string or null."
   463	        return None
   464	    value = value.strip()
   465	    if len(value) > maximum:
   466	        errors[field] = f"Must be at most {maximum} characters."
   467	    return value or None
   468	
   469	
   470	def _uuid_or_none(field, value, errors):
   471	    if value is None:
   472	        return None
   473	    try:
   474	        return uuid.UUID(str(value))
   475	    except (ValueError, TypeError, AttributeError):
   476	        errors[field] = "Must be a valid UUID or null."
   477	        return None
   478	
   479	
   480	def _datetime_or_none(field, value, errors):
   481	    if value is None:
   482	        return None
   483	    if not isinstance(value, str):
   484	        errors[field] = "Must be an ISO-8601 datetime or null."
   485	        return None
   486	    parsed = parse_datetime(value)
   487	    if parsed is None or not timezone.is_aware(parsed):
   488	        errors[field] = "Must be an ISO-8601 datetime with timezone or null."
   489	        return None
   490	    return parsed
   491	
   492	
   493	def _iso(value):
   494	    return value.isoformat().replace("+00:00", "Z") if value else None
   495	
   496	
   497	def validation_field_errors(exc):
   498	    if hasattr(exc, "message_dict"):
   499	        return {field: messages[0] for field, messages in exc.message_dict.items()}
   500	    return {"non_field_errors": str(exc)}

