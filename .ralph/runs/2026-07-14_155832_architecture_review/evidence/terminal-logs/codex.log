   326	def _applicability_specs(application, facts):
   327	    specs = [
   328	        ItemSpec(code, label, index, True, "source_always_required")
   329	        for index, (code, label) in enumerate(_BASE_ITEMS, start=1)
   330	    ]
   331	    subsidiary = facts.subsidiary_route is True
   332	    specs.append(
   333	        ItemSpec(
   334	            "tri_party_agreement",
   335	            "Declaration / Tri-party Agreement",
   336	            5,
   337	            subsidiary,
   338	            (
   339	                "frozen_subsidiary_repayment_route"
   340	                if facts.subsidiary_route is not None
   341	                else "subsidiary_route_source_missing"
   342	            ),
   343	            None if facts.subsidiary_route is not None else "subsidiary_route_source_missing",
   344	        )
   345	    )
   346	    if facts.holding_mode == "physical":
   347	        sh4, cdsl, blocker, source = True, False, None, "frozen_physical_shareholding"
   348	    elif facts.holding_mode == "demat":
   349	        sh4, cdsl, blocker, source = False, True, None, "frozen_demat_shareholding"
   350	    elif facts.holding_mode == "mixed":
   351	        sh4, cdsl, blocker, source = False, False, "shareholding_mode_conflicting", "frozen_shareholding_mode_conflict"
   352	    else:
   353	        sh4, cdsl, blocker, source = False, False, "shareholding_mode_missing", "frozen_shareholding_mode_missing"
   354	    specs.extend(
   355	        (
   356	            ItemSpec("sh4", "Share Transfer Form SH-4", 6, sh4, source, blocker),
   357	            ItemSpec("cdsl_pledge", "CDSL Pledge Evidence", 7, cdsl, source, blocker),
   358	        )
   359	    )
   360	    specs.extend(
   361	        (
   362	            ItemSpec("term_sheet", "Term Sheet", 8, True, "source_always_required"),
   363	            ItemSpec("loan_agreement", "Loan Agreement", 9, True, "source_always_required"),
   364	        )
   365	    )
   366	    mismatch, mismatch_source, mismatch_blocker = _signature_mismatch(application)
   367	    specs.append(
   368	        ItemSpec(
   369	            "bank_verification_letter",
   370	            "Bank Verification Letter",
   371	            10,
   372	            mismatch,
   373	            mismatch_source,
   374	            mismatch_blocker,
   375	        )
   376	    )
   377	    specs.append(
   378	        ItemSpec(
   379	            "final_checklist",
   380	            "Final Document Checklist",
   381	            11,
   382	            True,
   383	            "source_always_required",
   384	        )
   385	    )
   386	    return specs
