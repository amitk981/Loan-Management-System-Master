   263	def read_for_application(*, actor, application_id):
   264	    resolution = document_checklist_access.resolve_read_access(
   265	        actor=actor, application_id=application_id
   266	    )
   267	    if resolution.route == document_checklist_access.ROUTE_PRE_SANCTION:
   268	        raise PreSanctionChecklist
   269	    if resolution.error_code == "NOT_FOUND":
   270	        raise ChecklistNotFound
   271	    if resolution.error_code:
   272	        raise ChecklistAccessDenied(resolution.error_code)
   273	    application = resolution.application
   274	    checklist = (
   275	        DocumentChecklist.objects.prefetch_related("items")
   276	        .filter(loan_application=application)
   277	        .first()
   278	    )
   279	    if checklist is None:
   280	        raise ChecklistNotFound
   281	    return serialize(checklist)
