   548	    def _legal_document(self, document_type, file_name, checksum_character, actor):
   549	        document = DocumentFile.objects.create(
   550	            file_name=file_name,
   551	            file_extension=".pdf",
   552	            mime_type="application/pdf",
   553	            file_size_bytes=8,
   554	            storage_provider="local",
   555	            storage_key=f"tests/{file_name}",
   556	            checksum_sha256=checksum_character * 64,
   557	            uploaded_by_user=actor,
   558	            sensitivity_level="confidential",
   559	        )
   560	        template = DocumentTemplate.objects.create(
   561	            template_code=f"signature-{document_type}-{DocumentTemplate.objects.count() + 1}",
   562	            template_name=document_type.replace("_", " ").title(),
   563	            document_type=document_type,
   564	            borrower_type="individual_farmer",
   565	            template_version="1.0",
   566	            template_file=document,
   567	            approval_status="approved",
   568	            effective_from="2026-01-01",
   569	        )
   570	        LoanDocument.objects.create(
   571	            loan_application=self.application,
   572	            document_type=document_type,
   573	            document_category="legal",
   574	            party_required="borrower",
   575	            document_template=template,
   576	            document=document,
   577	            output_format="pdf",
   578	            generation_status=LoanDocument.GENERATION_GENERATED,
   579	            execution_status=LoanDocument.EXECUTION_PENDING,
   580	            verification_status=LoanDocument.VERIFICATION_PENDING,
   581	            renderer_contract_version=LoanDocument.RENDERER_CONTRACT_V1,
   582	            renderer_validated_document_id=document.pk,
   583	            renderer_validated_checksum_sha256=document.checksum_sha256,
   584	        )
   585	        return document

