+from sfpcl_credit.tests.test_signature_mismatch_api import SignatureMismatchApiTests
+from sfpcl_credit.tests.test_stamp_notary_api import StampDutyAndNotarisationApiTests
+
+
+class SignatureLifecycleRepro(SignatureMismatchApiTests):
+    def test_unresolved_mismatch_cannot_be_overwritten_by_capture(self):
+        url = f"/api/v1/loan-documents/{self.loan_document.pk}/signatures/"
+        mismatch = {
+            "signer_party_type": "borrower",
+            "signer_party_id": str(self.application.member_id),
+            "signer_name_snapshot": "Signature Test Borrower",
+            "signature_method": "wet_ink",
+            "signature_status": "mismatch",
+            "signed_at": None,
+            "signature_mismatch_flag": True,
+        }
+        created = self.client.post(
+            url, mismatch, content_type="application/json", **self._auth(self.actor)
+        )
+        self.assertEqual(created.status_code, 200, created.content)
+
+        overwritten = self.client.post(
+            url,
+            {
+                **mismatch,
+                "signature_status": "signed",
+                "signed_at": "2026-06-22T12:00:00Z",
+                "signature_mismatch_flag": False,
+            },
+            content_type="application/json",
+            **self._auth(self.actor),
+        )
+        self.assertEqual(overwritten.status_code, 409, overwritten.content)
+
+
+class StampAuthorityRepro(StampDutyAndNotarisationApiTests):
+    def test_compliance_cannot_record_cs_owned_insufficient_decision(self):
+        response = self.client.post(
+            f"/api/v1/loan-documents/{self.loan_document.pk}/stamp-duty-record/",
+            {
+                "stamp_paper_amount": "100.00",
+                "stamp_type": "physical",
+                "stamp_number": "UNDER-STAMPED",
+                "stamp_purchase_date": "2026-06-20",
+                "executed_date": "2026-06-22",
+                "status": "insufficient",
+                "remarks": "Adverse verification outcome.",
+            },
+            content_type="application/json",
+            **self._auth(self.actor),
+        )
+        self.assertEqual(response.status_code, 403, response.content)
