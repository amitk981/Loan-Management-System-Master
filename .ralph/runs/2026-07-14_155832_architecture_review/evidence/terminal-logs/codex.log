    34	def resolve_current_stage4_target(*, actor, permission, loan_document_id, for_update=False):
    35	    """Resolve the sanctioned documentation queue before owner/evidence queries.
    36	
    37	    Auth §19.2 defines sanctioned documentation applications as the canonical object scope for
    38	    Compliance Team and Company Secretary actors. The permission remains action-specific.
    39	    """
    40	    require_mutation_actor(actor=actor, permission=permission)
    41	    queryset = LoanDocument.objects
    42	    if for_update:
    43	        queryset = queryset.select_for_update(of=("self",))
    44	    loan_document = (
    45	        queryset.select_related("document", "loan_application")
    46	        .filter(pk=loan_document_id)
    47	        .first()
    48	    )
    49	    if loan_document is None:
    50	        raise NotFound
    51	    if (
    52	        loan_document.loan_application.application_status
    53	        != LoanApplication.STATUS_APPROVED_BY_SANCTION
    54	    ):
    55	        raise AccessDenied("OBJECT_ACCESS_DENIED")
    56	    if loan_document.renderer_validation_status != LoanDocument.RENDERER_CURRENT_VALIDATED:
    57	        raise ProvenanceConflict
    58	    return loan_document
