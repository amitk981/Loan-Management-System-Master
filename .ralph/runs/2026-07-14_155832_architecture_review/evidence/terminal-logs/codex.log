   625	        entity_type="document_checklist",
   626	        entity_id=checklist.pk,
   627	        old_value_json={"items": old_snapshot},
   628	        new_value_json={
   629	            "items": new_snapshot,
   630	            **evidence,
   631	        },
   632	        ip_address=(request_meta or {}).get("ip_address", ""),
   633	        user_agent=(request_meta or {}).get("user_agent", ""),
   634	    )
   635	    record_workflow_event(
