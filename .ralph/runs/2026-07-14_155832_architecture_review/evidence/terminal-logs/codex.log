   216	    ):
   217	        raise InvalidChecklistState(
   218	            "Checklist creation requires the latest coherent approved sanction decision."
   219	        )
   220	    specs = _applicability_specs(application, facts)
   221	    document_ids = _generated_document_ids(application.pk)
   222	    checklist = (
   223	        DocumentChecklist.objects.select_for_update()
   224	        .filter(loan_application=application)
   225	        .first()
   226	    )
   227	    created = checklist is None
   228	    if created:
   229	        checklist = DocumentChecklist.objects.create(loan_application=application)
   230	    old_snapshot = _item_snapshot(checklist)
   231	    changes = _synchronise_items(checklist, specs, document_ids)
   232	    new_snapshot = _item_snapshot(checklist)
   233	    if created:
   234	        _record_creation(
   235	            actor, checklist, facts, new_snapshot, source_reason, request_meta
   236	        )
   237	    elif changes.applicability_changed or changes.linkage_changed:
   238	        checklist.updated_at = timezone.now()
   239	        checklist.save(update_fields=["updated_at"])
   240	        if changes.applicability_changed:
   241	            _record_change(
   242	                actor,
   243	                checklist,
   244	                facts,
   245	                old_snapshot,
   246	                new_snapshot,
   247	                source_reason,
   248	                request_meta,
   249	            )
   250	        if changes.linkage_changed:
   251	            _record_linkage_change(
   252	                actor,
   253	                checklist,
   254	                facts,
   255	                old_snapshot,
   256	                new_snapshot,
   257	                source_reason,
   258	                request_meta,
   259	            )
   260	    return checklist
