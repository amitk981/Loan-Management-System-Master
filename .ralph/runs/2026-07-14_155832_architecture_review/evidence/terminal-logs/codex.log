    74	def generate(*, actor, application_id, payload, metadata, storage=None):
    75	    permissions = auth_service.effective_permission_codes(actor)
    76	    if (
    77	        not actor.can_authenticate()
    78	        or GENERATE_PERMISSION not in permissions
    79	        or document_services.TEMPLATE_FILE_REFERENCE_PERMISSION not in permissions
    80	    ):
    81	        raise LegalDocumentAccessDenied()
    82	    scoped_application, access = (
    83	        application_authority.resolve_documentation_application_access(
    84	            application_id=application_id,
    85	            actor=actor,
    86	            required_permission=GENERATE_PERMISSION,
    87	            actor_permissions=permissions,
    88	        )
    89	    )
    90	    if not access.allowed:
    91	        raise LegalDocumentAccessDenied(access.error_code or "OBJECT_ACCESS_DENIED")
    92	    if scoped_application is None:
    93	        raise LegalDocumentNotFound
    94	    cleaned = _validate_request(payload)
    95	    storage = storage or LocalDocumentStorage()
    96	    stored = None
    97	    try:
    98	        with transaction.atomic():
    99	            application = application_facts.resolve_for_generation(
   100	                application_id=application_id, for_update=True
   101	            )
   102	            if application is None:
   103	                raise ValidationError({"loan_application_id": "Loan application was not found."})
   104	            if application.application_status != application_facts.sanctioned_status():
   105	                raise InvalidGenerationState(
   106	                    "Loan documents can be generated only after sanction approval."
   107	                )
   108	            variant = document_templates.resolve_borrower_template_variant(
   109	                application.borrower_type
   110	            )
   111	            template = _resolve_template(cleaned, variant)
   112	            document_services.resolve_template_source_reference(
   113	                actor_permissions=permissions,
   114	                document_id=template.template_file_id,
   115	            )
   116	            _require_document_prerequisites(
   117	                application_id=application.application_id,
   118	                document_type=cleaned["document_type"],
   119	            )
   120	            replay = LoanDocument.objects.select_related("document").filter(
   121	                loan_application_id=application.application_id,
   122	                document_template=template,
   123	                output_format=cleaned["output_format"],
   124	            ).first()
   125	            if replay is not None:
   126	                if (
   127	                    replay.renderer_validation_status
   128	                    != LoanDocument.RENDERER_CURRENT_VALIDATED
   129	                ):
   130	                    raise RendererProvenanceConflict()
   131	                return serialize_generation(replay)
   132	
   133	            try:
   134	                template_source = storage.read_verified(template.template_file)
   135	            except (OSError, ValueError):
   136	                raise ValidationError(
   137	                    {"template_file_id": "Template source bytes are unavailable or invalid."}
   138	                )
   139	
   140	            sanction = approval_facts.resolve_for_generation(
   141	                application_id=application.application_id
   142	            )
   143	            if sanction is None:
   144	                raise InvalidGenerationState(
   145	                    "A retained sanctioned decision is required for document generation."
   146	                )
   147	            merge_values = _project_merge_values(application, sanction)
   148	            declared = template.merge_fields_json or []
   149	            _validate_declared_merge_fields(declared, merge_values)
   150	            file_name = _safe_output_name(
   151	                cleaned["document_type"],
   152	                application.application_reference_number,
   153	                cleaned["output_format"],
   154	            )
   155	            rendered = document_renderer.render(
   156	                output_format=cleaned["output_format"],
   157	                template_bytes=template_source,
   158	                merge_values={field: merge_values[field] for field in declared},
   159	            )
   160	            stored = storage.store(ContentFile(rendered.content, name=file_name))
   161	            generated_file = DocumentFile.objects.create(
   162	                file_name=file_name,
   163	                file_extension=f".{cleaned['output_format']}",
   164	                mime_type=rendered.mime_type,
   165	                file_size_bytes=stored.file_size_bytes,
   166	                storage_provider=stored.storage_provider,
   167	                storage_key=stored.storage_key,
   168	                checksum_sha256=stored.checksum_sha256,
   169	                uploaded_by_user=actor,
   170	                sensitivity_level=DocumentFile.SENSITIVITY_CONFIDENTIAL,
   171	            )
   172	            loan_document = LoanDocument.objects.create(
   173	                loan_application_id=application.application_id,
   174	                document_type=cleaned["document_type"],
   175	                document_category="legal",
   176	                party_required="borrower",
   177	                document_template=template,
   178	                document=generated_file,
   179	                output_format=cleaned["output_format"],
   180	                generation_status=LoanDocument.GENERATION_GENERATED,
   181	                execution_status=LoanDocument.EXECUTION_PENDING,
   182	                verification_status=LoanDocument.VERIFICATION_PENDING,
   183	                renderer_contract_version=LoanDocument.RENDERER_CONTRACT_V1,
   184	                renderer_validated_document_id=generated_file.pk,
   185	                renderer_validated_checksum_sha256=generated_file.checksum_sha256,
   186	            )
   187	            _record_evidence(
   188	                actor=actor,
   189	                metadata=metadata,
   190	                loan_document=loan_document,
   191	                template=template,
   192	            )
   193	            return serialize_generation(loan_document)
   194	    except Exception:
   195	        if stored is not None:
   196	            storage.delete(stored)
   197	        raise
