   486	def _item_snapshot(checklist):
   487	    return {
   488	        item.item_code: {
   489	            "required_flag": item.required_flag,
   490	            "applicable_flag": item.applicable_flag,
   491	            "completion_status": item.completion_status,
   492	            "applicability_source": item.applicability_source,
   493	            "applicability_blocker": item.applicability_blocker,
   494	            "loan_document_id": (
   495	                str(item.loan_document_id) if item.loan_document_id else None
   496	            ),
   497	        }
   498	        for item in checklist.items.order_by("display_order")
   499	    }
