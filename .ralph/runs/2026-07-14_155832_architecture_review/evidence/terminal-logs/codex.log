   551	    def clean(self):
   552	        from django.core.exceptions import ValidationError
   553	
   554	        super().clean()
   555	        errors = {}
   556	        if self.item_code not in self.ITEM_CODES:
   557	            errors["item_code"] = "Unsupported checklist item code."
   558	        if self.completion_status not in self.STATUSES:
   559	            errors["completion_status"] = "Unsupported completion status."
   560	        applicable_state = (
   561	            self.required_flag
   562	            and self.applicable_flag
   563	            and self.completion_status in {self.STATUS_PENDING, self.STATUS_COMPLETE}
   564	            and not self.applicability_blocker
   565	        )
   566	        inapplicable_state = (
   567	            not self.required_flag
   568	            and not self.applicable_flag
   569	            and self.completion_status == self.STATUS_NOT_APPLICABLE
   570	        )
   571	        if not (applicable_state or inapplicable_state):
   572	            errors["applicable_flag"] = "Checklist applicability state is inconsistent."
   573	        if self.completion_status != self.STATUS_COMPLETE and (
   574	            self.verified_by_user_id is not None or self.verified_at is not None
   575	        ):
   576	            errors["completion_status"] = "Pending items cannot carry verification facts."
   577	        if (
   578	            self.loan_document_id
   579	            and self.document_checklist_id
   580	            and self.loan_document.loan_application_id
   581	            != self.document_checklist.loan_application_id
   582	        ):
   583	            errors["loan_document"] = "Loan document must belong to the checklist application."
   584	        if errors:
   585	            raise ValidationError(errors)
   586	
   587	    def save(self, *args, **kwargs):
   588	        self.full_clean()
   589	        return super().save(*args, **kwargs)

