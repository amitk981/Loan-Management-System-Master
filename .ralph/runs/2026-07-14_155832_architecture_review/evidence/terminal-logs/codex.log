   502	def _applicability_snapshot(snapshot):
   503	    """Project only facts owned by applicability synchronisation."""
   504	    return {
   505	        code: {
   506	            key: value
   507	            for key, value in facts.items()
   508	            if key != "loan_document_id"
   509	        }
   510	        for code, facts in snapshot.items()
   511	    }
