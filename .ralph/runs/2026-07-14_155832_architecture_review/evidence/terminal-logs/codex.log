   334	def _record_evidence(
   335	    actor, loan_document, record, action, old, new, metadata, workflow_state=None
   336	):
   337	    context = {
   338	        "loan_document_id": str(loan_document.pk),
   339	        "loan_application_id": str(loan_document.loan_application_id),
   340	        "signature_record_id": str(record.pk),
   341	        "actor_role_codes": actor.role_codes(),
   342	        "actor_team_codes": actor.team_codes(),
   343	        "request_id": metadata.request_id,
   344	        **new,
   345	    }
   346	    AuditLog.objects.create(
   347	        actor_user=actor,
   348	        actor_type="user",
   349	        action=action,
   350	        entity_type="signature_record",
   351	        entity_id=record.pk,
   352	        old_value_json=old,
   353	        new_value_json=context,
   354	        ip_address=metadata.ip_address,
   355	        user_agent=metadata.user_agent,
   356	    )
   357	    VersionHistory.objects.create(
   358	        versioned_entity_type="signature_record",
   359	        versioned_entity_id=record.pk,
   360	        version_number=str(
   361	            VersionHistory.objects.filter(
   362	                versioned_entity_type="signature_record",
   363	                versioned_entity_id=record.pk,
   364	            ).count()
   365	            + 1
   366	        ),
   367	        change_summary=action,
   368	        author_user=actor,
   369	        old_value_json=old,
   370	        new_value_json=context,
   371	        effective_from=timezone.localdate(),
   372	    )
   373	    record_workflow_event(
   374	        actor=actor,
   375	        workflow_name="loan_document_signature",
   376	        entity_type="loan_document",
   377	        entity_id=loan_document.pk,
   378	        from_state=old.get("signature_status"),
   379	        to_state=workflow_state or new["signature_status"],
   380	        trigger_reason=action,
   381	        action_code=action,
   382	        metadata=context,
   383	    )
