   158	        "notarised_date": _date("notarised_date", payload.get("notarised_date")),
   159	        "status": status,
   160	        "evidence_document_id": payload.get("evidence_document_id"),
   161	        "remarks": _nullable_text("remarks", payload.get("remarks"), 4000),
   162	    }
   163	    errors = {}
   164	    if status == "completed":
   165	        for field in ("notary_name", "notary_registration_number", "notarised_date", "evidence_document_id"):
   166	            if not cleaned[field]:
