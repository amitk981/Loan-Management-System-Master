   150	def _validate_notary(payload, actor):
   151	    _exact_fields(payload, NOTARY_FIELDS)
   152	    status = payload.get("status")
   153	    if status not in NotarisationRecord.STATUSES:
   154	        raise ValidationError({"status": "Must be one of pending, completed, rejected."})
   155	    cleaned = {
   156	        "notary_name": _nullable_text("notary_name", payload.get("notary_name"), 255),
