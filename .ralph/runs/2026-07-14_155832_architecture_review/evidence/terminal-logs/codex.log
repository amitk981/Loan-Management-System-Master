    61	def record(*, actor, loan_document_id, payload, metadata):
    62	    document_authority.require_mutation_actor(actor=actor, permission=RECORD_PERMISSION)
    63	    if "compliance_team_member" not in actor.role_codes():
    64	        raise AccessDenied
    65	    cleaned = _validate_capture(payload)
    66	    with transaction.atomic():
    67	        loan_document = document_authority.resolve_current_stage4_target(
    68	            actor=actor,
    69	            permission=RECORD_PERMISSION,
    70	            loan_document_id=loan_document_id,
    71	            for_update=True,
    72	        )
    73	        record = (
    74	            SignatureRecord.objects.select_for_update()
    75	            .filter(
    76	                loan_document=loan_document,
    77	                signer_party_type=cleaned["signer_party_type"],
    78	                signer_party_id=cleaned["signer_party_id"],
    79	            )
    80	            .first()
    81	        )
    82	        old = _snapshot(record) if record else {}
    83	        new = _snapshot_values(cleaned)
    84	        old_capture = {field: old.get(field) for field in CAPTURE_FIELDS}
    85	        new_capture = {field: new.get(field) for field in CAPTURE_FIELDS}
    86	        if record is not None and old_capture == new_capture:
    87	            return _serialize(record)
    88	        if record is not None and record.mismatch_resolution_type:
    89	            raise InvalidState(
    90	                "A resolved signature cannot be changed through the capture action."
    91	            )
    92	
    93	        verification_values = (
    94	            {"verified_by_user": actor, "verified_at": timezone.now()}
    95	            if cleaned["signature_status"] in {"signed", "mismatch"}
    96	            else {"verified_by_user": None, "verified_at": None}
    97	        )
    98	        values = {
    99	            **cleaned,
   100	            **verification_values,
   101	            "mismatch_resolution_type": None,
   102	            "mismatch_resolution_document": None,
   103	            "mismatch_resolution_remarks": None,
   104	            "updated_at": timezone.now(),
   105	        }
   106	        if record is None:
   107	            record = SignatureRecord.objects.create(
   108	                loan_document=loan_document, **values
   109	            )
   110	            action = "documents.signature.created"
   111	        else:
   112	            for field, value in values.items():
   113	                setattr(record, field, value)
   114	            record.save(update_fields=list(values))
   115	            action = "documents.signature.changed"
   116	        _project_signature_fact(actor, loan_document, metadata)
   117	        new = _snapshot(record)
   118	        _record_evidence(actor, loan_document, record, action, old, new, metadata)
   119	        return _serialize(record)
