   267	def _resolve_evidence(*, application_id, resolution_type, document_id):
   268	    from sfpcl_credit.legal_documents.models import LoanDocument
   269	
   270	    required_type = (
   271	        "bank_verification_letter"
   272	        if resolution_type == "bank_verification_letter"
   273	        else "borrower_declaration"
   274	    )
   275	    evidence_loan_document = (
   276	        LoanDocument.objects.select_related("document")
   277	        .filter(
   278	            loan_application_id=application_id,
   279	            document_id=document_id,
   280	            document_type=required_type,
   281	        )
   282	        .first()
   283	    )
   284	    if (
   285	        evidence_loan_document is None
   286	        or evidence_loan_document.renderer_validation_status
   287	        != LoanDocument.RENDERER_CURRENT_VALIDATED
   288	    ):
   289	        raise EvidenceConflict(
   290	            "Resolution evidence was not found with retained legal provenance for this application."
   291	        )
   292	    if resolution_type == "borrower_declaration":
   293	        stamp = getattr(evidence_loan_document, "stamp_duty_record", None)
   294	        if stamp is None or stamp.status != "adequate":
   295	            raise EvidenceConflict(
   296	                "Borrower declaration resolution requires adequate non-judicial stamp evidence."
   297	            )
   298	    try:
   299	        return document_services.resolve_generated_legal_evidence_reference(
   300	            document_id=evidence_loan_document.document_id,
   301	            expected_checksum_sha256=(
   302	                evidence_loan_document.renderer_validated_checksum_sha256
   303	            ),
   304	        )
   305	    except ValidationError as exc:
   306	        raise EvidenceConflict(
   307	            "Resolution evidence was not found with retained legal provenance for this application."
   308	        ) from exc
