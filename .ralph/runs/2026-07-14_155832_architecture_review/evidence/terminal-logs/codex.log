   298	def _nullable_text(field, value, maximum):
   299	    if value is None:
   300	        return None
   301	    if not isinstance(value, str):
   302	        raise ValidationError({field: "Must be a string or null."})
   303	    value = value.strip()
   304	    if len(value) > maximum:
   305	        raise ValidationError({field: f"Must be at most {maximum} characters."})
   306	    return value or None
   307	
   308	
   309	def _iso(value):
   310	    return value.isoformat() if value else None
