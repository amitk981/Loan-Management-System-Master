   278	def _exact_fields(payload, allowed):
   279	    if not isinstance(payload, dict):
   280	        raise ValidationError({"body": "A JSON object is required."})
   281	    unknown = set(payload) - allowed
   282	    if unknown:
   283	        raise ValidationError({field: "Unknown field." for field in sorted(unknown)})
   284	    missing = allowed - set(payload)
   285	    if missing:
   286	        raise ValidationError({field: "This field is required." for field in sorted(missing)})
   287	
