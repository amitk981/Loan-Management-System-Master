    48	def upload_document_file(user, request, storage=None):
    49	    cleaned = validate_upload_request(request)
    50	    storage = storage or LocalDocumentStorage()
    51	    uploaded_file = cleaned["file"]
    52	    stored = storage.store(uploaded_file)
    53	    file_name = uploaded_file.name
    54	    file_extension = Path(file_name).suffix or None
    55	
    56	    with transaction.atomic():
    57	        document = DocumentFile.objects.create(
    58	            file_name=file_name,
    59	            file_extension=file_extension,
    60	            mime_type=getattr(uploaded_file, "content_type", "") or None,
    61	            file_size_bytes=stored.file_size_bytes,
    62	            storage_provider=stored.storage_provider,
    63	            storage_key=stored.storage_key,
    64	            checksum_sha256=stored.checksum_sha256,
    65	            uploaded_by_user=user,
    66	            sensitivity_level=cleaned["sensitivity_level"],
    67	        )
    68	        AuditLog.objects.create(
    69	            actor_user=user,
    70	            actor_type="user",
    71	            action=DOCUMENT_UPLOAD_AUDIT_ACTION,
    72	            entity_type="document_file",
    73	            entity_id=document.document_id,
    74	            old_value_json=None,
    75	            new_value_json={
    76	                "document_id": str(document.document_id),
    77	                "file_name": document.file_name,
    78	                "file_extension": document.file_extension,
    79	                "mime_type": document.mime_type,
    80	                "file_size_bytes": document.file_size_bytes,
    81	                "storage_provider": document.storage_provider,
    82	                "storage_key": document.storage_key,
    83	                "checksum_sha256": document.checksum_sha256,
    84	                "sensitivity_level": document.sensitivity_level,
    85	                "document_category": cleaned["document_category"],
    86	                "related_entity_type": cleaned.get("related_entity_type"),
    87	                "related_entity_id": str(cleaned["related_entity_id"])
    88	                if cleaned.get("related_entity_id")
    89	                else None,
    90	            },
    91	            ip_address=request_ip(request),
    92	            user_agent=request_user_agent(request),
    93	        )
    94	    return serialize_document_file(document)
