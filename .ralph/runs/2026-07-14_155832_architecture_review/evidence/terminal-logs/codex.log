   408	def _generated_document_ids(application_id):
   409	    by_type = selectors.latest_generated_metadata_by_type(
   410	        application_id=application_id,
   411	        document_types=set(_DOCUMENT_TYPE_BY_ITEM.values()),
   412	    )
   413	    return {
   414	        item_code: by_type.get(document_type)
   415	        for item_code, document_type in _DOCUMENT_TYPE_BY_ITEM.items()
   416	    }
