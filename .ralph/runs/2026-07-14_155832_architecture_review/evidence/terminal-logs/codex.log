   124	def resolve_referenceable_documents(
   125	    *,
   126	    actor_permissions,
   127	    document_ids_by_field,
   128	    context,
   129	    purpose,
   130	):
   131	    """Resolve document references only when immutable upload provenance proves access."""
   132	    if not document_ids_by_field:
   133	        return {}
   134	    permissions = set(actor_permissions)
   135	    if DOCUMENT_DOWNLOAD_PERMISSION not in permissions:
   136	        raise ValidationError(
   137	            {
   138	                field: _INACCESSIBLE_REFERENCE_MESSAGE
   139	                for field in document_ids_by_field
   140	            }
   141	        )
   142	    general_meeting_context = (
   143	        purpose == GENERAL_MEETING_REFERENCE_PURPOSE
   144	        and context.workflow_scope == GENERAL_MEETING_WORKFLOW_SCOPE
   145	    )
   146	    exception_context = (
   147	        purpose == EXCEPTION_REFERENCE_PURPOSE
   148	        and context.workflow_scope == EXCEPTION_WORKFLOW_SCOPE
   149	    )
   150	    legal_category_access_allowed = (
   151	        bool(
   152	            context.actor_role_codes
   153	            & {"compliance_team_member", "company_secretary", "credit_manager"}
   154	        )
   155	        or context.actor_is_related_case_approver
   156	    )
   157	    documents = DocumentFile.objects.in_bulk(document_ids_by_field.values())
   158	    upload_metadata = {}
   159	    for audit in (
   160	        AuditLog.objects.filter(
   161	            action=DOCUMENT_UPLOAD_AUDIT_ACTION,
   162	            entity_type="document_file",
   163	            entity_id__in=document_ids_by_field.values(),
   164	        )
   165	        .order_by("-created_at", "-audit_log_id")
   166	    ):
   167	        upload_metadata.setdefault(str(audit.entity_id), audit.new_value_json or {})
   168	
   169	    denied_fields = {}
   170	    for field, document_id in document_ids_by_field.items():
   171	        document = documents.get(document_id)
   172	        metadata = upload_metadata.get(str(document_id), {})
   173	        reference_is_allowed = (
   174	            (general_meeting_context or exception_context)
   175	            and context.related_entity_access_allowed
   176	            and legal_category_access_allowed
   177	            and document is not None
   178	            and metadata.get("document_id") == str(document_id)
   179	            and metadata.get("related_entity_type") == context.related_entity_type
   180	            and metadata.get("related_entity_id") == str(context.related_entity_id)
   181	            and metadata.get("document_category") == "legal"
   182	            and document.sensitivity_level in ALLOWED_SENSITIVITY_LEVELS
   183	            and metadata.get("sensitivity_level") == document.sensitivity_level
   184	        )
   185	        if not reference_is_allowed:
   186	            denied_fields[field] = _INACCESSIBLE_REFERENCE_MESSAGE
   187	    if denied_fields:
   188	        raise ValidationError(denied_fields)
   189	    return {
   190	        field: documents[document_id]
   191	        for field, document_id in document_ids_by_field.items()
   192	    }
   193	
