   112	def _validate_stamp(payload, actor):
   113	    _exact_fields(payload, STAMP_FIELDS)
   114	    raw_amount = payload.get("stamp_paper_amount")
   115	    if not isinstance(raw_amount, str) or not _MONEY.fullmatch(raw_amount):
   116	        raise ValidationError({"stamp_paper_amount": "Must be a non-negative two-decimal string."})
   117	    try:
   118	        amount = Decimal(raw_amount)
   119	    except InvalidOperation as exc:
   120	        raise ValidationError({"stamp_paper_amount": "Must be a non-negative two-decimal string."}) from exc
   121	    stamp_type = payload.get("stamp_type")
   122	    status = payload.get("status")
   123	    errors = {}
   124	    if stamp_type not in StampDutyRecord.TYPES:
   125	        errors["stamp_type"] = "Must be one of physical, electronic."
   126	    if status not in StampDutyRecord.STATUSES:
   127	        errors["status"] = "Must be one of pending, adequate, insufficient."
   128	    executed = _date("executed_date", payload.get("executed_date"))
   129	    purchased = _date("stamp_purchase_date", payload.get("stamp_purchase_date"))
   130	    if purchased and executed and purchased > executed:
   131	        errors["stamp_purchase_date"] = "Must be on or before the executed date."
   132	    if status == "adequate":
   133	        if executed is None:
   134	            errors["executed_date"] = "Adequate stamp duty requires an executed date."
   135	        if "company_secretary" not in actor.role_codes():
   136	            errors["status"] = "Only Company Secretary authority may record adequate status."
   137	    if errors:
   138	        raise ValidationError(errors)
   139	    return {
   140	        "stamp_paper_amount": amount,
   141	        "stamp_type": stamp_type,
   142	        "stamp_number": _nullable_text("stamp_number", payload.get("stamp_number"), 120),
   143	        "stamp_purchase_date": purchased,
   144	        "executed_date": executed,
   145	        "status": status,
   146	        "remarks": _nullable_text("remarks", payload.get("remarks"), 4000),
   147	    }
