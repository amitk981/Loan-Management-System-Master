   513	
   514	def _linkage_snapshot(snapshot):
   515	    """Project only the generated-document relationship owned by linkage."""
   516	    return {
   517	        code: {"loan_document_id": facts["loan_document_id"]}
   518	        for code, facts in snapshot.items()
   519	    }
