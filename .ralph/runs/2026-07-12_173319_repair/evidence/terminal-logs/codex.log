+
+afterEach(() => {
+  cleanup();
+  vi.restoreAllMocks();
+});
+
+describe('MemberProfile container', () => {
+  it('loads canonical member detail once when Strict Mode replays the mount effect', () => {
+    const pending = new Promise<memberApi.MemberProfileDetail>(() => undefined);
