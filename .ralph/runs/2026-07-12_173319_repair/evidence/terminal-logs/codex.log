+
+    render(
+      <StrictMode>
+        <MemberProfile memberId="member-1" onBack={vi.fn()} />
+      </StrictMode>,
+    );
+
+    expect(fetchProfile).toHaveBeenCalledTimes(1);
+    expect(fetchProfile).toHaveBeenCalledWith('member-1');
+  });
+});
