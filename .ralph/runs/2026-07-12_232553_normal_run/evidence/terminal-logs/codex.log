+            captured_by_user=self.maker, verified_flag=True,
+            verified_by_user=self.checkers[0], verified_at=timezone.now(),
+        )
+        rows = ActiveMemberStatusModule().calculate(
+            member_id=self.member.member_id, as_of_date=date(2026, 3, 31)
