        )

    def test_seed_is_idempotent(self):
        self._seed_e2e_users()
        self._seed_e2e_users()

        self.assertEqual(User.objects.filter(email=TRACER_EMAIL).count(), 1)
        self.assertEqual(User.objects.filter(email=ZERO_EMAIL).count(), 1)
        self.assertEqual(
