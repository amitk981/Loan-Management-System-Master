+                defaults={
+                    "permission_name": permission_code,
+                    "module_name": permission_code.split(".", 1)[0],
+                    "risk_level": Permission.RISK_HIGH,
+                },
+            )
+            RolePermission.objects.get_or_create(role=role, permission=permission)
+        return role
