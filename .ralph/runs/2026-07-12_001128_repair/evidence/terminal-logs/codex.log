+    @classmethod
+    def _ensure_credit_role(cls, role_code, role_name, permission_codes):
+        role = cls._ensure_role(
+            role_code,
+            role_name=role_name,
+            description="Deterministic Epic 006 trusted-browser role.",
+        )
+        for permission_code in permission_codes:
