+    def test_database_rejects_invalid_shapes_and_nullable_duplicate_authority_facts(self):
+        invalid_rows = (
+            MemberScopeAssignment(
+                user=self.actor, permission_code="members.member.read",
+                scope_type="unsupported",
+            ),
+            MemberScopeAssignment(
+                user=self.actor, permission_code="members.member.read",
