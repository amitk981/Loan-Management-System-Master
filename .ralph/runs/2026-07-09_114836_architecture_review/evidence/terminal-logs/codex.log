   144	    method,
   145	    headers: {
   146	      Accept: 'application/json',
   147	      Authorization: `Bearer ${session.accessToken}`,
   148	      ...(method === 'POST' ? { 'Content-Type': 'application/json' } : {}),
   149	    },
   150	    ...(method === 'POST' ? { body: JSON.stringify(body ?? {}) } : {}),
   151	  });
   152	  const envelope = await response.json() as ApiEnvelope<T>;
   153	  if (!response.ok || !envelope.success) {
   154	    throw new AuthSessionError(
   155	      envelope.error?.code ?? 'REQUEST_FAILED',
   156	      envelope.error?.message ?? 'Request failed.',
   157	      response.status,
   158	      normalizeFieldErrors(envelope.error?.field_errors),
   159	    );
   160	  }
   161	  return envelope;
