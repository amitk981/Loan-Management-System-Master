  return {
    ok: status >= 200 && status < 300,
    status,
    json: async () => body,
  } as Response;
}

function errorEnvelope(code: string) {
  return {
    success: false,
    error: { code, message: code, details: {}, field_errors: {} },
    meta: { api_version: 'v1' },
  };
}

