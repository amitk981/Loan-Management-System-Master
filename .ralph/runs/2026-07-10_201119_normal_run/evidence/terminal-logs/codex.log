+        note = (
+            LoanAppraisalNote.objects.select_for_update(of=("self",))
+            .select_related(
+                "risk_assessment",
+                "prepared_by_user",
+                "reviewed_by_user",
+            )
+            .filter(loan_application=application)
+            .first()
+        )
+        if note is None:
