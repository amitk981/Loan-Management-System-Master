+        if approval_case_model is not None:
+            self.assertEqual(approval_case_model.objects.count(), 0)
+        self.assertFalse(
+            AuditLog.objects.filter(action="appraisal.submitted_to_sanction").exists()
+        )
+        self.assertFalse(
