+        approval_case_model = apps.get_model("approvals", "ApprovalCase")
+        self.assertEqual(approval_case_model.objects.count(), 1)
+        self.assertEqual(AuditLog.objects.filter(action="appraisal.submitted_to_sanction").count(), 1)
