+        body = response.json()
+        assert_success_envelope(self, body)
+        data = body["data"]
+        self.assertEqual(data["loan_application_id"], str(self.application.pk))
+        self.assertEqual(data["loan_appraisal_note_id"], str(self.note.pk))
