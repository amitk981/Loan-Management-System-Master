+        if (
+            ApprovalCase.objects.select_for_update(of=("self",))
+            .filter(loan_application=application)
+            .exists()
+        ):
+            raise CreditModuleInvalidStateError(
+                "The appraisal has already been submitted for sanction."
+            )
+
+        now = timezone.now()
+        exception_required = (
