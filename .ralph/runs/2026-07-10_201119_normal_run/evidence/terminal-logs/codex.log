+    def _submit(self, payload, *, actor=None, request_id="submit-sanction-test"):
+        actor = actor or self.reviewer
+        login = self.client.post(
+            "/api/v1/auth/login/",
+            data={"email": actor.email, "password": "SanctionPass123!"},
