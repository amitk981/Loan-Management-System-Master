+        self.note.delete()
+
+        response = self._submit({"remarks": "No appraisal exists."})
+
+        self.assertEqual(response.status_code, 409)
+        self.assertEqual(response.json()["error"]["code"], "INVALID_STATE_TRANSITION")
+        self._assert_no_submission_writes()
