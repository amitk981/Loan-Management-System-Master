+                role_name=full_name,
+                is_system_role=True,
+                status="active",
+            )
+        for permission in permissions:
+            RolePermission.objects.get_or_create(role=role, permission=permission)
+        user = User.objects.create(
+            full_name=full_name,
+            email=f"{role_code}-{User.objects.count()}@sfpcl.example",
+            status="active",
+            primary_role=role,
