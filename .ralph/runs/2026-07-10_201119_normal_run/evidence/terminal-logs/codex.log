+    def test_invalid_or_inconsistent_appraisal_states_and_repeat_have_no_side_effects(self):
+        invalid_setups = (
+            ("draft", "returned", None),
+            ("review_pending", "", None),
+            ("rejected", "rejected", None),
+            ("reviewed", "reviewed", "history_comments"),
+            ("reviewed", "reviewed", "legacy_unverified"),
