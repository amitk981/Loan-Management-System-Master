+            .exists()
+        ):
+            raise CreditModuleInvalidStateError(
+                "The appraisal has already been submitted for sanction."
+            )
+
+        now = timezone.now()
+        exception_required = (
+            note.loan_limit_snapshot_json.get("exception_required_flag") is True
