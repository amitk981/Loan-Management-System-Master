+        self.assertEqual(self.note.appraisal_status, LoanAppraisalNote.STATUS_REVIEWED)
+        self.assertEqual(
+            self.application.application_status,
+            LoanApplication.STATUS_REFERENCE_GENERATED,
+        )
+        self._assert_no_submission_writes()
