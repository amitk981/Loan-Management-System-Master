+        and latest_review.to_state == LoanAppraisalNote.STATUS_REVIEWED
+        and latest_review.history_provenance
+        in {
+            AppraisalReviewDecision.PROVENANCE_NATIVE,
+            AppraisalReviewDecision.PROVENANCE_LEGACY_LATEST_ONLY,
