+        scope_denied = self._submit({"remarks": "Ready."})
+        self.assertEqual(scope_denied.status_code, 403)
+        self.assertEqual(scope_denied.json()["error"]["code"], "OBJECT_ACCESS_DENIED")
+        self._assert_no_submission_writes()
