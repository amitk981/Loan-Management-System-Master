diff --git a/sfpcl-lms/src/services/portalApi.ts b/sfpcl-lms/src/services/portalApi.ts
index aa7d9c47785dcf233c0d3d50efc3606a9d10de94..34a6095a5028cdeeb1ba8859bb7df2e1817a6ccc
