+    kyc_status: 'verified',
+    default_status: 'no_default',
+    share_summary: { number_of_shares: 5, holding_mode: 'physical', available_share_count: 5 },
+    active_member_status: { status: 'active', verified_at: null },
+  },
+  nominee: {
