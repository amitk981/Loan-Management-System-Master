+const normalizeFieldErrors = (fieldErrors?: Record<string, unknown>) => {
+  if (!fieldErrors) return undefined;
+  return Object.fromEntries(
+    Object.entries(fieldErrors).map(([field, value]) => [field, String(value)]),
+  );
+};
