+    nominee_name: 'Safe Portal Nominee',
+    age_at_application: 42,
+    minor_flag: false,
+    kyc_status: 'verified',
+    relationship_to_borrower: 'Spouse',
+    signature_required_flag: true,
+  },
+  timeline: [],
