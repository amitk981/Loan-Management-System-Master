    17	def _authorized(request, manage=False):
    18	    user, response = http_auth.authenticated_user(request)
    19	    if response is not None: return user, response
    20	    allowed = services.can_manage(user) if manage else services.can_read(user)
    21	    if not allowed: return user, error_response(request, 403, "FORBIDDEN", "You do not have approval matrix permission.")
    22	    return user, None
