    25	def _failure(request, exc):
    26	    if isinstance(exc, services.ConfigurationConflict):
    27	        status = 403 if exc.code in {
    28	            "FORBIDDEN", "MAKER_CHECKER_VIOLATION", "APPROVAL_AUTHORITY_REQUIRED"
    29	        } else 409
    30	        return error_response(request, status, exc.code, str(exc))
    31	    if isinstance(exc, ObjectDoesNotExist):
    32	        return error_response(request, 404, "NOT_FOUND", "Configuration was not found.")
    33	    details = exc.message_dict if hasattr(exc, "message_dict") else {"non_field_errors": [str(exc)]}
    34	    return error_response(request, 400, "VALIDATION_ERROR", "Configuration failed validation.",
    35	                          {key: value[0] if isinstance(value, list) else value for key, value in details.items()})
