+{
+  "success": false,
+  "error": {
+    "code": "VALIDATION_ERROR",
+    "message": "Loan-limit calculation failed validation.",
+    "field_errors": {
+      "cultivated_acreage": "CULTIVATED_ACREAGE_UNRESOLVED"
+    }
+  },
+  "meta": {
+    "request_id": "req-id",
+    "timestamp": "2026-07-10T00:00:00Z",
+    "api_version": "v1"
+  }
+}
+```
