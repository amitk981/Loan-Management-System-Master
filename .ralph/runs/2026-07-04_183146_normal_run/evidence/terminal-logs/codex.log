)
admin_role = Role.objects.create(
    role_code='system_admin',
    role_name='System Administrator',
    is_system_role=True,
    status='active',
)
accounts_role = Role.objects.create(
    role_code='accounts_head',
    role_name='Accounts Head',
    is_system_role=True,
    status='active',
)

def grant(role, code):
    permission, _ = Permission.objects.get_or_create(
        permission_code=code,
        defaults={
            'permission_name': code,
            'module_name': code.split('.', 1)[0],
            'risk_level': 'high',
        },
    )
    RolePermission.objects.get_or_create(role=role, permission=permission)

for code in ['users.user.create', 'users.user.update', 'users.user.disable', 'tracer.lifecycle.run']:
    grant(admin_role, code)
grant(credit_role, 'tracer.lifecycle.run')

