    headers=admin_headers,
).json()
client.post('/api/v1/auth/logout/', data={'refresh_token': credit_tokens['refresh_token']}, content_type='application/json')
examples['auth_me_401_invalid_token'] = client.get('/api/v1/auth/me/', headers=credit_headers).json()

