).json()
member = client.post('/api/v1/tracer/members/', data={'display_name': 'Evidence Member'}, content_type='application/json', headers=admin_headers).json()['data']
application = client.post(
    f\"/api/v1/tracer/members/{member['member_id']}/loan-applications/\",
    data={'amount': '100000.00'},
