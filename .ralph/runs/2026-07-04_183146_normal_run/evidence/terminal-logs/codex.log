import json
import os

os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'sfpcl_credit.config.settings')

import django
from django.core.management import call_command
from django.test import Client

django.setup()
call_command('migrate', verbosity=0)

from sfpcl_credit.identity.models import Permission, Role, RolePermission, User

client = Client()

credit_role = Role.objects.create(role_code='credit_manager', role_name='Credit Manager', is_system_role=True, status='active')
admin_role = Role.objects.create(role_code='system_admin', role_name='System Administrator', is_system_role=True, status='active')
accounts_role = Role.objects.create(role_code='accounts_head', role_name='Accounts Head', is_system_role=True, status='active')
partial_role = Role.objects.create(role_code='contract_user_creator', role_name='Contract User Creator', is_system_role=True, status='active')

def grant(role, code):
    permission, _ = Permission.objects.get_or_create(
        permission_code=code,
        defaults={'permission_name': code, 'module_name': code.split('.', 1)[0], 'risk_level': 'high'},
    )
    RolePermission.objects.get_or_create(role=role, permission=permission)

for code in ['users.user.create', 'users.user.update', 'users.user.disable', 'tracer.lifecycle.run']:
    grant(admin_role, code)
grant(credit_role, 'tracer.lifecycle.run')
grant(partial_role, 'users.user.create')

def create_user(full_name, email, role, password):
    user = User.objects.create(full_name=full_name, email=email, mobile_number='+917111111111', status='active', primary_role=role)
    user.set_password(password)
    user.save()
    return user

