    response = client.post(
        '/api/v1/auth/login/',
        data={'email': email, 'password': password},
        content_type='application/json',
    )
    return response.json()['data']

admin_tokens = login('system.admin.contract.example@sfpcl.example', 'AdminPass123"'!'"')
credit_tokens = login('credit.manager.contract.example@sfpcl.example', 'CorrectHorse123"'!'"')
admin_headers = {'Authorization': f\"Bearer {admin_tokens['access_token']}\"}
credit_headers = {'Authorization': f\"Bearer {credit_tokens['access_token']}\"}

