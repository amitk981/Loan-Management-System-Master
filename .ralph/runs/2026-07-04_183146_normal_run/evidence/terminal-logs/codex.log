create_user('Contract User Creator', 'contract.user.creator@sfpcl.example', partial_role, 'PartialPass123"'!'"')

def login(email, password):
    response = client.post('/api/v1/auth/login/', data={'email': email, 'password': password}, content_type='application/json')
    return response.json()['data']

admin_tokens = login('system.admin.contract.example@sfpcl.example', 'AdminPass123"'!'"')
credit_tokens = login('credit.manager.contract.example@sfpcl.example', 'CorrectHorse123"'!'"')
partial_tokens = login('contract.user.creator@sfpcl.example', 'PartialPass123"'!'"')
admin_headers = {'Authorization': f\"Bearer {admin_tokens['access_token']}\"}
credit_headers = {'Authorization': f\"Bearer {credit_tokens['access_token']}\"}
partial_headers = {'Authorization': f\"Bearer {partial_tokens['access_token']}\"}

examples = {}
examples['auth_me_success'] = client.get('/api/v1/auth/me/', headers=credit_headers).json()
examples['admin_users_pagination'] = client.get('/api/v1/admin/users/?page=1&page_size=20', headers=admin_headers).json()
examples['admin_users_401_auth_required'] = client.get('/api/v1/admin/users/').json()
examples['admin_users_403_permission_denied'] = client.get('/api/v1/admin/users/', headers=credit_headers).json()
examples['partial_admin_create_only_403_update_denied'] = client.post(
    f'/api/v1/admin/users/{target_user.user_id}/roles/',
