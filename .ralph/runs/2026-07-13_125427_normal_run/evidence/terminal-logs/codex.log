+            options={"db_table": "sanction_decisions"},
+        ),
+        migrations.AddIndex(
+            model_name="sanctiondecision",
+            index=models.Index(fields=["decision", "recorded_at"], name="idx_sanction_decision_time"),
+        ),
+    ]
