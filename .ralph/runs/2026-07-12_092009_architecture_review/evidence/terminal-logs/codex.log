   664	        errors.update({field: "Unknown field." for field in unknown})
   665	        if decision not in {"reviewed", "returned", "rejected"}:
   666	            errors["decision"] = "Must be reviewed, returned, or rejected."
   667	        if not isinstance(comments, str) or not comments.strip():
   668	            errors["review_comments"] = "This field must not be blank."
   669	        if errors:
   670	            raise CreditModuleValidationError(errors)
   671	        note = _lock_appraisal_after_application(appraisal_id)
