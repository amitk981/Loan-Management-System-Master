   116	def appraisal_available_actions(note, actor, permissions):
   117	    """Project the actions governed by this module's public transition predicates."""
   118	    permissions = set(permissions)
   119	    roles = set(actor.role_codes())
   120	
   121	    def action(code, label, permission, allowed, role=None, reason=None):
   122	        enabled = allowed and permission in permissions and (role is None or role in roles)
   123	        disabled_reason = reason or "Unavailable for this appraisal state or authority."
   124	        if permission not in permissions:
   125	            disabled_reason = f"Required permission {permission} is missing."
   126	        elif role is not None and role not in roles:
   127	            disabled_reason = f"Required role {role} is missing."
   128	        return {
   129	            "action_code": code,
   130	            "label": label,
   131	            "enabled": enabled,
   132	            "disabled_reason": None if enabled else disabled_reason,
   133	            "required_permission": permission,
   134	            "required_role": role,
   135	        }
   136	
   137	    evaluations = {
   138	        APPRAISAL_UPDATE_PERMISSION: evaluate_appraisal_update(note, permissions),
   139	        "revalidate_appraisal_prerequisites": evaluate_appraisal_revalidation(note, permissions),
   140	        APPRAISAL_SUBMIT_PERMISSION: evaluate_appraisal_submission(note),
   141	        APPRAISAL_REVIEW_PERMISSION: evaluate_appraisal_review(note, actor),
   142	        APPRAISAL_SANCTION_SUBMIT_PERMISSION: evaluate_sanction_submission(note),
   143	    }
   144	    return [
   145	        action(APPRAISAL_UPDATE_PERMISSION, "Update Appraisal Draft", APPRAISAL_UPDATE_PERMISSION, evaluations[APPRAISAL_UPDATE_PERMISSION].allowed, reason=evaluations[APPRAISAL_UPDATE_PERMISSION].reason),
   146	        action("revalidate_appraisal_prerequisites", "Revalidate Prerequisites", APPRAISAL_UPDATE_PERMISSION, evaluations["revalidate_appraisal_prerequisites"].allowed, reason=evaluations["revalidate_appraisal_prerequisites"].reason),
   147	        action(APPRAISAL_SUBMIT_PERMISSION, "Submit for Credit Review", APPRAISAL_SUBMIT_PERMISSION, evaluations[APPRAISAL_SUBMIT_PERMISSION].allowed, reason=evaluations[APPRAISAL_SUBMIT_PERMISSION].reason),
   148	        action(APPRAISAL_REVIEW_PERMISSION, "Record Credit Review", APPRAISAL_REVIEW_PERMISSION, evaluations[APPRAISAL_REVIEW_PERMISSION].allowed, role="credit_manager", reason=evaluations[APPRAISAL_REVIEW_PERMISSION].reason),
   149	        action(APPRAISAL_SANCTION_SUBMIT_PERMISSION, "Submit to Sanction Committee", APPRAISAL_SANCTION_SUBMIT_PERMISSION, evaluations[APPRAISAL_SANCTION_SUBMIT_PERMISSION].allowed, role="credit_manager", reason=evaluations[APPRAISAL_SANCTION_SUBMIT_PERMISSION].reason),
   150	    ]
   151	
   152	
   153	def _result_with_actions(note, actor, permissions, snapshot=None):
   154	    projected = dict(snapshot or appraisal_note_snapshot(note))
   155	    projected["available_actions"] = appraisal_available_actions(note, actor, permissions)
   156	    return AppraisalNoteResult(snapshot=projected)
