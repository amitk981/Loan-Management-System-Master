   647	        if "credit_manager" not in actor.role_codes():
   648	            raise CreditModulePermissionDenied(
   649	                "Only an active Credit Manager may review appraisal notes."
   650	            )
   651	        errors = {}
   652	        payload = payload_fields or {}
   653	        allowed_fields = {"decision", "review_comments"}
   654	        if decision == "rejected":
