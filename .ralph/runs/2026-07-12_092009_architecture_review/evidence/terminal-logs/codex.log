    RALPH_EVIDENCE_DIR="$run_dir/evidence/screenshots" \
      E2E_DJANGO_PYTHON="$venv_python" \
      npm run e2e -- "${specs[@]}"
  ) >> "$log" 2>&1; then
    rc=0
  else
    rc=$?
  fi
  echo >> "$log"
  echo "Exit code: $rc" >> "$log"
  (( rc == 0 ))
}

