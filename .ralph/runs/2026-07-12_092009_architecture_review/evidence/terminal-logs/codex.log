  echo >> "$log"
  echo "Exit code: $rc" >> "$log"
  echo "Cleanup exit code: $cleanup_rc" >> "$log"
  (( rc == 0 && cleanup_rc == 0 )) && postgresql_acceptance_log_passes "$log"
}

run_trusted_browser_acceptance_once() {
