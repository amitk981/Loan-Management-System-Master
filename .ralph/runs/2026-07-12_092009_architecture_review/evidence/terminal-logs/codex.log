   100	def evaluate_sanction_submission(note, *, latest_review=None, history_locked=False):
   101	    if note.appraisal_status != LoanAppraisalNote.STATUS_REVIEWED:
   102	        return AppraisalTransitionEvaluation(False, "Only a reviewed appraisal note can be submitted for sanction.")
   103	    if note.prerequisite_provenance != "verified":
   104	        return AppraisalTransitionEvaluation(False, "Sanction submission requires verified prerequisite snapshots.")
   105	    if _submission_errors(note):
   106	        return AppraisalTransitionEvaluation(False, "Sanction submission requires a complete appraisal and risk assessment.")
   107	    if not _frozen_prerequisites_complete(note):
   108	        return AppraisalTransitionEvaluation(False, "Sanction submission requires complete frozen eligibility and loan-limit snapshots.")
   109	    if not history_locked:
   110	        latest_review = note.review_decisions.order_by("decided_at", "appraisal_review_decision_id").last()
   111	    if latest_review is None or not _latest_review_matches_note(note, latest_review):
   112	        return AppraisalTransitionEvaluation(False, "The latest immutable review decision does not match the reviewed appraisal.")
   113	    return AppraisalTransitionEvaluation(True, None)
