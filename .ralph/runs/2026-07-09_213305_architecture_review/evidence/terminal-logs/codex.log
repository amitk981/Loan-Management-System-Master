   145	def evaluate_application_object_access(application, actor, required_permission, actor_permissions=None):
   146	    permissions = actor_permissions or auth_service.effective_permission_codes(actor)
   147	    allow_global = _has_credit_manager_domain_access(application, actor)
   148	    result = evaluate_object_access(
   149	        actor_user_id=actor.user_id,
   150	        actor_team_codes=actor.team_codes(),
   151	        actor_permission_codes=permissions,
   152	        required_permission=required_permission,
   153	        object_owner_user_id=application.created_by_user_id,
   154	        allow_global=allow_global,
   155	    )
   156	    if result.allowed or result.error_code != "OBJECT_ACCESS_DENIED":
   157	        return result
   158	    if (
   159	        application.received_by_user_id
   160	        and application.received_by_user_id != application.created_by_user_id
   161	    ):
   162	        return evaluate_object_access(
   163	            actor_user_id=actor.user_id,
   164	            actor_team_codes=actor.team_codes(),
   165	            actor_permission_codes=permissions,
   166	            required_permission=required_permission,
   167	            object_owner_user_id=application.received_by_user_id,
   168	            allow_global=allow_global,
   169	        )
   170	    return result
