   332	@transaction.atomic
   333	def generate_reference_after_completeness_pass(
   334	    application,
   335	    actor,
   336	    request_ip="",
   337	    request_user_agent="",
   338	    request_id=None,
   339	    actor_permissions=None,
   340	):
   341	    application = (
   342	        LoanApplication.objects.select_for_update()
   343	        .select_related("member", "received_by_user")
   344	        .get(loan_application_id=application.loan_application_id)
   345	    )
   346	    transition = evaluate_transition(
   347	        current_state=application.application_status,
   348	        requested_action="generate_reference",
   349	        actor_permissions=actor_permissions or auth_service.effective_permission_codes(actor),
   350	        transitions=APPLICATION_TRANSITIONS,
   351	    )
   352	    if application.application_reference_number:
   353	        raise LoanApplicationValidationError(
   354	            {"application_reference_number": "Application already has a reference number."}
   355	        )
   356	    if LoanRequestRegisterEntry.objects.filter(loan_application=application).exists():
   357	        raise LoanApplicationValidationError(
   358	            {"loan_request_register_entry": "Loan request register entry already exists."}
   359	        )
   360	
   361	    old_value_json = _audit_snapshot(application)
   362	    reference_number = _next_loan_application_reference()
   363	    now = timezone.now()
   364	    application.application_reference_number = reference_number
   365	    application.application_status = transition.next_state
   366	    application.current_stage = LoanApplication.STAGE_CREDIT_ASSESSMENT
   367	    application.completeness_status = LoanApplication.COMPLETENESS_COMPLETE
   368	    application.updated_at = now
   369	    application.updated_by_user = actor
   370	    application.save()
   371	    register_entry = LoanRequestRegisterEntry.objects.create(
   372	        loan_application=application,
   373	        application_reference_number=reference_number,
   374	        member=application.member,
   375	        date_received=application.application_date,
   376	        reference_generated_date=timezone.localdate(now),
   377	        received_channel=application.application_channel,
   378	        received_by_user=application.received_by_user,
   379	        register_status=LoanRequestRegisterEntry.STATUS_REFERENCE_GENERATED,
   380	        requested_amount=application.required_loan_amount,
   381	        declared_purpose=application.declared_purpose,
   382	        purpose_category=application.purpose_category,
   383	        borrower_name=application.member.display_name,
   384	        folio_number=application.member.folio_number,
   385	        member_type=application.member.member_type,
   386	        current_stage=application.current_stage,
   387	        current_owner_role="Deputy Manager / Credit Manager",
   388	    )
   389	    _audit_application(
   390	        application,
   391	        actor,
   392	        transition.definition.audit_action,
   393	        old_value_json,
   394	        request_ip,
   395	        request_user_agent,
   396	        request_id,
   397	        register_entry=register_entry,
   398	    )
   399	    record_workflow_event(
   400	        actor=actor,
   401	        workflow_name=transition.definition.workflow_name,
   402	        entity_type=transition.definition.entity_type,
   403	        entity_id=application.loan_application_id,
   404	        from_state=transition.previous_state,
   405	        to_state=transition.next_state,
   406	        trigger_reason=transition.definition.workflow_label,
   407	        action_code=transition.definition.action_code,
   408	    )
   409	    application.loan_request_register_entry = register_entry
   410	    return application
