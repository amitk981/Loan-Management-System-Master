  1070	    item_errors = []
  1071	    for index, raw_item in enumerate(raw_items):
  1072	        if not isinstance(raw_item, dict):
  1073	            item_errors.append({"index": index, "error": "Each deficiency item must be an object."})
  1074	            continue
  1075	        unknown_item_fields = set(raw_item.keys()) - {"item_code", "remarks"}
  1076	        item_code = _optional_text(raw_item.get("item_code")).lower()
