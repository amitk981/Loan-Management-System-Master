   105	def validate_upload_request(request):
   106	    field_errors = {}
   107	    uploaded_file = request.FILES.get("file")
   108	    document_category = (request.POST.get("document_category") or "").strip()
   109	    raw_sensitivity = (request.POST.get("sensitivity_level") or "").strip()
   110	    related_entity_type = (request.POST.get("related_entity_type") or "").strip()
   111	    raw_related_entity_id = (request.POST.get("related_entity_id") or "").strip()
   112	
   113	    if uploaded_file is None:
   114	        field_errors["file"] = "This field is required."
   115	    if not document_category:
   116	        field_errors["document_category"] = "This field is required."
   117	    if not raw_sensitivity:
   118	        field_errors["sensitivity_level"] = "This field is required."
   119	
   120	    sensitivity_level = raw_sensitivity.lower()
   121	    if raw_sensitivity and sensitivity_level not in ALLOWED_SENSITIVITY_LEVELS:
   122	        field_errors["sensitivity_level"] = (
   123	            "Must be one of public, internal, confidential, restricted."
   124	        )
   125	
   126	    related_entity_id = None
   127	    if raw_related_entity_id:
   128	        try:
   129	            related_entity_id = uuid.UUID(raw_related_entity_id)
   130	        except ValueError:
   131	            field_errors["related_entity_id"] = "Must be a valid UUID."
   132	
   133	    if field_errors:
   134	        raise ValidationError(field_errors)
   135	
   136	    return {
   137	        "file": uploaded_file,
   138	        "document_category": document_category,
   139	        "sensitivity_level": sensitivity_level,
   140	        "related_entity_type": related_entity_type or None,
   141	        "related_entity_id": related_entity_id,
   142	    }
   143	
   144	
   145	def serialize_document_file(document):
   146	    return {
   147	        "document_id": str(document.document_id),
   148	        "file_name": document.file_name,
   149	        "mime_type": document.mime_type,
   150	        "file_size_bytes": document.file_size_bytes,
   151	        "sensitivity_level": document.sensitivity_level,
   152	        "uploaded_at": document.uploaded_at.isoformat().replace("+00:00", "Z"),
   153	    }
