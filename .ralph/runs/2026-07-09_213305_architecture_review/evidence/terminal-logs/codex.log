  1078	            item_errors.append({"index": index, "item_code": "This field is required."})
  1079	            continue
  1080	        if unknown_item_fields:
  1081	            item_errors.append(
  1082	                {
  1083	                    "index": index,
  1084	                    "unknown_fields": sorted(unknown_item_fields),
  1085	                }
  1086	            )
  1087	            continue
  1088	        if item_code in seen:
