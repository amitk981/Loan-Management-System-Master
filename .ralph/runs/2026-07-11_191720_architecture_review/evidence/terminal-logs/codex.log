+  vi.resetModules();
+});
+
+const renderBoundary = (demoEnabled: boolean) => renderToStaticMarkup(
+  <LoginScreen
+    onLogin={vi.fn()}
+    onOpenMemberPortal={vi.fn()}
+    onDemoLogin={demoEnabled ? vi.fn() : undefined}
+    showDemoRoleSelector={demoEnabled}
