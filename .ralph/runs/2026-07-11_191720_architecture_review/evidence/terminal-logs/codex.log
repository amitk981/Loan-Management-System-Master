   251	      rejectionCategory={rejectionCategory}
   252	      reapplyAllowed={reapplyAllowed}
   253	      busyAction={busyAction}
   254	      onSelect={id => {
   255	        setSelectedId(id);
   256	        setComment('');
   257	        void loadSelected(id);
   258	      }}
   259	      onCommentChange={setComment}
   260	      onReasonChange={(itemCode, value) => setReasons(current => ({ ...current, [itemCode]: value }))}
   261	      onRejectionCategoryChange={setRejectionCategory}
   262	      onReapplyAllowedChange={setReapplyAllowed}
