   225	export const fetchStaffApplications = async (
   226	  filters: StaffApplicationFilters = {},
   227	): Promise<PaginatedResult<StaffApplication>> => {
   228	  const params = new URLSearchParams();
   229	  setParam(params, 'search', filters.search);
   230	  setParam(params, 'application_status', filters.applicationStatus);
   231	  setParam(params, 'current_stage', filters.currentStage);
   232	  setParam(params, 'member_id', filters.memberId);
   233	  setParam(params, 'ordering', filters.ordering);
   234	  setNumberParam(params, 'page', filters.page);
   235	  setNumberParam(params, 'page_size', filters.pageSize);
   236	  const envelope = await request<StaffApplication[]>(`/api/v1/loan-applications/${query(params)}`);
   237	  return { items: envelope.data ?? [], pagination: envelope.pagination ?? emptyPagination };
   238	};
