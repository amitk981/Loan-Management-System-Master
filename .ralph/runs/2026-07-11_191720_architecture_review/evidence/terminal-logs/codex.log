   170	      setSelectedId(selected.loan_application_id);
   171	      await loadSelected(selected.loan_application_id);
   172	    } catch (error) {
   173	      const next = errorState(error);
   174	      setStatus(next.status);
   175	      setMessage(next.message);
   176	      setApplications([]);
   177	    }
   178	  }, [initialSelectedId, loadSelected]);
   179	
   180	  useEffect(() => {
