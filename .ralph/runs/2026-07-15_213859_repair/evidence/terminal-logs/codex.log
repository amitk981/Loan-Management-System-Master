diff --git a/sfpcl_credit/documents/migrations/0005_deterministic_document_template_constraints.py b/sfpcl_credit/documents/migrations/0005_deterministic_document_template_constraints.py
new file mode 100644
index 0000000000000000000000000000000000000000..44b9a057d375ae81c78ab53da074b018752fa02d
--- /dev/null
+++ b/sfpcl_credit/documents/migrations/0005_deterministic_document_template_constraints.py
@@ -0,0 +1,41 @@
+from django.db import migrations, models
+
+
+class Migration(migrations.Migration):
+    dependencies = [
+        ("documents", "0004_loandocument"),
+    ]
+
+    operations = [
+        migrations.RemoveConstraint(
+            model_name="documenttemplate",
+            name="doc_template_approval_status",
+        ),
+        migrations.RemoveConstraint(
+            model_name="documenttemplate",
+            name="doc_template_borrower_type",
+        ),
+        migrations.AddConstraint(
+            model_name="documenttemplate",
+            constraint=models.CheckConstraint(
+                check=models.Q(
+                    ("approval_status__in", ("draft", "approved", "retired"))
+                ),
+                name="doc_template_approval_status",
+            ),
+        ),
+        migrations.AddConstraint(
+            model_name="documenttemplate",
+            constraint=models.CheckConstraint(
+                check=models.Q(
+                    ("borrower_type__isnull", True),
+                    (
+                        "borrower_type__in",
+                        ("individual_farmer", "fpc", "fpo"),
+                    ),
+                    _connector="OR",
+                ),
+                name="doc_template_borrower_type",
+            ),
+        ),
+    ]
