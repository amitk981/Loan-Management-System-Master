+            "variables_json": [
+                "application_reference_number",
+                "borrower_name",
+                "rejection_reason",
+            ],
+            "approval_status": "approved",
+            "template_version": "1.0",
+            "effective_from": "2026-04-01",
+        }
+        defaults.update(overrides)
+        return ContentTemplate.objects.create(**defaults)
