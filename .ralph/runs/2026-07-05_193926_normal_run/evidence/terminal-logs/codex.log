import uuid

from django.db import models
from django.utils import timezone


class LoanPolicyConfig(models.Model):
    STATUS_DRAFT = "draft"
    STATUS_ACTIVE = "active"
    STATUS_RETIRED = "retired"
    STATUSES = {STATUS_DRAFT, STATUS_ACTIVE, STATUS_RETIRED}

