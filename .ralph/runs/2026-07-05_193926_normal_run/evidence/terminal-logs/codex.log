+        self.assertEqual(ContentTemplate.objects.count(), 0)
+        self.assertEqual(
+            AuditLog.objects.filter(
+                action__startswith="communications.content_template."
+            ).count(),
+            0,
+        )
+
+    def test_reader_cannot_write_and_manager_can_list(self):
