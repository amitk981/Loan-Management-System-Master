diff --git a/sfpcl_credit/tests/test_content_templates_api.py b/sfpcl_credit/tests/test_content_templates_api.py
new file mode 100644
index 0000000000000000000000000000000000000000..3ba884630052c52239ffe1990be1caaf177bb552
--- /dev/null
+++ b/sfpcl_credit/tests/test_content_templates_api.py
@@ -0,0 +1,354 @@
+import uuid
+
+from django.test import Client, TestCase
+
+from sfpcl_credit.communications.models import ContentTemplate
+from sfpcl_credit.identity.models import AuditLog, Permission, Role, RolePermission, User
+from sfpcl_credit.tests.api_contracts import (
+    assert_error_envelope,
+    assert_pagination_shape,
+    assert_success_envelope,
+)
+
+
+CONTENT_TEMPLATES_URL = "/api/v1/content-templates/"
+CONTENT_TEMPLATE_READ_PERMISSION = "communications.content_template.read"
