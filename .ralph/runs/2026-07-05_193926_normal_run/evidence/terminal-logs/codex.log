+        )
+        self.assertEqual(forbidden.status_code, 403)
+        assert_error_envelope(self, forbidden.json(), "PERMISSION_DENIED")
+
+        response = self.client.get(
+            CONTENT_TEMPLATES_URL,
+            headers=self._manager_headers(),
+        )
