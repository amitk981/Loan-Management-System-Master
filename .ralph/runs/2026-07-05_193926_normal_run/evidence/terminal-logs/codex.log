+                        blank=True, db_index=True, max_length=20, null=True
+                    ),
+                ),
+                ("audience", models.CharField(db_index=True, max_length=80)),
+                (
+                    "subject_template",
+                    models.CharField(blank=True, max_length=255, null=True),
+                ),
+                ("body_template", models.TextField()),
+                ("variables_json", models.JSONField(blank=True, null=True)),
+                ("approval_status", models.CharField(db_index=True, max_length=60)),
+                ("template_version", models.CharField(max_length=40)),
+                ("effective_from", models.DateField()),
+                ("effective_to", models.DateField(blank=True, null=True)),
+            ],
+            options={
+                "db_table": "content_templates",
+                "ordering": ["template_code"],
+            },
+        ),
+    ]
