   445	def _paginated(queryset, serializer, query_params):
   446	    unknown = set(query_params.keys()) - {"page", "page_size"}
   447	    if unknown:
   448	        raise ValidationError({key: "Unknown query parameter." for key in sorted(unknown)})
   449	    page = _positive_int("page", query_params.get("page"), 1)
   450	    page_size = min(_positive_int("page_size", query_params.get("page_size"), 20), 100)
   451	    total_count = queryset.count()
   452	    total_pages = ceil(total_count / page_size) if total_count else 1
   453	    page = min(page, total_pages)
   454	    offset = (page - 1) * page_size
   455	    return [serializer(row) for row in queryset[offset:offset + page_size]], {
   456	        "page": page, "page_size": page_size, "total_count": total_count,
   457	        "total_pages": total_pages, "has_next": page < total_pages, "has_previous": page > 1,
   458	    }
