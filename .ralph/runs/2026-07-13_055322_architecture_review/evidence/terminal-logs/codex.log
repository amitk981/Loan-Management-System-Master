   586	                close_old_connections()
   587	
   588	        with ThreadPoolExecutor(max_workers=2) as pool:
   589	            results = list(pool.map(supersede, ("committee-next-a", "committee-next-b")))
   590	        self.assertEqual(sorted(results), ["lost", "won"])
   591	        self.assertEqual(SanctionCommittee.objects.count(), 2)
   592	        self.assertEqual(VersionHistory.objects.filter(versioned_entity_type="sanction_committee").count(), 2)
   593	        self.assertEqual(AuditLog.objects.filter(action__startswith="approvals.sanction_committee.").count(), 2)
