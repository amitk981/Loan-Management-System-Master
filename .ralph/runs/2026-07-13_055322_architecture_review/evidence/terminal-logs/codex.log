   410	        if not isinstance(values["service_from"], date) or not isinstance(values["service_to"], date):
   411	            raise ValueError("service_from and service_to must be dates.")
   412	        if values["service_from"] > values["service_to"]:
   413	            raise ValueError("service_from cannot be after service_to.")
   414	        if not isinstance(values["evidence_reference"], str) or not values["evidence_reference"].strip():
   415	            raise ValueError("evidence_reference is required.")

