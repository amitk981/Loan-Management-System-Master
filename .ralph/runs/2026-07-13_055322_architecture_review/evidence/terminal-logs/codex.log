   299	def _validate_rule(payload):
   300	    required = {"decision_type", "required_approver_roles", "required_director_count",
   301	                "joint_approval_required_flag", "effective_from", "version_number"}
   302	    allowed = required | {"amount_min", "amount_max", "condition_code", "register_required", "effective_to"}
   303	    errors = _unknown_missing(payload, allowed, required)
   304	    start = _date("effective_from", payload.get("effective_from"), errors)
   305	    end = _date("effective_to", payload.get("effective_to"), errors, optional=True)
   306	    low = _money("amount_min", payload.get("amount_min"), errors)
   307	    high = _money("amount_max", payload.get("amount_max"), errors)
   308	    if low is not None and high is not None and low > high:
   309	        errors["amount_max"] = "Must be greater than or equal to amount_min."
   310	    if start and end and end < start:
   311	        errors["effective_to"] = "Must be on or after effective_from."
   312	    roles = payload.get("required_approver_roles")
   313	    if not isinstance(roles, list) or not roles or any(not isinstance(x, str) or not x.strip() for x in roles):
   314	        errors["required_approver_roles"] = "Must be a non-empty list of role codes."
   315	    try:
   316	        director_count = int(payload.get("required_director_count"))
   317	        if director_count < 0: raise ValueError
   318	    except (TypeError, ValueError):
   319	        director_count = 0; errors["required_director_count"] = "Must be a non-negative integer."
   320	    if not isinstance(payload.get("joint_approval_required_flag"), bool):
   321	        errors["joint_approval_required_flag"] = "Must be a boolean."
   322	    for field in ("decision_type", "version_number"):
   323	        if not isinstance(payload.get(field), str) or not payload.get(field, "").strip(): errors[field] = "This field is required."
   324	    if errors: raise ValidationError(errors)
   325	    return {"decision_type": payload["decision_type"].strip(), "amount_min": low, "amount_max": high,
   326	            "condition_code": _nullable_string(payload.get("condition_code")),
   327	            "required_approver_roles_json": [x.strip() for x in roles],
   328	            "required_director_count": director_count,
   329	            "joint_approval_required_flag": payload["joint_approval_required_flag"],
   330	            "register_required": _nullable_string(payload.get("register_required")),
   331	            "effective_from": start, "effective_to": end, "version_number": payload["version_number"].strip()}
