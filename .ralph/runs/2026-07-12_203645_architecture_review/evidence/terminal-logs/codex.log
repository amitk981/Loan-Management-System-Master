    await waitFor(() => expect(update).toHaveBeenCalledWith('application-1', 'witness-1', { version: 1, address: 'Corrected Road', mobile: '9876543210' }));
    expect(fetch).toHaveBeenCalledTimes(2);
    view.unmount();
