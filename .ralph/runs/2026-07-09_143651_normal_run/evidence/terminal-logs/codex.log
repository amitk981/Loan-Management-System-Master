            self.assertNotIn("pan_hash", flattened)
            self.assertNotIn("aadhaar_hash", flattened)
            self.assertNotIn("ckyc_identifier_encrypted", flattened)
        self.assertEqual(WorkflowEvent.objects.count(), 0)
