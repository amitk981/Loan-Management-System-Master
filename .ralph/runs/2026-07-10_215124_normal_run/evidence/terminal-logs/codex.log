+        self.executor = MigrationExecutor(connection)
+        self.executor.migrate(self.migrate_from)
+        self.executor = MigrationExecutor(connection)
+        self.executor.migrate(self.migrate_to)
+        rerun_apps = self.executor.loader.project_state(self.migrate_to).apps
