+class LegacyAppraisalRemediationMigrationTests(TransactionTestCase):
+    migrate_from = [("credit", "0005_appraisalreviewdecision")]
+    migrate_to = [("credit", "0006_legacy_appraisal_history_remediation")]
+
+    def setUp(self):
