+            last_review_decision=decision,
+            tat_due_at=decided_at + timedelta(days=2),
+            tat_status="within_tat",
+            eligibility_assessment_id_snapshot=uuid4(),
+            loan_limit_assessment_id_snapshot=uuid4(),
+            eligibility_snapshot_json={},
