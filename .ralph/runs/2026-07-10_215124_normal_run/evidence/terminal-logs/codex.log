+            ),
+            "incomplete": self._create_case(
+                "incomplete",
+                decision="returned",
+                appraisal_status="review_pending",
+                comments="",
+            ),
+            "multiple_cycles": self._create_case(
+                "multiple-cycles",
+                decision="returned",
+                appraisal_status="review_pending",
+                existing_earlier=True,
