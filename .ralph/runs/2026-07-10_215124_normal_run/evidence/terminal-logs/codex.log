+        self.user = self._create_actor(self.old_apps)
+        self.ids = {
+            "returned_resubmitted": self._create_case(
+                "returned-resubmitted",
+                decision="returned",
+                appraisal_status="review_pending",
+                comments="Correct the repayment evidence.",
