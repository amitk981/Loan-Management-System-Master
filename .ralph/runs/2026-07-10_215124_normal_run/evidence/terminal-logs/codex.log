+            "verified_unrelated": self._create_case(
+                "verified-unrelated",
+                decision="returned",
+                appraisal_status="review_pending",
+                provenance="verified",
+            ),
+        }
+
+    def tearDown(self):
+        executor = MigrationExecutor(connection)
