        ).quantize(Decimal("0.01"))
        final_eligible_amount = min(shareholding_limit, land_limit)
        requested_amount = cleaned["requested_amount"].quantize(Decimal("0.01"))
        amount_within_limit = requested_amount <= final_eligible_amount

        old_value_json = (
