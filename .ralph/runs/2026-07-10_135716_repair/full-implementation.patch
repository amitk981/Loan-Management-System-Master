+    def test_credit_module_import_boundary_has_no_application_service_aliases(self):
+        import sfpcl_credit.applications.services as application_services
+        from sfpcl_credit.configurations.modules.configuration_resolver import (
+            resolve_effective_loan_policy,
+        )
+        from sfpcl_credit.credit.modules.appraisal_workflow import AppraisalWorkflow
+
+        for forbidden_name in (
+            "run_eligibility_assessment",
+            "calculate_loan_limit",
+            "serialize_eligibility_assessment",
+            "serialize_loan_limit_assessment",
+            "_effective_loan_policy",
+            "_loan_limit_assessment_audit_snapshot",
+        ):
+            self.assertFalse(
+                hasattr(application_services, forbidden_name),
+                f"applications.services must not expose credit helper {forbidden_name}",
+            )
+        self.assertTrue(callable(resolve_effective_loan_policy))
+        self.assertTrue(hasattr(AppraisalWorkflow, "create_or_update"))
