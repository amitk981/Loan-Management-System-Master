import django
django.setup()

from django.test.runner import DiscoverRunner
from sfpcl_credit.approvals.models import ApprovalAction
from sfpcl_credit.approvals.modules.conflict_of_interest import ConflictOfInterestModule
from sfpcl_credit.identity.models import RolePermission
from sfpcl_credit.tests.test_approval_case_routing_api import ApprovalCaseRoutingApiTests

def test_architecture_review_two_director_conflict_requires_distinct_authority(self):
    alternate = self.committee.director_2_user
    self.case.required_approvers_json = [
        {\"role_code\": \"cfo\", \"user_id\": str(self.cfo.pk), \"full_name\": self.cfo.full_name},
        {\"role_code\": \"director\", \"user_id\": str(self.director.pk), \"full_name\": self.director.full_name},
        {\"role_code\": \"director\", \"user_id\": str(alternate.pk), \"full_name\": alternate.full_name},
    ]
    self.case.excluded_approvers_json = [{
        \"user_id\": str(self.director.pk),
        \"conflict_code\": \"director_relative\",
        \"reason\": \"Borrower is relative of Director.\",
    }]
    effective = ConflictOfInterestModule.effective_approvers(self.case)
    self.assertEqual(
        len({str(item[\"user_id\"]) for item in effective}),
        len(self.case.required_approvers_json),
    )
    self.assertFalse(ConflictOfInterestModule.authority_is_satisfiable(self.case))

def test_architecture_review_alternate_action_is_in_canonical_history(self):
    alternate = self.committee.director_2_user
    for permission in (
        self.read_permission,
        self.approve_permission,
        self.reject_permission,
        self.return_permission,
    ):
        RolePermission.objects.create(role=alternate.primary_role, permission=permission)
    self.case.excluded_approvers_json = [{
        \"user_id\": str(self.director.pk),
        \"conflict_code\": \"director_relative\",
        \"reason\": \"Borrower is relative of Director.\",
    }]
    self.case.save(update_fields=[\"excluded_approvers_json\"])
    first = self.client.post(
        f\"/api/v1/approval-cases/{self.case.pk}/approve/\",
        {\"version\": 2},
        content_type=\"application/json\",
        **self._auth(self.cfo),
    )
    self.assertEqual(first.status_code, 200, first.json())
    final = self.client.post(
        f\"/api/v1/approval-cases/{self.case.pk}/approve/\",
        {\"version\": 3},
        content_type=\"application/json\",
        **self._auth(alternate),
    )
    self.assertEqual(final.status_code, 200, final.json())
    detail = self.client.get(
        f\"/api/v1/approval-cases/{self.case.pk}/\",
        **self._auth(self.cfo),
    )
    history = detail.json()[\"data\"][\"required_approvers\"]
    alternate_rows = [
        row for row in history if row[\"user_id\"] == str(alternate.pk)
    ]
    self.assertEqual(len(alternate_rows), 1)
    self.assertEqual(alternate_rows[0][\"decision\"], \"approved\")
    self.assertEqual(
        ApprovalAction.objects.filter(
            approval_case=self.case,
            approver_user=alternate,
            decision=\"approved\",
        ).count(),
        1,
    )

ApprovalCaseRoutingApiTests.test_architecture_review_two_director_conflict_requires_distinct_authority = (
    test_architecture_review_two_director_conflict_requires_distinct_authority
)
ApprovalCaseRoutingApiTests.test_architecture_review_alternate_action_is_in_canonical_history = (
    test_architecture_review_alternate_action_is_in_canonical_history
)

failures = DiscoverRunner(verbosity=2).run_tests([
    \"sfpcl_credit.tests.test_approval_case_routing_api.ApprovalCaseRoutingApiTests.test_architecture_review_two_director_conflict_requires_distinct_authority\",
    \"sfpcl_credit.tests.test_approval_case_routing_api.ApprovalCaseRoutingApiTests.test_architecture_review_alternate_action_is_in_canonical_history\",
])
raise SystemExit(bool(failures))
