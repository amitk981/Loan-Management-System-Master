   200	class AppraisalWorkflow:
   201	    @staticmethod
   202	    def lock_submitted_appraisal(*, appraisal_id):
   203	        """Lock and return an appraisal for the approval-owned transaction."""
   204	        return LoanAppraisalNote.objects.select_for_update().get(pk=appraisal_id)
   205	
   206	    @staticmethod
   207	    def restore_reviewed_state(appraisal_note):
   208	        appraisal_note.appraisal_status = LoanAppraisalNote.STATUS_REVIEWED
   209	        appraisal_note.save(update_fields=["appraisal_status"])
   210	
   211	    @transaction.atomic
   212	    def create_or_update(
   213	        self,
   214	        *,
   215	        actor,
   216	        application_id,
   217	        payload,
   218	        partial=False,
   219	        request_meta=None,
   220	        actor_permissions=None,
   221	    ):
   222	        permission = APPRAISAL_UPDATE_PERMISSION if partial else APPRAISAL_CREATE_PERMISSION
   223	        permissions = require_permission(
   224	            actor,
   225	            permission,
   226	            "You do not have permission to update appraisal notes."
   227	            if partial
   228	            else "You do not have permission to create appraisal notes.",
   229	            actor_permissions,
   230	        )
   231	        if not partial or "risk_assessment" in payload:
   232	            require_permission(
   233	                actor,
   234	                RISK_MANAGE_PERMISSION,
   235	                "You do not have permission to manage risk assessments.",
   236	                permissions,
   237	            )
   238	        application = (
   239	            LoanApplication.objects.select_for_update(of=("self",))
   240	            .select_related("created_by_user", "received_by_user")
   241	            .filter(loan_application_id=application_id)
   242	            .first()
   243	        )
   244	        if application is None:
   245	            raise CreditModuleNotFound("Loan application was not found.")
   246	        require_application_access(application, actor, permission, permissions)
   247	        payload = _clean_payload(payload, partial=partial)
   248	        current = (
   249	            LoanAppraisalNote.objects.select_for_update(of=("self",))
   250	            .select_related("risk_assessment", "prepared_by_user", "reviewed_by_user")
   251	            .filter(loan_application=application)
   252	            .first()
   253	        )
   254	        if partial:
   255	            loan_limit = current.loan_limit_snapshot_json if current is not None else {}
   256	        else:
   257	            projection_permissions = set(permissions) | {APPLICATION_READ_PERMISSION}
   258	            try:
   259	                eligibility = EligibilityAssessmentModule().get(
   260	                    actor=actor,
   261	                    application_id=application_id,
   262	                    actor_permissions=projection_permissions,
   263	                ).snapshot
   264	                eligibility = {key: value for key, value in eligibility.items() if key != "available_actions"}
   265	            except CreditModuleNotFound as exc:
   266	                raise CreditModuleInvalidStateError(
   267	                    "A stored eligible eligibility assessment is required before appraisal."
   268	                ) from exc
   269	            if eligibility["overall_result"] != "eligible":
   270	                raise CreditModuleInvalidStateError(
   271	                    "Appraisal creation requires eligibility overall_result eligible."
   272	                )
   273	            try:
   274	                loan_limit = LoanLimitCalculator().get_assessment(
   275	                    actor=actor,
   276	                    application_id=application_id,
   277	                    actor_permissions=projection_permissions,
   278	                ).snapshot
   279	                loan_limit = {key: value for key, value in loan_limit.items() if key != "available_actions"}
   280	            except CreditModuleNotFound as exc:
   281	                raise CreditModuleInvalidStateError(
   282	                    "A stored loan-limit assessment is required before appraisal."
   283	                ) from exc
   284	        if (
   285	            "recommended_amount" in payload
   286	            and loan_limit
   287	            and payload["recommended_amount"]
   288	            > Decimal(loan_limit["final_eligible_loan_amount"])
   289	            and not loan_limit["exception_required_flag"]
   290	        ):
   291	            raise CreditModuleValidationError(
   292	                {
   293	                    "recommended_amount": (
   294	                        "Cannot exceed the frozen final eligible amount unless the frozen "
