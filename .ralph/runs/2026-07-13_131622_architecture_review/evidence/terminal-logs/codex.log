   139	        try:
   140	            data, pagination = services.list_rules(request.GET)
   141	            return list_response(data, pagination, request)
   142	        except ValidationError as exc:
   143	            return _failure(request, exc)
   144	    try: return success_response(services.create_rule(user, request, parse_json_body(request)), request)
   145	    except (ValidationError, services.ConfigurationConflict) as exc: return _failure(request, exc)
   146	
