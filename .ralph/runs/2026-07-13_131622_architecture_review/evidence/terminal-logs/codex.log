    17	def list_approval_cases(*, actor, query_params):
    18	    unknown = set(query_params.keys()) - _LIST_PARAMS
    19	    if unknown:
    20	        raise ValidationError(
    21	            {field: "Unknown query parameter." for field in sorted(unknown)}
    22	        )
    23	    page = _positive_int("page", query_params.get("page"), 1)
    24	    page_size = min(_positive_int("page_size", query_params.get("page_size"), 20), 100)
    25	    assigned_to_me = _boolean("assigned_to_me", query_params.get("assigned_to_me"))
    26	    queryset = (
    27	        ApprovalCase.objects.select_related("loan_application", "loan_appraisal_note")
    28	        .prefetch_related("actions")
    29	        .filter(
    30	            version__gte=2,
    31	            approval_matrix_rule_id__isnull=False,
    32	            sanction_committee_id__isnull=False,
    33	            decision_date__isnull=False,
