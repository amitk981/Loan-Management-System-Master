   126	        required_approvers.append(
   127	            {
   128	                **item,
   129	                "decision": action.decision if action else None,
   130	                "acted_at": (
   131	                    action.acted_at.isoformat().replace("+00:00", "Z")
   132	                    if action
   133	                    else None
   134	                ),
   135	            }
   136	        )
   137	    snapshot = {
   138	        **serialize_case_snapshot(case),
   139	        "required_approvers": required_approvers,
   140	        "review_facts": _review_facts(case),
   141	        "available_actions": _available_actions(
   142	            case, actor, actor_permissions, action_by_user
   143	        ),
