   257	def is_routable_approval_case(case):
   258	    """Validate the complete immutable authority and credit snapshot."""
   259	    required = case.required_approvers_json
   260	    matrix = case.matrix_projection_json
   261	    committee = case.committee_projection_json
   262	    return (
   263	        case.version >= 2
   264	        and case.approval_matrix_rule_id is not None
   265	        and bool(case.approval_matrix_rule_version)
   266	        and case.sanction_committee_id is not None
   267	        and bool(case.sanction_committee_version)
   268	        and case.decision_date is not None
   269	        and case.amount is not None
   270	        and bool(case.related_entity_type)
   271	        and case.related_entity_id is not None
   272	        and isinstance(required, list)
   273	        and bool(required)
   274	        and isinstance(case.excluded_approvers_json, list)
   275	        and all(
   276	            isinstance(item, dict)
   277	            and item.get("role_code")
   278	            and item.get("user_id")
   279	            and item.get("full_name")
   280	            for item in required
   281	        )
   282	        and isinstance(matrix, dict)
   283	        and matrix.get("approval_matrix_rule_id") == str(case.approval_matrix_rule_id)
   284	        and matrix.get("version_number") == case.approval_matrix_rule_version
   285	        and matrix.get("decision_date") == case.decision_date.isoformat()
   286	        and _matrix_projection_is_coherent(case, matrix)
   287	        and isinstance(committee, dict)
   288	        and committee.get("sanction_committee_id") == str(case.sanction_committee_id)
   289	        and committee.get("version_number") == case.sanction_committee_version
   290	        and committee.get("decision_date") == case.decision_date.isoformat()
   291	        and _approver_snapshot_is_coherent(required, matrix, committee)
   292	        and _loan_limit_provenance_is_complete(case)
   293	    )
   294	
   295	
   296	def _matrix_projection_is_coherent(case, matrix):
   297	    condition = matrix.get("condition_code") or ""
   298	    roles = matrix.get("required_approver_roles")
   299	    director_count = matrix.get("required_director_count")
   300	    return (
   301	        case.approval_type == ApprovalCase.TYPE_SANCTION
   302	        and case.related_entity_type == "loan_application"
   303	        and str(case.related_entity_id) == str(case.loan_application_id)
   304	        and matrix.get("decision_type") == "loan_sanction"
   305	        and _same_amount(matrix.get("amount"), case.amount)
   306	        and _amount_inside_projection(case.amount, matrix)
   307	        and condition == (case.exception_condition_code or "")
   308	        and condition in ("", "exceeds_permissible_limit")
   309	        and (
   310	            (not condition and not case.exception_reason)
   311	            or (
   312	                condition
   313	                and bool(case.exception_reason.strip())
   314	                and case.exception_reason == case.reason_for_approval
   315	            )
   316	        )
   317	        and isinstance(roles, list)
   318	        and roles == ["cfo", "director"]
   319	        and isinstance(director_count, int)
   320	        and director_count in (1, 2)
   321	        and matrix.get("joint_approval_required") is True
   322	        and isinstance(matrix.get("register_required"), str)
   323	        and bool(matrix["register_required"].strip())
   324	        and case.loan_appraisal_note.reviewed_at is not None
   325	        and case.decision_date
   326	        == timezone.localdate(case.loan_appraisal_note.reviewed_at)
   327	        and case.amount == case.loan_appraisal_note.recommended_amount
   328	    )
   329	
   330	
   331	def _approver_snapshot_is_coherent(required, matrix, committee):
   332	    cfo_id = str(committee.get("cfo_user_id") or "")
   333	    director_ids = committee.get("director_user_ids")
   334	    if (
   335	        not cfo_id
   336	        or not isinstance(director_ids, list)
   337	        or len(director_ids) != 2
   338	        or any(not item for item in director_ids)
   339	    ):
   340	        return False
   341	    director_ids = [str(item) for item in director_ids]
   342	    committee_ids = [cfo_id, *director_ids]
   343	    if len(set(committee_ids)) != 3:
   344	        return False
   345	    expected = [("cfo", cfo_id)] + [
   346	        ("director", user_id)
   347	        for user_id in director_ids[: matrix["required_director_count"]]
   348	    ]
   349	    if len(required) != len(expected):
   350	        return False
   351	    actual = []
   352	    for item in required:
   353	        if (
   354	            not isinstance(item, dict)
   355	            or not isinstance(item.get("full_name"), str)
   356	            or not item["full_name"].strip()
   357	        ):
   358	            return False
   359	        actual.append((item.get("role_code"), str(item.get("user_id") or "")))
   360	    return actual == expected and len({user_id for _, user_id in actual}) == len(actual)
   361	
   362	
   363	def _same_amount(first, second):
   364	    try:
   365	        return Decimal(str(first)) == Decimal(str(second))
   366	    except (InvalidOperation, TypeError, ValueError):
   367	        return False
   368	
   369	
   370	def _amount_inside_projection(amount, matrix):
   371	    try:
   372	        amount = Decimal(str(amount))
   373	        minimum = Decimal(str(matrix["amount_min"]))
   374	        maximum = (
   375	            Decimal(str(matrix["amount_max"]))
   376	            if matrix.get("amount_max") is not None
   377	            else None
   378	        )
   379	    except (KeyError, InvalidOperation, TypeError, ValueError):
   380	        return False
   381	    return amount >= minimum and (maximum is None or amount <= maximum)
   382	
   383	
   384	def _loan_limit_provenance_is_complete(case):
   385	    provenance = case.loan_limit_provenance_json
   386	    required = (
   387	        "loan_limit_assessment_id",
   388	        "loan_application_id",
   389	        "exception_required_flag",
   390	        "calculation_rule_version",
   391	        "policy_config_id",
   392	        "policy_name",
   393	        "calculated_at",
   394	    )
   395	    snapshot = case.loan_appraisal_note.loan_limit_snapshot_json
   396	    condition_requires_exception = bool(case.exception_condition_code)
   397	    return (
   398	        isinstance(provenance, dict)
   399	        and all(provenance.get(key) not in (None, "") for key in required)
   400	        and str(provenance["loan_limit_assessment_id"])
   401	        == str(case.loan_appraisal_note.loan_limit_assessment_id_snapshot)
   402	        and str(provenance["loan_application_id"]) == str(case.loan_application_id)
   403	        and isinstance(provenance["exception_required_flag"], bool)
   404	        and provenance["exception_required_flag"] == case.exception_required_flag
   405	        and (not provenance["exception_required_flag"] or condition_requires_exception)
   406	        and isinstance(snapshot, dict)
   407	        and all(provenance.get(key) == snapshot.get(key) for key in required)
   408	    )
