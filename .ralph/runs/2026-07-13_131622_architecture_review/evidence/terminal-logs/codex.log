    86	                allowed=False,
    87	                reason="approval_case_not_assigned",
    88	                error_code="OBJECT_ACCESS_DENIED",
    89	                required_permission="approvals.case.read",
    90	            )
    91	        )
    92	    return serialize_case_detail(case, actor, set(actor_permissions))
