    34	@require_http_methods(["GET"])
    35	def approval_case_collection(request):
    36	    user, response = http_auth.authenticated_user(request)
    37	    if response is not None:
    38	        return response
    39	    if "approvals.case.read" not in effective_permission_codes(user):
    40	        return error_response(
    41	            request, 403, "FORBIDDEN", "You do not have approval case read permission."
    42	        )
    43	    try:
    44	        data, pagination = approval_case_engine.list_approval_cases(
    45	            actor=user, query_params=request.GET
    46	        )
    47	        return list_response(data, pagination, request)
    48	    except ValidationError as exc:
    49	        details = exc.message_dict if hasattr(exc, "message_dict") else {}
    50	        return error_response(
    51	            request,
    52	            400,
    53	            "VALIDATION_ERROR",
    54	            "Approval case filters failed validation.",
    55	            {key: value[0] if isinstance(value, list) else value for key, value in details.items()},
    56	        )
