   102	def _approval_case_action(request, approval_case_id, handler):
   103	    user, response = http_auth.authenticated_user(request)
   104	    if response is not None:
   105	        return response
   106	    try:
   107	        data = handler(
   108	            actor=user,
   109	            case_id=approval_case_id,
   110	            payload=parse_json_body(request),
   111	            actor_permissions=effective_permission_codes(user),
   112	            request_meta={
   113	                "request_id": request.headers.get("X-Request-ID"),
   114	                "ip_address": request.META.get("REMOTE_ADDR", ""),
   115	                "user_agent": request.headers.get("User-Agent", ""),
   116	            },
   117	        )
   118	        return success_response(data, request)
   119	    except ObjectDoesNotExist:
   120	        return error_response(request, 404, "NOT_FOUND", "Approval case was not found.")
   121	    except ValidationError as exc:
   122	        details = exc.message_dict if hasattr(exc, "message_dict") else {}
   123	        return error_response(
   124	            request,
   125	            400,
   126	            "VALIDATION_ERROR",
   127	            "Approval action failed validation.",
   128	            {key: value[0] if isinstance(value, list) else value for key, value in details.items()},
   129	        )
   130	    except approval_actions.ApprovalActionConflict as exc:
   131	        return error_response(
   132	            request, exc.status, exc.code, exc.message, exc.field_errors
   133	        )
