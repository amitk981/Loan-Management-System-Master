   104	def serialize_case_summary(case):
   105	    return {
   106	        "approval_case_id": str(case.pk),
   107	        "approval_type": case.approval_type,
   108	        "related_entity_type": case.related_entity_type,
   109	        "related_entity_id": str(case.related_entity_id),
   110	        "loan_application_id": str(case.loan_application_id),
   111	        "application_reference_number": case.loan_application.application_reference_number,
   112	        "amount": f"{case.amount:.2f}",
   113	        "current_status": case.current_status,
   114	        "decision_date": case.decision_date.isoformat(),
   115	        "version": case.version,
   116	    }
