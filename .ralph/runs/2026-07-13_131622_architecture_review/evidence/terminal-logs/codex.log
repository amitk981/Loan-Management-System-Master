    95	def can_read_approval_case(*, actor, case):
    96	    """Return whether the immutable case snapshot gives this actor object scope."""
    97	    actor_id = str(actor.pk)
    98	    return any(
    99	        isinstance(item, dict) and str(item.get("user_id")) == actor_id
   100	        for item in case.required_approvers_json
   101	    )
