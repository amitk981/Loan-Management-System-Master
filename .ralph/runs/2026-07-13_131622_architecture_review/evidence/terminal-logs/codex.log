    71	def get_approval_case(*, actor, case_id, actor_permissions):
    72	    case = (
    73	        ApprovalCase.objects.select_related(
    74	            "loan_application",
    75	            "loan_appraisal_note__risk_assessment",
    76	        )
    77	        .prefetch_related("actions")
    78	        .filter(pk=case_id)
