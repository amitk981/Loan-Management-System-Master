   218	def _available_actions(case, actor, actor_permissions, action_by_user):
   219	    actor_id = str(actor.pk)
   220	    pending_assignment = is_pending_approval_case_actor(
   221	        case=case, actor_id=actor_id
   222	    )
   223	    action_specs = (
   224	        ("approve", "Approve", "approvals.case.approve"),
   225	        ("reject", "Reject", "approvals.case.reject"),
   226	        ("return", "Return for Clarification", "approvals.case.return"),
   227	    )
   228	    actions = []
   229	    for action_code, label, permission in action_specs:
   230	        enabled = (
   231	            case.current_status == ApprovalCase.STATUS_PENDING
   232	            and pending_assignment
   233	            and permission in actor_permissions
   234	        )
   235	        if case.current_status != ApprovalCase.STATUS_PENDING:
   236	            reason = "Approval case is not pending."
   237	        elif actor_id in action_by_user:
   238	            reason = "You have already acted on this approval case."
   239	        elif not pending_assignment:
   240	            reason = "You are not a pending approver for this case."
   241	        elif permission not in actor_permissions:
   242	            reason = "Required permission is not granted."
   243	        else:
   244	            reason = None
   245	        actions.append(
   246	            {
   247	                "action_code": action_code,
   248	                "label": label,
   249	                "enabled": enabled,
   250	                "disabled_reason": reason,
   251	                "required_permission": permission,
   252	            }
   253	        )
   254	    return actions
