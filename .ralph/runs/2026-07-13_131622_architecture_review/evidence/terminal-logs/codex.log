    13	def _authorized(request, manage=False):
    14	    user, response = http_auth.authenticated_user(request)
    15	    if response is not None: return user, response
    16	    allowed = services.can_manage(user) if manage else services.can_read(user)
    17	    if not allowed: return user, error_response(request, 403, "FORBIDDEN", "You do not have approval matrix permission.")
    18	    return user, None
    19	
    20	
    21	def _failure(request, exc):
    22	    if isinstance(exc, services.ConfigurationConflict):
    23	        status = 403 if exc.code in {
    24	            "FORBIDDEN", "MAKER_CHECKER_VIOLATION", "APPROVAL_AUTHORITY_REQUIRED"
    25	        } else 409
    26	        return error_response(request, status, exc.code, str(exc))
    27	    if isinstance(exc, ObjectDoesNotExist):
    28	        return error_response(request, 404, "NOT_FOUND", "Configuration was not found.")
    29	    details = exc.message_dict if hasattr(exc, "message_dict") else {"non_field_errors": [str(exc)]}
    30	    return error_response(request, 400, "VALIDATION_ERROR", "Configuration failed validation.",
    31	                          {key: value[0] if isinstance(value, list) else value for key, value in details.items()})
    32	
