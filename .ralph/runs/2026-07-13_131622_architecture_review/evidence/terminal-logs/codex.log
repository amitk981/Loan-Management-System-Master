   119	def serialize_case_detail(case, actor, actor_permissions):
   120	    action_by_user = {
   121	        str(action.approver_user_id): action for action in case.actions.all()
   122	    }
   123	    required_approvers = []
   124	    for item in case.required_approvers_json:
