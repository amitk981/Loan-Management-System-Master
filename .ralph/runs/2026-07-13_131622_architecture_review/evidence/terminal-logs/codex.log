   411	def is_pending_approval_case_actor(*, case, actor_id):
   412	    """Return whether an in-scope actor still owns a pending decision slot."""
   413	    if case.current_status != ApprovalCase.STATUS_PENDING:
   414	        return False
   415	    excluded_ids = {
   416	        str(item.get("user_id") if isinstance(item, dict) else item)
   417	        for item in case.excluded_approvers_json
   418	        if (isinstance(item, dict) and item.get("user_id")) or not isinstance(item, dict)
   419	    }
   420	    acted_ids = {str(action.approver_user_id) for action in case.actions.all()}
   421	    return actor_id not in excluded_ids and actor_id not in acted_ids and any(
   422	        str(item.get("user_id")) == actor_id
   423	        for item in case.required_approvers_json
   424	        if isinstance(item, dict)
   425	    )
