   249	def _submitted_version(payload):
   250	    unknown = set(payload) - {"version", "comments"}
   251	    errors = {field: "Unknown field." for field in sorted(unknown)}
   252	    version = payload.get("version")
   253	    if not isinstance(version, int) or isinstance(version, bool) or version < 1:
   254	        errors["version"] = "Must be a positive integer."
   255	    if errors:
   256	        raise ApprovalActionConflict(
   257	            "Approval action failed validation.",
   258	            code="VALIDATION_ERROR",
   259	            status=400,
   260	            field_errors=errors,
   261	        )
   262	    return version
   263	
   264	
   265	def _comments(payload, *, required):
   266	    comments = payload.get("comments")
   267	    if comments is None and not required:
   268	        return None
   269	    if not isinstance(comments, str):
   270	        raise ApprovalActionConflict(
   271	            "Approval action failed validation.",
   272	            code="VALIDATION_ERROR",
   273	            status=400,
   274	            field_errors={"comments": "Must be a string."},
   275	        )
   276	    cleaned = comments.strip()
   277	    if required and not cleaned:
   278	        raise ApprovalActionConflict(
   279	            "Approval action failed validation.", code="VALIDATION_ERROR", status=400,
   280	            field_errors={"comments": "This field must not be blank."},
   281	        )
   282	    return cleaned or None
