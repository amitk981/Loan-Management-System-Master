    65	def evaluate_appraisal_update(note, permissions):
    66	    if note.appraisal_status != LoanAppraisalNote.STATUS_DRAFT:
    67	        return AppraisalTransitionEvaluation(False, "Only draft appraisal notes can be updated.")
    68	    return AppraisalTransitionEvaluation(True, None)
    69	
    70	
    71	def evaluate_appraisal_revalidation(note, permissions):
    72	    if RISK_MANAGE_PERMISSION not in permissions:
    73	        return AppraisalTransitionEvaluation(False, "Risk changes require risk-assessment authority.")
    74	    if note.appraisal_status not in {LoanAppraisalNote.STATUS_DRAFT, LoanAppraisalNote.STATUS_REVIEW_PENDING, LoanAppraisalNote.STATUS_REVIEWED}:
    75	        return AppraisalTransitionEvaluation(False, "Rejected or sanction-submitted appraisal notes require governed manual repair.")
    76	    if note.prerequisite_provenance != "legacy_unverified":
    77	        return AppraisalTransitionEvaluation(False, "Only legacy-unverified appraisal prerequisites can be revalidated.")
    78	    return AppraisalTransitionEvaluation(True, None)
    79	
    80	
    81	def evaluate_appraisal_submission(note):
    82	    if note.appraisal_status != LoanAppraisalNote.STATUS_DRAFT:
    83	        return AppraisalTransitionEvaluation(False, "Only a draft appraisal note can be submitted for review.")
    84	    if note.prerequisite_provenance != "verified":
    85	        return AppraisalTransitionEvaluation(False, "Appraisal prerequisites must be explicitly revalidated before review.")
    86	    if _submission_errors(note):
    87	        return AppraisalTransitionEvaluation(False, "Appraisal and risk assessment must be complete before review.")
    88	    return AppraisalTransitionEvaluation(True, None)
    89	
    90	
    91	def evaluate_appraisal_review(note, actor):
    92	    if note.appraisal_status != LoanAppraisalNote.STATUS_REVIEW_PENDING:
    93	        return AppraisalTransitionEvaluation(False, "Only a review-pending appraisal note can be reviewed.")
    94	    if note.prerequisite_provenance != "verified":
    95	        return AppraisalTransitionEvaluation(False, "Appraisal review requires verified prerequisite snapshots.")
    96	    if note.prepared_by_user_id == actor.pk:
    97	        return AppraisalTransitionEvaluation(False, "The appraisal preparer cannot review their own appraisal note.")
    98	    return AppraisalTransitionEvaluation(True, None)
    99	
   100	
   101	def evaluate_sanction_submission(note, *, latest_review=None, history_locked=False):
   102	    if note.appraisal_status != LoanAppraisalNote.STATUS_REVIEWED:
   103	        return AppraisalTransitionEvaluation(False, "Only a reviewed appraisal note can be submitted for sanction.")
   104	    if note.prerequisite_provenance != "verified":
   105	        return AppraisalTransitionEvaluation(False, "Sanction submission requires verified prerequisite snapshots.")
   106	    if _submission_errors(note):
   107	        return AppraisalTransitionEvaluation(False, "Sanction submission requires a complete appraisal and risk assessment.")
   108	    if not _frozen_prerequisites_complete(note):
   109	        return AppraisalTransitionEvaluation(False, "Sanction submission requires complete frozen eligibility and loan-limit snapshots.")
   110	    if not history_locked:
   111	        latest_review = note.review_decisions.order_by("decided_at", "appraisal_review_decision_id").last()
   112	    if latest_review is None or not _latest_review_matches_note(note, latest_review):
   113	        return AppraisalTransitionEvaluation(False, "The latest immutable review decision does not match the reviewed appraisal.")
   114	    return AppraisalTransitionEvaluation(True, None)
