+def _safe_member_values(member, fields):
+    result = {}
+    for field in fields:
+        if field in _IDENTITY_FIELDS:
+            result[field] = mask_protected_identity(getattr(member, f"{field}_encrypted"), 10 if field == "pan" else 12)
