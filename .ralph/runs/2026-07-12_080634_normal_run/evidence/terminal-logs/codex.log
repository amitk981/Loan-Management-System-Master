diff --git a/sfpcl_credit/tests/test_member_governance_api.py b/sfpcl_credit/tests/test_member_governance_api.py
new file mode 100644
index 0000000000000000000000000000000000000000..3eabdca5ff29512db2822a89b7bb79c4428fa289
