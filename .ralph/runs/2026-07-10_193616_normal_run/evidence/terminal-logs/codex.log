+class AppraisalReviewDecision(models.Model):
+    PROVENANCE_NATIVE = "native"
+    PROVENANCE_LEGACY_LATEST_ONLY = "legacy_latest_only"
+
+    appraisal_review_decision_id = models.UUIDField(
+        primary_key=True,
+        default=uuid.uuid4,
+        editable=False,
+    )
+    loan_appraisal_note = models.ForeignKey(
+        LoanAppraisalNote,
