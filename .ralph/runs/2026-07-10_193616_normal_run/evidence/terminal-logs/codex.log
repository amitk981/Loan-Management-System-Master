                    "appraisal.returned",
                    "appraisal.rejected",
                )
            ).exists()
        )
        )
        self.assertEqual(apps.get_model("applications", "RejectionNote").objects.count(), 0)
        self.assertEqual(
            WorkflowEvent.objects.filter(workflow_name="appraisal_note").count(),
            workflow_count_before_denials,
        )

