+            workflow_name="appraisal_note",
+            entity_type="loan_appraisal_note",
+            entity_id=note.pk,
+            from_state=from_state,
+            to_state=note.appraisal_status,
+            trigger_reason=f"Appraisal review decision recorded as {decision}.",
