+            entity_id=note.pk,
+            old_value_json={"appraisal_status": from_state},
+            new_value_json={
+                "loan_appraisal_note_id": str(note.pk),
+                "loan_application_id": str(note.loan_application_id),
+                "appraisal_status": note.appraisal_status,
+                "decision": decision,
+                "reviewed_by_user_id": str(actor.pk),
