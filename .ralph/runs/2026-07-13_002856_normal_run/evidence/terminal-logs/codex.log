+        return unavailable
+    land_area = sum((row.area_acres for row in verified_land), Decimal("0.00"))
+    if (
+        profile.land_area_under_cultivation_acres is None
+        or profile.land_area_under_cultivation_acres != land_area
+    ):
+        return unavailable
