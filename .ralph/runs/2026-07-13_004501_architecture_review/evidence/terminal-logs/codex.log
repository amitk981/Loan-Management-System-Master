   125	def application_limit_projection(member, *, requested_amount=None):
   126	    requested = _optional_money(requested_amount, "requested_amount")
   127	    unavailable = {
   128	        "status": "unavailable",
   129	        "unavailable_reason": "verified_active_member_authority_not_available",
   130	        "shareholding_based_limit_amount": None,
   131	        "land_based_limit_amount": None,
   132	        "final_eligible_loan_amount": None,
   133	        "requested_amount": _money(requested),
   134	        "amount_within_limit_flag": None,
   135	        "exception_required_flag": None,
   136	        "calculated_as_of_date": None,
   137	        "calculation_rule_version": None,
   138	    }
   139	    today = timezone.localdate()
   140	    authority = ActiveMemberStatus.objects.filter(
   141	        active_member_status_id=member.active_member_status_id,
   142	        member=member,
   143	        status__in=("active", "relaxation"),
   144	        effective_from__lte=today,
   145	        effective_to__isnull=True,
   146	    ).first()
   147	    if authority is None:
   148	        return unavailable
   149	    current_result = ActiveMemberStatusModule().calculate(
   150	        member_id=member.member_id,
   151	        as_of_date=today,
   152	    )
   153	    if (
   154	        str(authority.result_id) != current_result.result_id
   155	        or authority.evidence_snapshot != current_result.to_snapshot()
   156	        or current_result.member_active_check not in {"pass", "relaxation"}
   157	        or not current_result.qualification_route
   158	    ):
   159	        return unavailable
   160	    shareholdings = list(
   161	        Shareholding.objects.filter(
   162	            member=member,
   163	            status="active",
   164	            valuation_effective_date__lte=today,
   165	            valuation_per_share__gt=0,
   166	            number_of_shares__gt=0,
   167	        )[:2]
   168	    )
   169	    verified_land = list(
   170	        LandHolding.objects.filter(member=member, verification_status="verified")
   171	    )
   172	    profile = IndividualMemberProfile.objects.filter(member=member).first()
   173	    if len(shareholdings) != 1 or not verified_land or profile is None:
   174	        return unavailable
   175	    land_area = sum((row.area_acres for row in verified_land), Decimal("0.00"))
   176	    if (
   177	        profile.land_area_under_cultivation_acres is None
   178	        or profile.land_area_under_cultivation_acres != land_area
   179	    ):
   180	        return unavailable
   181	    try:
   182	        policy = resolve_effective_loan_policy(calculation_date=today)
   183	    except ConfigurationResolutionError:
   184	        return unavailable
   185	    shareholding = shareholdings[0]
   186	    share_limit, land_limit, final_limit = calculate_limit_amounts(
   187	        number_of_shares=shareholding.number_of_shares,
   188	        valuation_per_share=shareholding.valuation_per_share,
   189	        land_area=land_area,
   190	        policy=policy,
   191	    )
   192	    within_limit = requested <= final_limit if requested is not None else None
   193	    return {
   194	        "status": "available",
   195	        "unavailable_reason": None,
   196	        "shareholding_based_limit_amount": _money(share_limit),
   197	        "land_based_limit_amount": _money(land_limit),
   198	        "final_eligible_loan_amount": _money(final_limit),
   199	        "requested_amount": _money(requested),
   200	        "amount_within_limit_flag": within_limit,
   201	        "exception_required_flag": not within_limit if within_limit is not None else None,
   202	        "calculated_as_of_date": current_result.calculated_as_of_date,
   203	        "calculation_rule_version": policy.policy_version,
   204	    }
   205	
   206	
   207	def _optional_money(value, field):
   208	    if value in (None, ""):
   209	        return None
   210	    try:
   211	        parsed = Decimal(str(value))
   212	    except (InvalidOperation, TypeError, ValueError) as exc:
   213	        raise ValidationError({field: "Enter a valid amount."}) from exc
   214	    if not parsed.is_finite() or parsed <= 0:
   215	        raise ValidationError({field: "Amount must be greater than zero."})
   216	    return parsed.quantize(Decimal("0.01"))
