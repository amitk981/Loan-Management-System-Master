    39	
    40	def calculate_limit_amounts(*, number_of_shares, valuation_per_share, land_area, policy):
    41	    per_share_limits = []
    42	    if policy.share_limit_percentage is not None:
    43	        per_share_limits.append(
    44	            valuation_per_share * policy.share_limit_percentage / Decimal("100")
    45	        )
    46	    if policy.per_share_cap_amount is not None:
    47	        per_share_limits.append(policy.per_share_cap_amount)
    48	    share_limit = (Decimal(number_of_shares) * min(per_share_limits)).quantize(Decimal("0.01"))
    49	    land_limit = (land_area * policy.default_scale_of_finance_per_acre_amount).quantize(Decimal("0.01"))
    50	    return share_limit, land_limit, min(share_limit, land_limit)
