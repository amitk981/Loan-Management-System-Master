   862	def serialize_produce_supply_record(record, user=None, portal=False):
   863	    can_verify = bool(user and user_can_verify_produce_supply(user))
   864	    maker = bool(user and record.captured_by_user_id == user.user_id)
   865	    action = {
   866	        "action_code": PRODUCE_SUPPLY_VERIFY_PERMISSION,
   867	        "label": "Verify supply record",
   868	        "enabled": can_verify and not maker and not record.verified_flag,
   869	        "disabled_reason": None,
   870	        "required_permission": PRODUCE_SUPPLY_VERIFY_PERMISSION,
   871	        "required_role": None,
   872	    }
   873	    if maker:
   874	        action["disabled_reason"] = "The record maker cannot verify this supply record."
   875	    elif record.verified_flag:
   876	        action["disabled_reason"] = "This supply record is already verified."
   877	    elif not can_verify:
   878	        action["disabled_reason"] = "Missing supply verification permission."
   879	    data = {
   880	        "produce_supply_record_id": str(record.produce_supply_record_id),
   881	        "member_id": str(record.member_id),
   882	        "financial_year": record.financial_year,
   883	        "supplied_to_entity_type": record.supplied_to_entity_type,
