BASE_DIR = Path(__file__).resolve().parents[1]


def env_bool(name, default):
    value = os.environ.get(name)
    if value is None:
        return default
    return value.strip().lower() in {"1", "true", "yes", "on"}


def env_csv(name, default):
    value = os.environ.get(name)
    if value is None:
