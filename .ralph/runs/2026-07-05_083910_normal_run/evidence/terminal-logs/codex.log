diff --git a/sfpcl_credit/workflows/models.py b/sfpcl_credit/workflows/models.py
new file mode 100644
index 0000000000000000000000000000000000000000..c1bca94d27fff7255e80dfe027648caf390de3ba
--- /dev/null
+++ b/sfpcl_credit/workflows/models.py
@@ -0,0 +1,24 @@
+import uuid
+
+from django.db import models
+from django.utils import timezone
+
+
+class WorkflowEvent(models.Model):
+    workflow_event_id = models.UUIDField(
+        primary_key=True, default=uuid.uuid4, editable=False
+    )
+    workflow_name = models.CharField(max_length=100, db_index=True)
+    entity_type = models.CharField(max_length=100, db_index=True)
+    entity_id = models.UUIDField(db_index=True)
+    from_state = models.CharField(max_length=100, blank=True, null=True)
+    to_state = models.CharField(max_length=100, db_index=True)
