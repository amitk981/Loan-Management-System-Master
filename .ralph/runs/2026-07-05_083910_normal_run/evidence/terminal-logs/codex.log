+        self.assertEqual(response.status_code, 403)
+        assert_error_envelope(self, response.json(), "PERMISSION_DENIED")
+
+    def test_authorized_list_returns_item_shape_and_pagination_newest_first(self):
+        response = self.client.get(
+            self.URL,
