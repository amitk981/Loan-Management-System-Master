   518	    @transaction.atomic
   519	    def review(
   520	        self,
   521	        *,
   522	        actor,
   523	        appraisal_id,
   524	        decision,
   525	        comments,
   526	        request_meta=None,
   527	        actor_permissions=None,
   528	        payload_fields=None,
   529	    ):
   530	        permissions = require_permission(
   531	            actor,
   532	            APPRAISAL_REVIEW_PERMISSION,
   533	            "You do not have permission to review appraisal notes.",
   534	            actor_permissions,
   535	        )
   536	        errors = {}
   537	        payload = payload_fields or {}
   538	        allowed_fields = {"decision", "review_comments"}
   539	        if decision == "rejected":
   540	            allowed_fields.update(
   541	                {
   542	                    "rejection_reason_category",
   543	                    "detailed_reason",
   544	                    "reapply_allowed_flag",
   545	                    "communication_mode",
   546	                }
   547	            )
   548	        unknown = sorted(set(payload) - allowed_fields)
   549	        errors.update({field: "Unknown field." for field in unknown})
   550	        if decision not in {"reviewed", "returned", "rejected"}:
   551	            errors["decision"] = "Must be reviewed, returned, or rejected."
   552	        if not isinstance(comments, str) or not comments.strip():
   553	            errors["review_comments"] = "This field must not be blank."
   554	        if errors:
   555	            raise CreditModuleValidationError(errors)
   556	        note = (
   557	            LoanAppraisalNote.objects.select_for_update()
   558	            .select_related(
   559	                "loan_application__created_by_user",
   560	                "loan_application__received_by_user",
   561	                "risk_assessment",
   562	                "prepared_by_user",
   563	                "reviewed_by_user",
   564	            )
   565	            .filter(loan_appraisal_note_id=appraisal_id)
   566	            .first()
   567	        )
   568	        if note is None:
   569	            raise CreditModuleNotFound("Appraisal note was not found.")
   570	        require_application_access(
   571	            note.loan_application,
   572	            actor,
   573	            APPRAISAL_REVIEW_PERMISSION,
   574	            permissions,
   575	        )
   576	        if note.appraisal_status != LoanAppraisalNote.STATUS_REVIEW_PENDING:
   577	            raise CreditModuleInvalidStateError(
   578	                "Only a review-pending appraisal note can be reviewed."
   579	            )
   580	        if note.prerequisite_provenance != "verified":
   581	            raise CreditModuleInvalidStateError(
   582	                "Appraisal review requires verified prerequisite snapshots."
   583	            )
