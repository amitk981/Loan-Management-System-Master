   399	    @transaction.atomic
   400	    def revalidate_prerequisites(
   401	        self,
   402	        *,
   403	        actor,
   404	        appraisal_id,
   405	        payload,
   406	        request_meta=None,
   407	        actor_permissions=None,
   408	    ):
   409	        permissions = require_permission(
   410	            actor,
   411	            APPRAISAL_UPDATE_PERMISSION,
   412	            "You do not have permission to revalidate appraisal prerequisites.",
   413	            actor_permissions,
   414	        )
   415	        require_permission(
   416	            actor,
   417	            RISK_MANAGE_PERMISSION,
   418	            "You do not have permission to manage risk assessments.",
   419	            permissions,
   420	        )
   421	        if payload:
   422	            raise CreditModuleValidationError(
   423	                {field: "Unknown field." for field in sorted(payload)}
   424	            )
   425	        note = (
   426	            LoanAppraisalNote.objects.select_for_update()
   427	            .select_related(
   428	                "loan_application__created_by_user",
   429	                "loan_application__received_by_user",
   430	                "risk_assessment",
   431	                "prepared_by_user",
   432	                "reviewed_by_user",
   433	            )
   434	            .filter(loan_appraisal_note_id=appraisal_id)
   435	            .first()
   436	        )
   437	        if note is None:
   438	            raise CreditModuleNotFound("Appraisal note was not found.")
   439	        require_application_access(
   440	            note.loan_application,
   441	            actor,
   442	            APPRAISAL_UPDATE_PERMISSION,
   443	            permissions,
   444	        )
   445	        if note.appraisal_status != LoanAppraisalNote.STATUS_DRAFT:
   446	            raise CreditModuleInvalidStateError(
   447	                "Only a draft appraisal note can revalidate prerequisites."
   448	            )
   449	        if note.prerequisite_provenance != "legacy_unverified":
   450	            raise CreditModuleInvalidStateError(
   451	                "Only legacy-unverified appraisal prerequisites can be revalidated."
   452	            )
   453	        projection_permissions = set(permissions) | {APPLICATION_READ_PERMISSION}
   454	        eligibility = EligibilityAssessmentModule().get(
   455	            actor=actor,
   456	            application_id=note.loan_application_id,
   457	            actor_permissions=projection_permissions,
   458	        ).snapshot
   459	        if eligibility["overall_result"] != "eligible":
   460	            raise CreditModuleInvalidStateError(
   461	                "Revalidation requires eligibility overall_result eligible."
   462	            )
   463	        loan_limit = LoanLimitCalculator().get_assessment(
   464	            actor=actor,
   465	            application_id=note.loan_application_id,
   466	            actor_permissions=projection_permissions,
   467	        ).snapshot
   468	        note.eligibility_assessment_id_snapshot = eligibility[
   469	            "eligibility_assessment_id"
   470	        ]
   471	        note.loan_limit_assessment_id_snapshot = loan_limit[
   472	            "loan_limit_assessment_id"
   473	        ]
   474	        note.eligibility_snapshot_json = eligibility
   475	        note.loan_limit_snapshot_json = loan_limit
   476	        note.prerequisite_provenance = "verified"
   477	        note.save(
   478	            update_fields=(
   479	                "eligibility_assessment_id_snapshot",
   480	                "loan_limit_assessment_id_snapshot",
   481	                "eligibility_snapshot_json",
   482	                "loan_limit_snapshot_json",
   483	                "prerequisite_provenance",
   484	            )
   485	        )
   486	        request_meta = normalize_request_meta(request_meta)
   487	        AuditLog.objects.create(
   488	            actor_user=actor,
   489	            action="appraisal.prerequisites_revalidated",
   490	            entity_type="loan_appraisal_note",
   491	            entity_id=note.pk,
   492	            old_value_json={"prerequisite_provenance": "legacy_unverified"},
   493	            new_value_json={
   494	                "prerequisite_provenance": "verified",
   495	                "eligibility_assessment_id": str(
   496	                    note.eligibility_assessment_id_snapshot
   497	                ),
   498	                "loan_limit_assessment_id": str(
   499	                    note.loan_limit_assessment_id_snapshot
   500	                ),
   501	                "request_id": request_meta.request_id,
   502	            },
   503	            ip_address=request_meta.ip_address,
   504	            user_agent=request_meta.user_agent,
   505	        )
   506	        record_workflow_event(
   507	            actor=actor,
   508	            workflow_name="appraisal_note",
   509	            entity_type="loan_appraisal_note",
   510	            entity_id=note.pk,
   511	            from_state=note.appraisal_status,
   512	            to_state=note.appraisal_status,
   513	            trigger_reason="Appraisal prerequisite projections revalidated.",
   514	            action_code="appraisal.prerequisites_revalidated",
   515	        )
   516	        return AppraisalNoteResult(snapshot=appraisal_note_snapshot(note))
