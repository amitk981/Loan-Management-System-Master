   276	    def get(self, *, actor, application_id, actor_permissions=None):
   277	        permissions = actor_permissions or auth_service.effective_permission_codes(actor)
   278	        permission = next(
   279	            (code for code in APPRAISAL_READ_PERMISSIONS if code in permissions),
   280	            None,
   281	        )
   282	        if permission is None:
   283	            require_permission(
   284	                actor,
   285	                APPRAISAL_CREATE_PERMISSION,
   286	                "You do not have permission to read appraisal notes.",
   287	                permissions,
   288	            )
   289	        application = (
   290	            LoanApplication.objects.select_related("created_by_user", "received_by_user")
   291	            .filter(loan_application_id=application_id)
   292	            .first()
   293	        )
   294	        if application is None:
   295	            raise CreditModuleNotFound("Loan application was not found.")
   296	        require_application_access(application, actor, permission, permissions)
   297	        note = (
   298	            LoanAppraisalNote.objects.select_related(
   299	                "risk_assessment",
   300	                "prepared_by_user",
   301	                "reviewed_by_user",
   302	            )
   303	            .filter(loan_application=application)
   304	            .first()
   305	        )
   306	        if note is None:
   307	            raise CreditModuleNotFound("Appraisal note was not found.")
   308	        return AppraisalNoteResult(snapshot=appraisal_note_snapshot(note))
