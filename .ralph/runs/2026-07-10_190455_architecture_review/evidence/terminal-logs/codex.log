   689	    @staticmethod
   690	    def _imports_from_module(tree, module_name):
   691	        imported_members = {
   692	            (alias.name, alias.asname)
   693	            for node in ast.walk(tree)
   694	            if isinstance(node, ast.ImportFrom) and node.module == module_name
   695	            for alias in node.names
   696	        }
   697	        imported_modules = {
   698	            (alias.name, alias.asname)
   699	            for node in ast.walk(tree)
   700	            if isinstance(node, ast.Import)
   701	            for alias in node.names
   702	            if alias.name == module_name
   703	        }
   704	        return imported_members | imported_modules
