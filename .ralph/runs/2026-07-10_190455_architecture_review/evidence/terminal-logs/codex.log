   901	    def test_competing_valid_reruns_serialize_complete_snapshots_and_evidence(self):
   902	        from sfpcl_credit.credit.modules.loan_limit_calculator import LoanLimitCalculator
   903	
   904	        calculator, first_shareholding, _policy = self._calculator_fixture()
   905	        initial = calculator.calculate_for_application(
   906	            actor=self.actor,
   907	            application_id=self.application.loan_application_id,
   908	            payload=self._loan_limit_payload(first_shareholding),
   909	            request_meta={"request_id": "concurrency-initial"},
   910	        ).snapshot
   911	        second_shareholding = self._shareholding(
   912	            folio_number="FOL-CREDIT-MODULE-SECOND",
   913	            number_of_shares=250,
   914	            available_share_count=250,
   915	        )
   916	        initial_audit_count = AuditLog.objects.filter(
   917	            action="loan_limit.calculated"
   918	        ).count()
   919	        initial_workflow_count = WorkflowEvent.objects.filter(
   920	            workflow_name="loan_limit_assessment"
   921	        ).count()
   922	        first_locked = Barrier(2)
   923	        second_attempting = Barrier(2)
   924	        release_first = Event()
   925	        second_payload_entered = Event()
   926	        ordering = []
   927	        ordering_lock = Lock()
   928	
   929	        def record(step):
   930	            with ordering_lock:
   931	                ordering.append(step)
   932	
   933	        def first_payload():
   934	            record("first_locked_application")
   935	            first_locked.wait(timeout=10)
   936	            if not release_first.wait(timeout=10):
   937	                raise AssertionError("Timed out waiting to release the first calculation.")
   938	            record("first_released")
   939	            return self._loan_limit_payload(first_shareholding)
   940	
   941	        def second_payload():
   942	            record("second_locked_application")
   943	            second_payload_entered.set()
   944	            return self._loan_limit_payload(second_shareholding)
   945	
   946	        def calculate(payload, request_id, attempted_barrier=None):
   947	            close_old_connections()
   948	            try:
   949	                actor = User.objects.get(user_id=self.actor.user_id)
   950	                if attempted_barrier is not None:
   951	                    record("second_attempting_application_lock")
   952	                    attempted_barrier.wait(timeout=10)
   953	                return LoanLimitCalculator().calculate_for_application(
   954	                    actor=actor,
   955	                    application_id=self.application.loan_application_id,
   956	                    payload=payload,
   957	                    request_meta={"request_id": request_id},
   958	                ).snapshot
   959	            finally:
   960	                connections["default"].close()
   961	
   962	        with ThreadPoolExecutor(max_workers=2) as executor:
   963	            first_future = executor.submit(
   964	                calculate,
   965	                first_payload,
   966	                "concurrency-first",
   967	            )
   968	            first_locked.wait(timeout=10)
   969	            second_future = executor.submit(
   970	                calculate,
   971	                second_payload,
   972	                "concurrency-second",
   973	                second_attempting,
   974	            )
   975	            second_attempting.wait(timeout=10)
   976	            try:
   977	                self.assertFalse(
   978	                    second_payload_entered.wait(timeout=0.5),
   979	                    "The second calculation reached its payload before the first committed.",
   980	                )
   981	            finally:
   982	                release_first.set()
   983	            first = first_future.result(timeout=10)
   984	            second = second_future.result(timeout=10)
   985	
   986	        assessment = LoanLimitAssessment.objects.get(
   987	            loan_application=self.application
   988	        )
   989	        final = calculator.get_assessment(
   990	            actor=self.actor,
   991	            application_id=self.application.loan_application_id,
   992	        ).snapshot
   993	        self.assertEqual(LoanLimitAssessment.objects.count(), 1)
   994	        self.assertEqual(
   995	            str(assessment.loan_limit_assessment_id),
   996	            initial["loan_limit_assessment_id"],
   997	        )
   998	        self.assertEqual(first["shareholding_id"], str(first_shareholding.shareholding_id))
   999	        self.assertEqual(first["number_of_shares"], 100)
  1000	        self.assertEqual(first["shareholding_based_limit_amount"], "20000.00")
  1001	        self.assertEqual(second["shareholding_id"], str(second_shareholding.shareholding_id))
  1002	        self.assertEqual(second["number_of_shares"], 250)
  1003	        self.assertEqual(second["shareholding_based_limit_amount"], "50000.00")
  1004	        self.assertEqual(final, second)
  1005	        self.assertEqual(
  1006	            AuditLog.objects.filter(action="loan_limit.calculated").count(),
  1007	            initial_audit_count + 2,
  1008	        )
  1009	        self.assertEqual(
  1010	            WorkflowEvent.objects.filter(workflow_name="loan_limit_assessment").count(),
  1011	            initial_workflow_count + 2,
  1012	        )
  1013	        final_audit = AuditLog.objects.filter(
  1014	            action="loan_limit.calculated",
  1015	            entity_id=assessment.loan_limit_assessment_id,
  1016	        ).latest("created_at")
  1017	        audit_projection = dict(final_audit.new_value_json)
  1018	        self.assertEqual(audit_projection.pop("request_id"), "concurrency-second")
  1019	        final_projection = dict(final)
  1020	        final_projection.pop("warnings")
  1021	        self.assertEqual(audit_projection, final_projection)
  1022	        self.assertEqual(
  1023	            ordering,
  1024	            [
  1025	                "first_locked_application",
  1026	                "second_attempting_application_lock",
  1027	                "first_released",
  1028	                "second_locked_application",
  1029	            ],
  1030	        )
  1031	        print(f"database_backend={connection.vendor} ordering={' -> '.join(ordering)}")
