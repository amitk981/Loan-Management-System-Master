   746	def _submission_errors(note):
   747	    errors = {}
   748	    for field in (
   749	        "borrower_summary",
   750	        "eligibility_summary",
   751	        "loan_limit_summary",
   752	        "recommended_security_summary",
   753	        "repayment_capacity_notes",
   754	    ):
   755	        if not getattr(note, field).strip():
   756	            errors[field] = "This field must not be blank."
   757	    if note.recommended_amount <= 0:
   758	        errors["recommended_amount"] = "Must be greater than zero."
   759	    if note.recommended_tenure_months is not None and note.recommended_tenure_months <= 0:
   760	        errors["recommended_tenure_months"] = "Must be a positive integer."
   761	    if note.recommended_interest_type and note.recommended_interest_type != "floating":
   762	        errors["recommended_interest_type"] = "Must be floating when supplied."
   763	    if note.recommendation not in {"approve", "reject", "conditions"}:
   764	        errors["recommendation"] = "Must be approve, reject, or conditions."
   765	    for field in (
   766	        "market_risk_rating",
   767	        "operational_risk_rating",
   768	        "borrower_risk_rating",
   769	        "overall_risk_rating",
   770	    ):
   771	        if getattr(note.risk_assessment, field) not in {"low", "medium", "high"}:
   772	            errors[f"risk_assessment.{field}"] = "Must be low, medium, or high."
   773	    return errors
