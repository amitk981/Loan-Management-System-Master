   706	    @classmethod
   707	    def _credit_boundary_violations(cls, source):
   708	        references = cls._resolved_import_references(ast.parse(source))
   709	        violations = set()
   710	        concrete_assessments = {
   711	            "sfpcl_credit.credit.models.EligibilityAssessment",
   712	            "sfpcl_credit.credit.models.LoanLimitAssessment",
   713	        }
   714	        if references & concrete_assessments:
   715	            violations.add("direct credit assessment model access")
   716	        if "sfpcl_credit.configurations.models.LoanPolicyConfig" in references:
   717	            violations.add("direct loan policy model access")
   718	        if any(
   719	            reference.startswith(
   720	                "sfpcl_credit.credit.modules.loan_limit_calculator._"
   721	            )
   722	            for reference in references
   723	        ):
   724	            violations.add("private loan-limit module access")
   725	        return violations
   726	
   727	    @classmethod
   728	    def _missing_required_imports(cls, source, required):
   729	        references = cls._resolved_import_references(ast.parse(source))
   730	        return set(required) - references
   731	
   732	    @staticmethod
   733	    def _resolved_import_references(tree):
   734	        aliases = {}
   735	        imported = set()
   736	        for node in ast.walk(tree):
   737	            if isinstance(node, ast.Import):
   738	                for alias in node.names:
   739	                    local_name = alias.asname or alias.name.split(".")[0]
   740	                    target = alias.name if alias.asname else local_name
   741	                    aliases[local_name] = target
   742	                    imported.add(alias.name)
   743	            elif isinstance(node, ast.ImportFrom):
   744	                module = node.module or ""
   745	                for alias in node.names:
   746	                    target = f"{module}.{alias.name}" if module else alias.name
   747	                    aliases[alias.asname or alias.name] = target
   748	                    imported.add(target)
   749	
   750	        references = set(imported)
   751	        for node in ast.walk(tree):
   752	            parts = []
   753	            current = node
   754	            while isinstance(current, ast.Attribute):
   755	                parts.append(current.attr)
   756	                current = current.value
   757	            if isinstance(current, ast.Name) and current.id in aliases:
   758	                references.add(
   759	                    ".".join([aliases[current.id], *reversed(parts)])
   760	                )
   761	        return references
