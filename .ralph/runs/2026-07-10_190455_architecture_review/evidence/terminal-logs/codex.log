   776	def _clean_payload(payload, *, partial):
   777	    payload = dict(payload)
   778	    allowed = {
   779	        "borrower_summary",
   780	        "eligibility_summary",
   781	        "loan_limit_summary",
   782	        "recommended_amount",
   783	        "recommended_tenure_months",
   784	        "recommended_interest_type",
   785	        "recommended_security_summary",
   786	        "repayment_capacity_notes",
   787	        "risk_assessment",
   788	        "recommendation",
   789	    }
   790	    unknown = sorted(set(payload) - allowed)
   791	    if unknown:
   792	        raise CreditModuleValidationError(
   793	            {field: "Unknown field." for field in unknown}
   794	        )
   795	    required_summaries = {
   796	        "borrower_summary",
   797	        "eligibility_summary",
   798	        "loan_limit_summary",
   799	        "recommended_security_summary",
   800	        "repayment_capacity_notes",
   801	    }
   802	    errors = {}
   803	    for field in required_summaries:
   804	        if field not in payload:
   805	            if not partial:
   806	                errors[field] = "This field is required."
   807	        elif not isinstance(payload[field], str) or not payload[field].strip():
   808	            errors[field] = "This field must not be blank."
   809	    if "recommendation" not in payload:
   810	        if not partial:
   811	            errors["recommendation"] = "This field is required."
   812	    elif payload["recommendation"] not in {"approve", "reject", "conditions"}:
   813	        errors["recommendation"] = "Must be approve, reject, or conditions."
   814	    if "recommended_amount" not in payload:
   815	        if not partial:
   816	            errors["recommended_amount"] = "This field is required."
   817	    else:
   818	        try:
   819	            amount = Decimal(str(payload["recommended_amount"]))
   820	        except (InvalidOperation, TypeError, ValueError):
   821	            errors["recommended_amount"] = "Must be a valid amount."
   822	        else:
   823	            if not amount.is_finite() or amount <= 0:
   824	                errors["recommended_amount"] = "Must be greater than zero."
   825	            else:
   826	                payload["recommended_amount"] = amount
   827	    if "recommended_tenure_months" in payload:
   828	        tenure = payload["recommended_tenure_months"]
   829	        if isinstance(tenure, bool) or not isinstance(tenure, int) or tenure <= 0:
   830	            errors["recommended_tenure_months"] = "Must be a positive integer."
   831	    if "recommended_interest_type" in payload and payload["recommended_interest_type"] != "floating":
   832	        errors["recommended_interest_type"] = "Must be floating when supplied."
   833	    if "risk_assessment" not in payload:
   834	        if not partial:
   835	            errors["risk_assessment"] = "This field is required."
   836	    elif not isinstance(payload["risk_assessment"], dict):
   837	        errors["risk_assessment"] = "Must be an object."
   838	    else:
   839	        risk = payload["risk_assessment"]
   840	        allowed_risk = {
   841	            "market_risk_rating",
   842	            "operational_risk_rating",
   843	            "borrower_risk_rating",
   844	            "overall_risk_rating",
   845	            "risk_mitigation_notes",
   846	        }
   847	        for field in sorted(set(risk) - allowed_risk):
   848	            errors[f"risk_assessment.{field}"] = "Unknown field."
   849	        for field in (
   850	            "market_risk_rating",
   851	            "operational_risk_rating",
   852	            "borrower_risk_rating",
   853	            "overall_risk_rating",
   854	        ):
   855	            if field not in risk:
   856	                if not partial:
   857	                    errors[f"risk_assessment.{field}"] = "This field is required."
   858	            elif risk[field] not in {"low", "medium", "high"}:
   859	                errors[f"risk_assessment.{field}"] = "Must be low, medium, or high."
   860	        if "risk_mitigation_notes" in risk and not isinstance(
   861	            risk["risk_mitigation_notes"], str
   862	        ):
   863	            errors["risk_assessment.risk_mitigation_notes"] = "Must be text."
   864	    if errors:
   865	        raise CreditModuleValidationError(errors)
   866	    return payload

