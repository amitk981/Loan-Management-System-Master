    52	class AppraisalWorkflow:
    53	    @transaction.atomic
    54	    def create_or_update(
    55	        self,
    56	        *,
    57	        actor,
    58	        application_id,
    59	        payload,
    60	        partial=False,
    61	        request_meta=None,
    62	        actor_permissions=None,
    63	    ):
    64	        permission = APPRAISAL_UPDATE_PERMISSION if partial else APPRAISAL_CREATE_PERMISSION
    65	        permissions = require_permission(
    66	            actor,
    67	            permission,
    68	            "You do not have permission to update appraisal notes."
    69	            if partial
    70	            else "You do not have permission to create appraisal notes.",
    71	            actor_permissions,
    72	        )
    73	        if not partial or "risk_assessment" in payload:
    74	            require_permission(
    75	                actor,
    76	                RISK_MANAGE_PERMISSION,
    77	                "You do not have permission to manage risk assessments.",
    78	                permissions,
    79	            )
    80	        application = (
    81	            LoanApplication.objects.select_for_update()
    82	            .select_related("created_by_user", "received_by_user")
    83	            .filter(loan_application_id=application_id)
    84	            .first()
    85	        )
    86	        if application is None:
    87	            raise CreditModuleNotFound("Loan application was not found.")
    88	        require_application_access(application, actor, permission, permissions)
    89	        payload = _clean_payload(payload, partial=partial)
    90	        current = (
    91	            LoanAppraisalNote.objects.select_for_update()
    92	            .select_related("risk_assessment", "prepared_by_user", "reviewed_by_user")
    93	            .filter(loan_application=application)
    94	            .first()
    95	        )
    96	        if partial:
    97	            loan_limit = current.loan_limit_snapshot_json if current is not None else {}
    98	        else:
    99	            projection_permissions = set(permissions) | {APPLICATION_READ_PERMISSION}
   100	            try:
   101	                eligibility = EligibilityAssessmentModule().get(
   102	                    actor=actor,
   103	                    application_id=application_id,
   104	                    actor_permissions=projection_permissions,
   105	                ).snapshot
   106	            except CreditModuleNotFound as exc:
   107	                raise CreditModuleInvalidStateError(
   108	                    "A stored eligible eligibility assessment is required before appraisal."
   109	                ) from exc
   110	            if eligibility["overall_result"] != "eligible":
   111	                raise CreditModuleInvalidStateError(
   112	                    "Appraisal creation requires eligibility overall_result eligible."
   113	                )
   114	            try:
   115	                loan_limit = LoanLimitCalculator().get_assessment(
   116	                    actor=actor,
   117	                    application_id=application_id,
   118	                    actor_permissions=projection_permissions,
   119	                ).snapshot
   120	            except CreditModuleNotFound as exc:
   121	                raise CreditModuleInvalidStateError(
   122	                    "A stored loan-limit assessment is required before appraisal."
   123	                ) from exc
   124	        if (
   125	            "recommended_amount" in payload
   126	            and loan_limit
   127	            and payload["recommended_amount"]
   128	            > Decimal(loan_limit["final_eligible_loan_amount"])
   129	            and not loan_limit["exception_required_flag"]
   130	        ):
   131	            raise CreditModuleValidationError(
   132	                {
   133	                    "recommended_amount": (
   134	                        "Cannot exceed the frozen final eligible amount unless the frozen "
   135	                        "loan-limit projection already requires an exception."
   136	                    )
   137	                }
   138	            )
   139	        if partial:
   140	            if current is None:
   141	                raise CreditModuleNotFound("Appraisal note was not found.")
   142	            if current.appraisal_status != LoanAppraisalNote.STATUS_DRAFT:
   143	                raise CreditModuleInvalidStateError("Only draft appraisal notes can be updated.")
   144	            changed_fields = []
   145	            for field in (
   146	                "borrower_summary",
   147	                "eligibility_summary",
   148	                "loan_limit_summary",
   149	                "recommended_amount",
   150	                "recommended_tenure_months",
   151	                "recommended_interest_type",
   152	                "recommended_security_summary",
   153	                "repayment_capacity_notes",
   154	                "recommendation",
   155	            ):
   156	                if field in payload:
   157	                    value = payload[field]
   158	                    if field == "recommended_amount":
   159	                        value = Decimal(str(value))
   160	                    setattr(current, field, value)
   161	                    changed_fields.append(field)
   162	            risk_payload = payload.get("risk_assessment", {})
   163	            for field in (
   164	                "market_risk_rating",
   165	                "operational_risk_rating",
   166	                "borrower_risk_rating",
   167	                "overall_risk_rating",
   168	                "risk_mitigation_notes",
   169	            ):
   170	                if field in risk_payload:
   171	                    setattr(current.risk_assessment, field, risk_payload[field])
   172	                    changed_fields.append(f"risk_assessment.{field}")
   173	            if risk_payload:
   174	                current.risk_assessment.assessed_by_user = actor
   175	                current.risk_assessment.assessed_at = timezone.now()
   176	                current.risk_assessment.save()
   177	            current.save()
   178	            request_meta = normalize_request_meta(request_meta)
   179	            AuditLog.objects.create(
   180	                actor_user=actor,
   181	                action="appraisal.updated",
   182	                entity_type="loan_appraisal_note",
   183	                entity_id=current.pk,
   184	                old_value_json={"appraisal_status": current.appraisal_status},
   185	                new_value_json={
   186	                    "appraisal_status": current.appraisal_status,
   187	                    "changed_fields": sorted(changed_fields),
   188	                    "request_id": request_meta.request_id,
   189	                },
   190	                ip_address=request_meta.ip_address,
   191	                user_agent=request_meta.user_agent,
   192	            )
   193	            record_workflow_event(
   194	                actor=actor,
   195	                workflow_name="appraisal_note",
   196	                entity_type="loan_appraisal_note",
   197	                entity_id=current.pk,
   198	                from_state=current.appraisal_status,
   199	                to_state=current.appraisal_status,
   200	                trigger_reason="Appraisal note draft updated.",
   201	                action_code="appraisal.updated",
   202	            )
   203	            return AppraisalNoteResult(snapshot=appraisal_note_snapshot(current))
   204	        if current is not None:
   205	            raise CreditModuleInvalidStateError(
   206	                "An appraisal note already exists for this loan application."
   207	            )
   208	
   209	        now = timezone.now()
   210	        risk_payload = payload["risk_assessment"]
   211	        risk = RiskAssessment.objects.create(
   212	            loan_application=application,
   213	            market_risk_rating=risk_payload["market_risk_rating"],
   214	            operational_risk_rating=risk_payload["operational_risk_rating"],
   215	            borrower_risk_rating=risk_payload["borrower_risk_rating"],
   216	            overall_risk_rating=risk_payload["overall_risk_rating"],
   217	            risk_mitigation_notes=risk_payload.get("risk_mitigation_notes", ""),
   218	            assessed_by_user=actor,
   219	            assessed_at=now,
   220	        )
   221	        due_at = application.created_at + timedelta(days=2)
   222	        note = LoanAppraisalNote.objects.create(
   223	            loan_application=application,
   224	            prepared_by_user=actor,
   225	            prepared_at=now,
   226	            tat_due_at=due_at,
   227	            tat_status=_tat_status(now, due_at),
   228	            eligibility_assessment_id_snapshot=eligibility["eligibility_assessment_id"],
   229	            loan_limit_assessment_id_snapshot=loan_limit["loan_limit_assessment_id"],
   230	            eligibility_snapshot_json=eligibility,
   231	            loan_limit_snapshot_json=loan_limit,
   232	            prerequisite_provenance="verified",
   233	            borrower_summary=payload["borrower_summary"],
   234	            eligibility_summary=payload["eligibility_summary"],
   235	            loan_limit_summary=payload["loan_limit_summary"],
   236	            recommended_amount=payload["recommended_amount"],
   237	            recommended_tenure_months=payload.get("recommended_tenure_months"),
   238	            recommended_interest_type=payload.get("recommended_interest_type", ""),
   239	            recommended_security_summary=payload["recommended_security_summary"],
   240	            repayment_capacity_notes=payload["repayment_capacity_notes"],
   241	            risk_assessment=risk,
   242	            recommendation=payload["recommendation"],
   243	            appraisal_status=LoanAppraisalNote.STATUS_DRAFT,
   244	        )
   245	        request_meta = normalize_request_meta(request_meta)
   246	        AuditLog.objects.create(
   247	            actor_user=actor,
   248	            action="appraisal.created",
   249	            entity_type="loan_appraisal_note",
   250	            entity_id=note.loan_appraisal_note_id,
   251	            old_value_json=None,
   252	            new_value_json={
   253	                "loan_appraisal_note_id": str(note.pk),
   254	                "loan_application_id": str(application.pk),
   255	                "risk_assessment_id": str(risk.pk),
   256	                "eligibility_assessment_id": str(note.eligibility_assessment_id_snapshot),
   257	                "loan_limit_assessment_id": str(note.loan_limit_assessment_id_snapshot),
   258	                "appraisal_status": note.appraisal_status,
   259	                "request_id": request_meta.request_id,
   260	            },
   261	            ip_address=request_meta.ip_address,
   262	            user_agent=request_meta.user_agent,
   263	        )
   264	        record_workflow_event(
   265	            actor=actor,
   266	            workflow_name="appraisal_note",
   267	            entity_type="loan_appraisal_note",
   268	            entity_id=note.pk,
   269	            from_state="not_started",
   270	            to_state=note.appraisal_status,
   271	            trigger_reason="Appraisal note draft created.",
   272	            action_code="appraisal.created",
   273	        )
   274	        return AppraisalNoteResult(snapshot=appraisal_note_snapshot(note))
