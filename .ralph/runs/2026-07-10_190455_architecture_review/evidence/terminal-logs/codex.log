   310	    @transaction.atomic
   311	    def submit_for_review(
   312	        self,
   313	        *,
   314	        actor,
   315	        appraisal_id,
   316	        payload,
   317	        request_meta=None,
   318	        actor_permissions=None,
   319	    ):
   320	        permissions = require_permission(
   321	            actor,
   322	            APPRAISAL_SUBMIT_PERMISSION,
   323	            "You do not have permission to submit appraisal notes for review.",
   324	            actor_permissions,
   325	        )
   326	        unknown = sorted(set(payload) - {"remarks"})
   327	        errors = {field: "Unknown field." for field in unknown}
   328	        if not isinstance(payload.get("remarks"), str) or not payload["remarks"].strip():
   329	            errors["remarks"] = "This field must not be blank."
   330	        if errors:
   331	            raise CreditModuleValidationError(errors)
   332	        note = (
   333	            LoanAppraisalNote.objects.select_for_update()
   334	            .select_related(
   335	                "loan_application__created_by_user",
   336	                "loan_application__received_by_user",
   337	                "risk_assessment",
   338	                "prepared_by_user",
   339	                "reviewed_by_user",
   340	            )
   341	            .filter(loan_appraisal_note_id=appraisal_id)
   342	            .first()
   343	        )
   344	        if note is None:
   345	            raise CreditModuleNotFound("Appraisal note was not found.")
   346	        require_application_access(
   347	            note.loan_application,
   348	            actor,
   349	            APPRAISAL_SUBMIT_PERMISSION,
   350	            permissions,
   351	        )
   352	        if note.appraisal_status != LoanAppraisalNote.STATUS_DRAFT:
   353	            raise CreditModuleInvalidStateError(
   354	                "Only a draft appraisal note can be submitted for review."
   355	            )
   356	        if note.prerequisite_provenance != "verified":
   357	            raise CreditModuleInvalidStateError(
   358	                "Appraisal prerequisites must be explicitly revalidated before review."
   359	            )
   360	        submission_errors = _submission_errors(note)
   361	        if submission_errors:
   362	            raise CreditModuleValidationError(submission_errors)
   363	        now = timezone.now()
   364	        note.appraisal_status = LoanAppraisalNote.STATUS_REVIEW_PENDING
   365	        note.tat_status = _tat_status(now, note.tat_due_at)
   366	        note.submission_remarks = payload["remarks"].strip()
   367	        note.save(
   368	            update_fields=["appraisal_status", "tat_status", "submission_remarks"]
   369	        )
   370	        request_meta = normalize_request_meta(request_meta)
   371	        AuditLog.objects.create(
   372	            actor_user=actor,
   373	            action="appraisal.submitted_for_review",
   374	            entity_type="loan_appraisal_note",
   375	            entity_id=note.pk,
   376	            old_value_json={"appraisal_status": LoanAppraisalNote.STATUS_DRAFT},
   377	            new_value_json={
   378	                "appraisal_status": note.appraisal_status,
   379	                "tat_status": note.tat_status,
   380	                "submission_reason_exists": True,
   381	                "submission_reason_owner_id": str(note.pk),
   382	                "request_id": request_meta.request_id,
   383	            },
   384	            ip_address=request_meta.ip_address,
   385	            user_agent=request_meta.user_agent,
   386	        )
   387	        record_workflow_event(
   388	            actor=actor,
   389	            workflow_name="appraisal_note",
   390	            entity_type="loan_appraisal_note",
   391	            entity_id=note.pk,
   392	            from_state=LoanAppraisalNote.STATUS_DRAFT,
   393	            to_state=note.appraisal_status,
   394	            trigger_reason="Appraisal note submitted for Credit Manager review.",
   395	            action_code="appraisal.submitted_for_review",
   396	        )
   397	        return AppraisalNoteResult(snapshot=appraisal_note_snapshot(note))
