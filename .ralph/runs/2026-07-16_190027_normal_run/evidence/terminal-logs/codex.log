+import uuid
+
+from django.db import models
+from django.db.models.functions import Lower, Trim
+from django.utils import timezone
+
+
+class SapCustomerProfileRequest(models.Model):
+    STATUS_DRAFT = "draft"
+    STATUS_SENT = "sent"
+    STATUS_COMPLETED = "completed"
