+        WorkflowEvent = apps.get_model("workflows", "WorkflowEvent")
+
+        role = Role.objects.create(
+            role_code="sap_migration_owner",
+            role_name="SAP Migration Owner",
+        )
+        requester = User.objects.create(
+            full_name="Migration Requester",
