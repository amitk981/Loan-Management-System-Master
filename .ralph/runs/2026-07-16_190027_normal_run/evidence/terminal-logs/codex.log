+                    )
+                    | models.Q(
+                        request_status="sent", sent_at__isnull=False,
+                        sent_communication__isnull=False, sent_task__isnull=False,
+                        completed_at__isnull=True, sap_customer_code__isnull=True,
+                        completion_reused_existing_code__isnull=True,
+                    )
+                    | models.Q(
