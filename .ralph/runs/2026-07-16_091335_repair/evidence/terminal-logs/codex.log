+            if item["item_code"] == "poa"
+        )
+        self.assertEqual(
+            {action["label"] for action in power_of_attorney["available_actions"]},
+            {
+                "Record borrower signature",
+                "Record nominee signature",
+                "Record stamp",
+                "Record notarisation",
+                "Upload / re-upload signed copy",
+                "Request correction",
+            },
+        )

