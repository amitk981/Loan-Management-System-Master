+fs.mkdirSync(evidenceDir, { recursive: true });
+
+test('distinct finance roles drive one appraisal to one pending sanction case', async ({ page }) => {
+  let role: 'deputy_manager_finance' | 'credit_manager' = 'deputy_manager_finance';
+  let status = 'draft';
