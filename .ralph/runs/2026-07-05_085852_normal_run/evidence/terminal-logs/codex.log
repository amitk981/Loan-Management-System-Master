+
+    operations = [
+        migrations.CreateModel(
+            name="DocumentFile",
+            fields=[
+                (
+                    "document_id",
+                    models.UUIDField(
+                        default=uuid.uuid4,
+                        editable=False,
+                        primary_key=True,
+                        serialize=False,
+                    ),
+                ),
+                ("file_name", models.CharField(max_length=255)),
+                ("file_extension", models.CharField(blank=True, max_length=20, null=True)),
