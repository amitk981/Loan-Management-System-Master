+
+
+class MemberRegistry:
+    APPROVE_PERMISSION = "members.member.identity_change.approve"
+
+    @classmethod
+    @transaction.atomic
+    def request_identity_change(cls, member_id, payload, actor_user):
+        if not services.user_can_update_members(actor_user):
