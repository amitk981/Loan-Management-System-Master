 def create_member(payload, actor_user, request_ip_value="", request_user_agent_value=""):
     allowed = {
@@ -126,6 +132,10 @@
         errors["aadhaar"] = "This field is required for an individual farmer."
     if aadhaar and not _AADHAAR_RE.fullmatch(aadhaar):
