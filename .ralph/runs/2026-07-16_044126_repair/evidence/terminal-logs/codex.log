agent:
  default_tool: codex
  allowed_tools:
    - codex
  # codex-only: on usage-limit exhaustion the loop stops cleanly (completed
  # slices are already committed) for a rerun after the limit resets. To
  # restore the codex<->claude switch, re-add claude above and set this true.
  limit_fallback: false

  codex:
    default_profile: default
    allow_model_override: true
    allow_effort_override: true
    allow_xhigh: false
    fail_if_model_unavailable: true
    record_settings_file: true
    approval_modes_allowed:
      - never
      - on-request
      - untrusted
    fallback:
      enabled: false
      order: []
      downgrade_effort_on_fallback: false
    profiles:
      default:
        model: gpt-5.5
        reasoning_effort: medium
        verbosity: medium
        allowed_modes:
          - normal_run
        intended_use: Normal one-slice AFK implementation.
      fast:
        model: gpt-5.5
        reasoning_effort: low
        verbosity: low
        allowed_modes:
          - preflight_only
          - docs_only
          - normal_run
        intended_use: Small docs edits, simple UI copy, and quick inspection.
      economy:
        model: gpt-5-codex-mini
        reasoning_effort: medium
        verbosity: low
        allowed_modes:
          - normal_run
        intended_use: Lower-cost runs if available on the user's plan.
      deep:
        model: gpt-5.5
        reasoning_effort: high
        verbosity: medium
        allowed_modes:
          - bootstrap
          - normal_run
          - repair
          - architecture_review
        intended_use: Complex slices, API/database work, and difficult bugs.
      repair:
        model: gpt-5.5
        reasoning_effort: high
        verbosity: medium
        allowed_modes:
          - repair
        intended_use: Diagnose failed runs and repeated gate failures.
      architecture:
        model: gpt-5.5
        reasoning_effort: high
        verbosity: high
        allowed_modes:
          - architecture_review
        intended_use: Architecture review, ADRs, and refactor-slice planning.

run:
  default_iterations: 1
  max_iterations: 3
  # A repeated unchanged failure receives at most this many repair attempts.
  max_retries: 2
  # When validation progresses to a different failure signature, keep repairing
  # the same quarantined worktree up to this overall safety ceiling.
  max_progressive_repairs: 5
  require_clean_git: true
  use_worktree: true
  allow_no_worktree_override: false
  stop_on_ambiguity: false  # ambiguity handled by docs/working/DECISION_POLICY.md, not by stopping
  stop_on_high_risk: false  # standing approval + veto model; see docs/working/HIGH_RISK_APPROVALS.md
  auto_commit: true
  auto_merge: true
  auto_push: true
  push_remote: github-master
  # Agents integrate ONLY into this branch; the owner alone promotes staging -> main
  # (see docs/working/RELEASE_PROMOTION.md). ralph-run.sh refuses to run on any other branch.
  integration_branch: staging
  agent_timeout_seconds: 7200  # watchdog: a hung agent fails into the repair path
  environment_setup_timeout_seconds: 900  # dependency preparation is non-interactive and bounded
  validation_timeout_seconds: 3600  # watchdog: gates are unattended and must never wait forever
  auto_deploy: false
  architecture_review_every_completed_slices: 4

limits:
  # Enforced by ralph-validate.sh (excluding .ralph/ bookkeeping). Sized so a
  # legitimate vertical slice (models+views+tests+migrations+docs) fits, while
  # a runaway broad rewrite fails.
  max_changed_files: 30
  max_lines_changed: 2000
  max_new_dependencies: 4
  max_database_migrations: 1

quality_gates:
  install: false
  build: true
  typecheck: true
  lint: true  # enabled 2026-07-04 after 002FL landed the ESLint baseline (owner action)
  unit_tests: true
  integration_tests: false
  e2e_tests: optional
  backend_check: true
  # backend_tests disabled 2026-07-10 (owner action): backend_coverage runs the
  # identical full suite under `coverage run` and fails on any test failure, so
  # the plain run was a pure duplicate costing ~4 min per slice. Same tests,
  # same failure semantics, same coverage floor — re-enable if coverage is off.
  backend_tests: false
  backend_migrations: true
  backend_coverage: true
  coverage_fail_under: 85

risk:
  low_risk_auto_commit: true
  medium_risk_auto_commit: true
  high_risk_auto_commit: true  # standing approval + veto model; protected paths + gates are the controls
  high_risk_stop_required: false

worktree:
  enabled: true
  path: .ralph/worktrees
  cleanup_idle: true

commands:
  project_dir: sfpcl-lms
  backend_dir: sfpcl_credit
  # Base interpreter for the orchestrator-managed venv at .ralph/venv (agents have no
  # network and must never pip install; the orchestrator installs pinned requirements).
  backend_python: /usr/local/bin/python3.11
  package_manager: auto
  install: auto
  build: auto
  typecheck: auto
  lint: auto
  test: auto
  integration_test: auto
  e2e_test: auto

docs:
  source_readonly: true
  update_handoff: true
  update_progress: true
  update_state: true
  update_assumptions: true

