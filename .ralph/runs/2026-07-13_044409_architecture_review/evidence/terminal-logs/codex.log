    43	        raise InvalidApprovalFacts("Decision type and decision date are required.")
    44	    try:
    45	        amount = Decimal(amount)
    46	    except (InvalidOperation, TypeError, ValueError) as exc:
    47	        raise InvalidApprovalFacts("Amount must be a finite decimal.") from exc
    48	    if not amount.is_finite() or amount < 0:
    49	        raise InvalidApprovalFacts("Amount must be a finite non-negative decimal.")
    50	    condition_code = condition_code or None
    51	    matches = list(
    52	        ApprovalMatrixRule.objects.filter(
    53	            decision_type=decision_type.strip(),
    54	            condition_code=condition_code,
    55	            effective_from__lte=decision_date,
    56	        )
    57	        .filter(Q(effective_to__isnull=True) | Q(effective_to__gte=decision_date))
