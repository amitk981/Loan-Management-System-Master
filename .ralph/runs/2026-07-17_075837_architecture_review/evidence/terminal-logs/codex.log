   250	def _locked_maker(actor):
   251	    maker = (
   252	        User.objects.select_for_update()
   253	        .select_related("primary_role")
   254	        .filter(pk=getattr(actor, "pk", None), status=User.ACTIVE_STATUS)
   255	        .first()
   256	    )
   257	    permissions = set(auth_service.effective_permission_codes(maker)) if maker else set()
   258	    permission = Permission.objects.filter(permission_code=INITIATE_PERMISSION).first()
   259	    if (
   260	        maker is None
   261	        or not maker.can_authenticate()
   262	        or maker.primary_role.status != "active"
   263	        or maker.primary_role.role_code != "senior_manager_finance"
   264	        or INITIATE_PERMISSION not in permissions
   265	        or permission is None
   266	        or permission.risk_level != Permission.RISK_CRITICAL
   267	    ):
   268	        raise DomainPermissionDenied(
   269	            "Active Senior Manager Finance initiation authority is required."
   270	        )
   271	    return maker
