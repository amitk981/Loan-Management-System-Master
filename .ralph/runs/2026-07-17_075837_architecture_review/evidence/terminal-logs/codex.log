    40	def _execute_with_translation(callback, values, uploaded_file, request):
    41	    try:
    42	        return callback(values, uploaded_file, request)
    43	    except ValidationError:
    44	        raise
    45	    except checklist_actions.AccessDenied as exc:
    46	        raise OwnerAccessDenied(exc.error_code) from exc
    47	    except checklist_actions.NotFound as exc:
    48	        raise OwnerNotFound from exc
    49	    except checklist_actions.Conflict as exc:
    50	        raise OwnerConflict(str(exc), exc.error_code) from exc
    51	    except documentation_actions.AccessDenied as exc:
    52	        raise OwnerAccessDenied from exc
    53	    except documentation_actions.NotFound as exc:
    54	        raise OwnerNotFound from exc
    55	    except documentation_actions.Conflict as exc:
    56	        raise OwnerConflict(str(exc)) from exc
    57	    except (document_generation.LegalDocumentAccessDenied, loan_document_verification.AccessDenied, signatures.AccessDenied, stamp_notary.AccessDenied) as exc:
    58	        raise OwnerAccessDenied from exc
    59	    except (document_generation.LegalDocumentNotFound, loan_document_verification.NotFound, signatures.NotFound, stamp_notary.NotFound) as exc:
    60	        raise OwnerNotFound from exc
    61	    except (document_generation.RendererProvenanceConflict, loan_document_verification.Conflict, signatures.InvalidState, signatures.ProjectionConflict, signatures.EvidenceConflict, stamp_notary.ProjectionConflict) as exc:
    62	        raise OwnerConflict(str(exc)) from exc
