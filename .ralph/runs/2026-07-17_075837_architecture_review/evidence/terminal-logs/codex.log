    75	def _owner_allows(authorizer, actor):
    76	    try:
    77	        authorizer(actor)
    78	    except (checklist_actions.AccessDenied, document_generation.LegalDocumentAccessDenied, loan_document_verification.AccessDenied, signatures.AccessDenied, stamp_notary.AccessDenied):
    79	        return False
