    82	def _item_authorising_role(actor):
    83	    allowed = {'compliance_team_member', 'company_secretary'}
    84	    effective = set(auth_service.effective_role_codes(actor))
    85	    governed = (actor.approval_authority_type or '').strip()
    86	    if governed in allowed and governed in effective:
    87	        return governed
    88	    if actor.primary_role.role_code in allowed and actor.primary_role.role_code in effective:
    89	        return actor.primary_role.role_code
    90	    return None
