   274	def _require_current_readiness(readiness, loan_account_id):
   275	    expected_codes = [spec.code for spec in CHECK_SPECS]
   276	    checks = readiness.get("checks") if isinstance(readiness, dict) else None
   277	    if not isinstance(checks, list):
   278	        raise DisbursementReadinessStale("Current readiness evidence is unavailable.")
   279	    canonical = [
   280	        {"code": item.get("code"), "status": item.get("status")}
   281	        for item in checks
   282	        if isinstance(item, dict)
   283	    ]
   284	    digest = _digest(canonical)
   285	    evidence = readiness.get("_evidence")
   286	    if (
   287	        str(readiness.get("loan_account_id")) != str(loan_account_id)
   288	        or readiness.get("ready_for_disbursement") is not True
   289	        or len(canonical) != len(checks)
   290	        or [item["code"] for item in canonical] != expected_codes
   291	        or any(item["status"] != "pass" for item in canonical)
   292	        or not isinstance(evidence, dict)
   293	        or set(evidence)
   294	        != {
   295	            "check_digest",
   296	            "sap_customer_code_id",
   297	            "sap_profile_request_id",
   298	            "borrower_bank_account_id",
   299	            "bank_verification_decision_id",
   300	            "source_bank_account_id",
   301	        }
   302	        or evidence.get("check_digest") != digest
   303	        or any(not evidence.get(key) for key in set(evidence) - {"check_digest"})
   304	    ):
   305	        raise DisbursementReadinessStale(
   306	            "All 23 exact current readiness checks must pass in canonical order."
   307	        )
   308	    return digest, evidence
