    64	def _action(action_code, label, required_permission, action_url, *, owner_execute, method='POST', required_role=None, fixed_payload=None, fields=None, **options):
    65	    result = {'action_code': action_code, 'label': label, 'enabled': True, 'disabled_reason': None, 'required_permission': required_permission, 'action_url': action_url, 'method': method, '_owner_execute': partial(_execute_with_translation, owner_execute)}
    66	    if required_role:
    67	        result['required_role'] = required_role
    68	    if fixed_payload:
    69	        result['fixed_payload'] = fixed_payload
    70	    if fields:
    71	        result['fields'] = fields
    72	    result.update(options)
    73	    return result
