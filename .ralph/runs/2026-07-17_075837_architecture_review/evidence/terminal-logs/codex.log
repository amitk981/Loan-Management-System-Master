  if ralph_slice_has_capability "$slice_file" "$RALPH_CAPABILITY_LOCALHOST_E2E_SERVER"; then
    localhost_e2e_required=1
  fi
fi

run_id="${run_id:-$(date '+%Y-%m-%d_%H%M%S')_validate}"
