    70	def resolve_source_bank_account(*, for_update=False):
    71	    """Resolve one verified active SFPCL-owned RBL account without plaintext."""
    72	    from sfpcl_credit.members.models import BankAccount
    73	
    74	    queryset = BankAccount.objects
    75	    if for_update:
    76	        queryset = queryset.select_for_update()
    77	    rows = list(
    78	        queryset.filter(
    79	            owner_party_type="sfpcl",
    80	            bank_name__iexact="RBL Bank",
    81	            verification_status="verified",
    82	            status="active",
    83	        ).order_by("bank_account_id")[:2]
    84	    )
    85	    if len(rows) != 1:
    86	        return None
    87	    return SourceBankAccountDecision(
    88	        source_bank_account_id=rows[0].pk,
