   202	def _validate_payload(payload, idempotency_key):
   203	    allowed = {
   204	        "disbursement_amount",
   205	        "borrower_bank_account_id",
   206	        "source_bank_account_id",
   207	        "final_verification_comments",
   208	    }
   209	    errors = {field: "Unknown field." for field in sorted(set(payload) - allowed)}
   210	    for field in allowed - set(payload):
   211	        errors[field] = "This field is required."
   212	    try:
   213	        amount = Decimal(str(payload.get("disbursement_amount", "")))
   214	        if not amount.is_finite() or amount.as_tuple().exponent < -2:
   215	            raise InvalidOperation
   216	    except (InvalidOperation, ValueError):
   217	        amount = None
   218	        errors["disbursement_amount"] = "Enter a positive amount with at most 2 decimals."
   219	    if amount is not None and (
   220	        amount <= 0 or amount >= Decimal("10000000000000000")
   221	    ):
   222	        errors["disbursement_amount"] = (
   223	            "Amount must be positive and fit the 18,2 money boundary."
   224	        )
   225	    parsed_ids = {}
   226	    for field in ("borrower_bank_account_id", "source_bank_account_id"):
   227	        try:
   228	            parsed_ids[field] = uuid.UUID(str(payload.get(field, "")))
   229	        except (ValueError, TypeError, AttributeError):
   230	            errors[field] = "Must be a valid UUID."
   231	    raw_comments = payload.get("final_verification_comments")
   232	    comments = raw_comments.strip() if isinstance(raw_comments, str) else ""
   233	    if not isinstance(raw_comments, str) or not comments:
   234	        errors["final_verification_comments"] = "This field is required."
   235	    elif len(comments) > 2000:
   236	        errors["final_verification_comments"] = "Must be at most 2000 characters."
   237	    key = idempotency_key.strip() if isinstance(idempotency_key, str) else ""
   238	    if not key or len(key) > 255:
   239	        errors["Idempotency-Key"] = "A valid Idempotency-Key header is required."
   240	    if errors:
   241	        raise ValidationError(errors)
   242	    return {
   243	        "disbursement_amount": amount.quantize(Decimal("0.01")),
   244	        **parsed_ids,
   245	        "final_verification_comments": comments,
   246	        "idempotency_key_digest": hashlib.sha256(key.encode()).hexdigest(),
   247	    }
