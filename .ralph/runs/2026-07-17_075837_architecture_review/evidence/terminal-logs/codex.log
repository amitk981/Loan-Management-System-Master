   139	def _canonical_signature_identity(application, party):
   140	    if party == 'borrower':
   141	        return (str(application.member_id), application.member.legal_name)
   142	    if party == 'nominee' and application.nominee_id:
   143	        return (str(application.nominee_id), application.nominee.nominee_name)
   144	    if party == 'witness':
   145	        witnesses = list(Witness.objects.filter(loan_application=application, verification_status='verified', shareholder_verified_flag=True).order_by('created_at', 'witness_id')[:2])
   146	        if len(witnesses) == 1:
   147	            return (str(witnesses[0].pk), witnesses[0].witness_name)
   148	    return None
