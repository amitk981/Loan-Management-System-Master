   333	def _require_bank_facts(*, account, cleaned, bank, source, readiness_evidence):
   334	    if (
   335	        not bank.valid
   336	        or bank.member_id != account.member_id
   337	        or bank.bank_account_id != cleaned["borrower_bank_account_id"]
   338	        or str(bank.bank_account_id)
   339	        != readiness_evidence["borrower_bank_account_id"]
   340	        or str(bank.bank_verification_decision_id)
   341	        != readiness_evidence["bank_verification_decision_id"]
   342	        or source is None
   343	        or not source.active
   344	        or source.source_bank_account_id != cleaned["source_bank_account_id"]
   345	        or str(source.source_bank_account_id)
   346	        != readiness_evidence["source_bank_account_id"]
   347	    ):
   348	        raise DisbursementReadinessStale(
   349	            "The verified beneficiary or governed source-bank evidence has changed."
   350	        )
