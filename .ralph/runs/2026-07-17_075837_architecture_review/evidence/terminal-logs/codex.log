    14	def resolve_effective_loan_policy(*, calculation_date, for_update=False):
    15	    queryset = LoanPolicyConfig.objects
    16	    if for_update:
    17	        queryset = queryset.select_for_update()
    18	    policies = list(
    19	        queryset.filter(
    20	            status=LoanPolicyConfig.STATUS_ACTIVE,
    21	            effective_from__lte=calculation_date,
    22	        )
    23	        .filter(Q(effective_to__isnull=True) | Q(effective_to__gte=calculation_date))
    24	        .order_by("-effective_from", "-loan_policy_config_id")[:2]
    25	    )
    26	    if len(policies) != 1:
    27	        raise ConfigurationResolutionError(
    28	            {
    29	                "loan_policy_config": (
    30	                    "Exactly one active loan policy must apply on calculation_date."
    31	                )
    32	            }
    33	        )
    34	    policy = policies[0]
    35	    if not policy.board_approval_reference:
    36	        raise ConfigurationResolutionError(
    37	            {
    38	                "loan_policy_config": (
    39	                    "Active loan-limit policy requires Board approval metadata."
    40	                )
    41	            }
    42	        )
    43	    if policy.default_scale_of_finance_per_acre_amount <= 0:
    44	        raise ConfigurationResolutionError(
    45	            {"loan_policy_config": "Scale of finance must be greater than zero."}
    46	        )
    47	    configured_rules = [
    48	        value
    49	        for value in (policy.share_limit_percentage, policy.per_share_cap_amount)
    50	        if value is not None
    51	    ]
    52	    if not configured_rules or any(value <= 0 for value in configured_rules):
    53	        raise ConfigurationResolutionError(
    54	            {
    55	                "loan_policy_config": (
    56	                    "Configure a positive share percentage or per-share cap before calculation."
    57	                )
    58	            }
    59	        )
    60	    return policy
