   495	class DisbursementInitiationRaceTests(TransactionTestCase):
   496	    reset_sequences = True
   497	
   498	    def setUp(self):
   499	        self.fixture = DisbursementInitiationApiTests(
   500	            "test_current_ready_payment_is_recorded_once_without_transfer_side_effects"
   501	        )
   502	        self.fixture.setUp()
   503	
   504	    def test_five_changed_initiations_retain_one_complete_winner_run_one(self):
   505	        self._run_five()
   506	
   507	    def test_five_changed_initiations_retain_one_complete_winner_run_two(self):
   508	        self._run_five()
   509	
   510	    def _run_five(self):
   511	        from sfpcl_credit.disbursements.models import Disbursement
   512	        from sfpcl_credit.disbursements.modules.disbursement_initiation import (
   513	            DisbursementConflict,
   514	            initiate,
   515	        )
   516	        from sfpcl_credit.identity.models import AuditLog, User
   517	        from sfpcl_credit.communications.models import Notification
   518	        from sfpcl_credit.workflows.models import WorkflowEvent
   519	
   520	        bank = SimpleNamespace(
   521	            valid=True,
   522	            member_id=self.fixture.application.member_id,
   523	            bank_account_id=self.fixture.borrower_bank_id,
   524	            cancelled_cheque_id=uuid4(),
   525	            bank_verification_decision_id=self.fixture.bank_decision_id,
   526	        )
   527	        source = SimpleNamespace(
   528	            source_bank_account_id=self.fixture.source_bank_id,
   529	            active=True,
   530	            bank_name="RBL Bank",
   531	        )
   532	        gate = Barrier(5)
   533	
   534	        def contender(index):
   535	            close_old_connections()
   536	            try:
   537	                actor = User.objects.get(pk=self.fixture.actor.pk)
   538	                gate.wait(timeout=15)
   539	                try:
   540	                    result = initiate(
   541	                        actor=actor,
   542	                        loan_account_id=self.fixture.account_id,
   543	                        payload={
   544	                            "disbursement_amount": "400000.00",
   545	                            "borrower_bank_account_id": str(
   546	                                self.fixture.borrower_bank_id
   547	                            ),
   548	                            "source_bank_account_id": str(self.fixture.source_bank_id),
   549	                            "final_verification_comments": f"Race contender {index}",
   550	                        },
   551	                        idempotency_key=f"race-initiation-{index}",
   552	                    )
   553	                    return ("won", result["disbursement_id"])
   554	                except DisbursementConflict:
   555	                    return ("conflict", None)
   556	            finally:
   557	                connections["default"].close()
   558	
   559	        with (
   560	            patch(
   561	                "sfpcl_credit.disbursements.modules.disbursement_readiness."
   562	                "DisbursementReadinessModule.evaluate",
   563	                return_value=self.fixture._readiness(),
   564	            ),
   565	            patch(
   566	                "sfpcl_credit.applications.modules.document_checklist_facts."
   567	                "resolve_blank_cheque_bank_fact",
   568	                return_value=bank,
   569	            ),
   570	            patch(
   571	                "sfpcl_credit.configurations.modules.configuration_resolver."
   572	                "resolve_source_bank_account",
   573	                return_value=source,
   574	            ),
   575	            ThreadPoolExecutor(max_workers=5) as pool,
   576	        ):
   577	            results = list(pool.map(contender, range(5)))
   578	
   579	        winners = [item for item in results if item[0] == "won"]
   580	        self.assertEqual(len(winners), 1, results)
   581	        self.assertEqual(len([item for item in results if item[0] == "conflict"]), 4)
   582	        row = Disbursement.objects.get()
   583	        self.assertEqual(str(row.pk), winners[0][1])
   584	        self.assertEqual(row.cfc_task.related_entity_id, row.pk)
   585	        self.assertEqual(row.initiation_audit.entity_id, row.pk)
   586	        self.assertEqual(row.initiation_workflow_event.entity_id, row.pk)
   587	        self.assertEqual(
   588	            AuditLog.objects.filter(action="disbursement.initiated").count(), 1
   589	        )
   590	        self.assertEqual(
   591	            WorkflowEvent.objects.filter(workflow_name="DisbursementInitiated").count(),
   592	            1,
   593	        )
   594	        self.assertEqual(
   595	            Notification.objects.filter(
   596	                notification_type="disbursement_authorisation"
   597	            ).count(),
   598	            1,
   599	        )

