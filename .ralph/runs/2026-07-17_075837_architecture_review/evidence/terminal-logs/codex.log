   370	            for code in CHECK_CODES
   371	        ]
   372	        canonical = [{"code": item["code"], "status": item["status"]} for item in checks]
   373	        return {
   374	            "loan_account_id": self.account_id,
   375	            "loan_application_id": str(self.application.pk),
   376	            "ready_for_disbursement": True,
   377	            "evaluated_at": "2026-07-17T07:30:00Z",
   378	            "checks": checks,
   379	            "_evidence": {
   380	                "check_digest": hashlib.sha256(
   381	                    json.dumps(canonical, separators=(",", ":")).encode()
