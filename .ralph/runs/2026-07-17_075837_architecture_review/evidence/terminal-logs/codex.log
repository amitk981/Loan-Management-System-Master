    77	def resolve_readiness_account(*, actor, loan_account_id, cfc_scope_resolver=None):
    78	    """Resolve Stage-5 loan scope without reusing origination assignment."""
    79	    actor = _locked_actor(actor)
    80	    permissions = set(auth_service.effective_permission_codes(actor))
    81	    permission = "finance.disbursement.readiness"
    82	    readiness_roles = {
    83	        "senior_manager_finance",
    84	        "chief_financial_controller",
    85	        "credit_manager",
    86	        "cfo",
    87	        "internal_auditor",
    88	    }
    89	    if permission not in permissions or not set(actor.role_codes()).intersection(
    90	        readiness_roles
    91	    ):
    92	        raise DomainPermissionDenied("Disbursement readiness permission is required.")
    93	    account = (
    94	        LoanAccount.objects.select_for_update()
    95	        .select_related(
    96	            "loan_application",
    97	            "member",
    98	            "sanction_decision",
    99	            "terms",
   100	        )
   101	        .filter(pk=loan_account_id)
   102	        .first()
   103	    )
   104	    if account is None:
   105	        raise DomainObjectAccessDenied(None)
   106	    roles = set(actor.role_codes())
   107	    if "senior_manager_finance" in roles:
   108	        scoped = SapCustomerProfileModule.is_current_finance_assignee(
   109	            application_id=account.loan_application_id,
   110	            member_id=account.member_id,
   111	            actor_id=actor.pk,
   112	        )
   113	    elif "chief_financial_controller" in roles:
   114	        scoped = bool(
   115	            cfc_scope_resolver
   116	            and cfc_scope_resolver(actor_id=actor.pk, loan_account_id=account.pk)
   117	        )
   118	    elif "credit_manager" in roles:
   119	        # Credit owns the loan/monitoring domain, but an archived loan is no
   120	        # longer part of its operational queue.
   121	        scoped = account.loan_account_status in _CREDIT_MONITORING_STATUSES
   122	    elif "cfo" in roles:
   123	        # CFO has the source-defined portfolio detail scope.
   124	        scoped = True
   125	    else:
   126	        # Auditor scope is an explicit persisted read-only grant, not a role or
   127	        # application-assignment shortcut.
   128	        scoped = ApprovalCaseReadScopeGrant.objects.filter(
   129	            role=actor.primary_role,
   130	            scope_type=ApprovalCaseReadScopeGrant.SCOPE_AUDIT_READONLY,
   131	            status=ApprovalCaseReadScopeGrant.STATUS_ACTIVE,
   132	        ).exists()
   133	    if not scoped:
   134	        raise DomainObjectAccessDenied(None)
   135	    if (
   136	        account.loan_application.member_id != account.member_id
   137	        or account.terms.loan_account_id != account.pk
   138	        or account.sanction_decision.loan_application_id
   139	        != account.loan_application_id
   140	    ):
