   311	def _require_unfunded_account(account, amount):
   312	    zero_fields = (
   313	        account.disbursed_amount,
   314	        account.principal_outstanding,
   315	        account.interest_outstanding,
   316	        account.charges_outstanding,
   317	        account.total_outstanding,
   318	    )
   319	    if (
   320	        account.loan_account_status != LoanAccount.STATUS_SANCTIONED
   321	        or account.loan_application.member_id != account.member_id
   322	        or account.sanction_decision.loan_application_id != account.loan_application_id
   323	        or account.terms.loan_account_id != account.pk
   324	        or any(value != 0 for value in zero_fields)
   325	        or amount != account.terms.loan_amount
   326	        or amount > account.sanctioned_amount
   327	    ):
   328	        raise DisbursementReadinessStale(
   329	            "The loan account amount or unfunded sanctioned state has changed."
   330	        )
