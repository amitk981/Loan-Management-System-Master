+        )
+        from sfpcl_credit.credit.modules.appraisal_workflow import (
+            AppraisalWorkflow,
+            CreditModuleInvalidStateError,
+        )
+
+        workflow = AppraisalWorkflow()
+        created = workflow.create_or_update(
