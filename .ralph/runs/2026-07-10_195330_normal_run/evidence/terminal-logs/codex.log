+            ).values(*history_fields)
+        )
+        winner_locked = Event()
+        loser_attempting = Event()
+        loser_completed = Event()
+        release_winner = Event()
+        ordering = []
+        ordering_lock = Lock()
+
+        def record(step):
+            with ordering_lock:
+                ordering.append(step)
+
+        class CoordinatedRejectionPayload(dict):
+            blocked = False
+
+            def get(self, key, default=None):
