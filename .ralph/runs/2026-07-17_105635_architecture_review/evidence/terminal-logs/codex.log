      shift 2
      ;;
    --worktree)
      worktree_dir="${2:?--worktree requires a value}"
      shift 2
      ;;
    --mode)
      mode="${2:?--mode requires a value}"
      shift 2
      ;;
    --slice)
      slice_id="${2:?--slice requires a value}"
      shift 2
      ;;
    *)
