+        )
+        changed = dict(send_audit.new_value_json)
+        changed["assigned_to_user_id"] = str(uuid4())
+        AuditLog.objects.filter(pk=send_audit.pk).update(new_value_json=changed)
+
+        self.assertIsNone(
