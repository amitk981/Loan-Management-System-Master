   220	        self.assertEqual(immutable.status_code, 400)
   221	        self.assertIn("member_id", immutable.json()["error"]["field_errors"])
   222	        stale = self.client.patch(self._detail_url(witness_id), data={"version": 2, "witness_name": "Changed"}, content_type="application/json", headers=headers)
   223	        self.assertEqual(stale.status_code, 409)
   224	        self.assertEqual(Witness.objects.get().version, 1)
   225	        self.assertEqual(WitnessChangeHistory.objects.count(), 0)
   226	        self.assertEqual(AuditLog.objects.count(), baseline_audits)
