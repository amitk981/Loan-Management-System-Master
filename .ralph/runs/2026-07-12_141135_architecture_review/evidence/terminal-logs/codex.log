   217	def create_witness(application, payload, actor_user, request_ip="", request_user_agent=""):
   218	    allowed_fields = {"member_id", "witness_name", "pan", "aadhaar", "address", "mobile"}
   219	    unknown_fields = sorted(set(payload) - allowed_fields)
   220	    if unknown_fields:
   221	        raise WitnessValidationError(
   222	            "VALIDATION_ERROR",
