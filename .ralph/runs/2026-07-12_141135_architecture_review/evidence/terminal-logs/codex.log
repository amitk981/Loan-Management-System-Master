   224	            {field: "Unknown field." for field in unknown_fields},
   225	        )
   226	    try:
   227	        member_id = uuid.UUID(str(payload.get("member_id") or ""))
   228	    except (ValueError, TypeError, AttributeError) as exc:
   229	        raise WitnessValidationError(
   230	            "MISSING_REQUIRED_FIELD" if not payload.get("member_id") else "VALIDATION_ERROR",
   231	            "Witness member is required.",
   232	            {"member_id": "A valid member UUID is required."},
   233	        ) from exc
   234	    member = Member.objects.filter(member_id=member_id, is_deleted=False).first()
   235	    if member is None:
   236	        raise WitnessValidationError("NOT_FOUND", "Witness member was not found.")
   237	    witness_name = str(payload.get("witness_name") or "").strip()
   238	    if not witness_name:
