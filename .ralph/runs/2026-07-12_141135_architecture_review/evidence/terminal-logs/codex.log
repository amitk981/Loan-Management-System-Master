  1823	def _clean_return_deficiencies_payload(application, payload):
  1824	    unknown = set(payload.keys()) - {"communication_mode", "message", "items"}
  1825	    errors = {field: "Unknown field." for field in sorted(unknown)}
  1826	    communication_mode = _optional_text(payload.get("communication_mode"))
  1827	    message = _optional_text(payload.get("message"))
  1828	    raw_items = payload.get("items")
  1829	    if not communication_mode:
  1830	        errors["communication_mode"] = "This field is required."
  1831	    if not message:
  1832	        errors["message"] = "This field is required."
  1833	    if not isinstance(raw_items, list) or not raw_items:
  1834	        errors["items"] = "At least one deficiency item is required."
  1835	        raw_items = []
  1836	
  1837	    blocking_items = {
  1838	        item["document_type"]: item
  1839	        for item in build_completeness_workbench(application)["required_checklist_items"]
  1840	        if not item["complete"]
  1841	    }
  1842	    cleaned_items = []
  1843	    seen = set()
  1844	    item_errors = []
  1845	    for index, raw_item in enumerate(raw_items):
  1846	        if not isinstance(raw_item, dict):
  1847	            item_errors.append({"index": index, "error": "Each deficiency item must be an object."})
  1848	            continue
  1849	        unknown_item_fields = set(raw_item.keys()) - {"item_code", "remarks"}
  1850	        item_code = _optional_text(raw_item.get("item_code")).lower()
  1851	        if not item_code:
  1852	            item_errors.append({"index": index, "item_code": "This field is required."})
  1853	            continue
  1854	        if unknown_item_fields:
  1855	            item_errors.append(
  1856	                {
  1857	                    "index": index,
  1858	                    "unknown_fields": sorted(unknown_item_fields),
  1859	                }
  1860	            )
  1861	            continue
  1862	        if item_code in seen:
  1863	            item_errors.append({"index": index, "item_code": "Duplicate deficiency item."})
  1864	            continue
  1865	        source_item = blocking_items.get(item_code)
  1866	        if source_item is None:
  1867	            item_errors.append(
  1868	                {
  1869	                    "index": index,
  1870	                    "item_code": "Must match a current blocking completeness checklist item.",
  1871	                }
  1872	            )
  1873	            continue
  1874	        seen.add(item_code)
  1875	        cleaned_items.append(
  1876	            {
  1877	                "item_code": item_code,
  1878	                "deficiency_type": _deficiency_type_for_source_reason(
  1879	                    source_item["reason_code"]
  1880	                ),
  1881	                "source_reason_code": source_item["reason_code"],
  1882	                "description": _deficiency_description(source_item),
  1883	                "remarks": _optional_text(raw_item.get("remarks")),
  1884	            }
  1885	        )
  1886	    if item_errors:
  1887	        errors["items"] = item_errors
  1888	    if errors:
  1889	        raise LoanApplicationValidationError(errors)
  1890	    return {
  1891	        "communication_mode": communication_mode,
  1892	        "message": message,
  1893	        "items": cleaned_items,
  1894	    }
