    63	    @classmethod
    64	    @transaction.atomic
    65	    def request_identity_change(cls, member_id, payload, actor_user):
    66	        member = Member.objects.select_for_update().filter(member_id=member_id, is_deleted=False).first()
    67	        if member is None:
    68	            return None
    69	        cls._require_member_access(
    70	            actor_user=actor_user, member=member, permission=services.MEMBER_UPDATE_PERMISSION
    71	        )
    72	        version = payload.get("version")
    73	        reason = payload.get("reason")
    74	        pan, aadhaar = payload.get("pan"), payload.get("aadhaar")
    75	        errors = {}
    76	        if version != member.version: errors["version"] = "Version is stale."
    77	        if member.kyc_status != "verified": errors["member"] = "Identity changes require verified KYC."
    78	        if not isinstance(reason, str) or not reason.strip(): errors["reason"] = "A reason is required."
    79	        if not pan and not aadhaar: errors["pan"] = "At least one identity field is required."
    80	        if pan and (not isinstance(pan, str) or not services._PAN_RE.fullmatch(pan)): errors["pan"] = "Invalid PAN format."
    81	        if aadhaar and (not isinstance(aadhaar, str) or not services._AADHAAR_RE.fullmatch(aadhaar)): errors["aadhaar"] = "Invalid Aadhaar format."
    82	        if pan and Member.objects.filter(pan_hash=identity_hash(pan), is_deleted=False).exclude(member_id=member.member_id).exists():
    83	            errors["pan"] = "A member with this PAN already exists."
    84	        if aadhaar and Member.objects.filter(aadhaar_hash=identity_hash(aadhaar), is_deleted=False).exclude(member_id=member.member_id).exists():
    85	            errors["aadhaar"] = "A member with this Aadhaar already exists."
    86	        if errors: raise ValidationError(errors)
    87	        return MemberIdentityChangeRequest.objects.create(
    88	            member=member, requester_user=actor_user, reason=reason.strip(), member_version=member.version,
    89	            proposed_pan_encrypted=protected_identity_token(pan, 10) if pan else "", proposed_pan_hash=identity_hash(pan) if pan else "",
    90	            proposed_aadhaar_encrypted=protected_identity_token(aadhaar, 12) if aadhaar else "", proposed_aadhaar_hash=identity_hash(aadhaar) if aadhaar else "",
    91	        )
    92	
    93	    @classmethod
    94	    @transaction.atomic
    95	    def approve_identity_change(cls, request_id, actor_user):
    96	        change = MemberIdentityChangeRequest.objects.select_for_update().select_related("member").filter(identity_change_request_id=request_id).first()
    97	        if change is None: return None
    98	        member = Member.objects.select_for_update().get(member_id=change.member_id)
    99	        cls._require_member_access(actor_user=actor_user, member=member, permission=cls.APPROVE_PERMISSION)
   100	        approval = cls.evaluate_identity_approval(member, change, actor_user)
   101	        if not approval["enabled"]:
   102	            if approval["status"] == 403: raise PermissionDenied(approval["disabled_reason"])
   103	            raise services.MemberWriteConflict(approval["code"], approval["disabled_reason"])
   104	        old_values, new_values, changed = {}, {}, []
   105	        for field, length in (("pan", 10), ("aadhaar", 12)):
   106	            token = getattr(change, f"proposed_{field}_encrypted")
   107	            if token:
   108	                changed.append(field); old_values[field] = mask_protected_identity(getattr(member, f"{field}_encrypted"), length)
   109	                setattr(member, f"{field}_encrypted", token); setattr(member, f"{field}_hash", getattr(change, f"proposed_{field}_hash"))
   110	                new_values[field] = mask_protected_identity(token, length)
   111	        member.kyc_status = "pending"; member.rekyc_due_date = None; member.version += 1
   112	        member.updated_by_user = actor_user; member.updated_at = timezone.now()
   113	        try:
   114	            with transaction.atomic():
   115	                member.save()
   116	        except IntegrityError:
   117	            errors = {}
   118	            if change.proposed_pan_hash and Member.objects.filter(pan_hash=change.proposed_pan_hash, is_deleted=False).exclude(member_id=member.member_id).exists(): errors["pan"] = "A member with this PAN already exists."
   119	            if change.proposed_aadhaar_hash and Member.objects.filter(aadhaar_hash=change.proposed_aadhaar_hash, is_deleted=False).exclude(member_id=member.member_id).exists(): errors["aadhaar"] = "A member with this Aadhaar already exists."
   120	            raise ValidationError(errors or {"identity": "PAN or Aadhaar already belongs to a member."})
   121	        change.status = "approved"; change.approver_user = actor_user; change.approved_at = timezone.now(); change.save()
   122	        MemberChangeHistory.objects.create(member=member, actor_user=actor_user, change_type="identity_change_approved", changed_fields=changed, old_value_json=old_values, new_value_json=new_values, reason=change.reason)
   123	        AuditLog.objects.create(actor_user=actor_user, action="members.member.identity_change_approved", entity_type="member", entity_id=member.member_id, new_value_json={"request_id": str(change.identity_change_request_id), "changed_fields": changed})
   124	        return member
   125	
   126	    @classmethod
   127	    def evaluate_identity_approval(cls, member, change, actor_user):
   128	        permissions = auth_service.effective_permission_codes(actor_user)
   129	        if cls.APPROVE_PERMISSION not in permissions:
   130	            return {"enabled": False, "disabled_reason": "Missing identity change approval permission.", "status": 403, "code": "FORBIDDEN"}
   131	        if change is None or change.status != "pending":
   132	            return {"enabled": False, "disabled_reason": "Identity change request is not pending.", "status": 409, "code": "IDENTITY_CHANGE_NOT_PENDING"}
   133	        if change.requester_user_id == actor_user.user_id:
   134	            return {"enabled": False, "disabled_reason": "Requester cannot approve their own change.", "status": 403, "code": "FORBIDDEN"}
   135	        if member.version != change.member_version or member.kyc_status != "verified":
   136	            return {"enabled": False, "disabled_reason": "Member has changed; refresh and retry.", "status": 409, "code": "STALE_WRITE"}
   137	        return {"enabled": True, "disabled_reason": None, "status": 200, "code": None}
