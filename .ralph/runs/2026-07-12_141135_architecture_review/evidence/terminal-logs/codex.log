    31	
    32	class ActiveMemberStatusModule:
    33	    """Public member-owned projection for BR-004/BR-007 evidence."""
    34	
    35	    def calculate(self, *, member_id, as_of_date=None):
    36	        calculated_as_of_date = as_of_date or timezone.localdate()
    37	        member = (
    38	            Member.objects.select_related("individual_profile", "producer_institution_profile")
    39	            .filter(member_id=member_id, is_deleted=False)
    40	            .first()
    41	        )
    42	        if member is None:
    43	            raise Member.DoesNotExist("Member was not found.")
    44	        services_availed = self._services_availed(member)
    45	        rows = tuple(
    46	            self._project_row(row)
    47	            for row in member.produce_supply_records.select_related("producer_institution_member").all()
    48	        )
    49	        qualifying_years = [row.financial_year for row in rows if row.qualifying]
    50	        continuity = longest_continuous_financial_years(qualifying_years)
    51	        if member.membership_status != "active":
    52	            return ActiveMemberStatusResult(
    53	                calculated_as_of_date.isoformat(), "fail", "ineligible",
    54	                f"BR-003 requires active member status or relaxation evidence; member status is {member.membership_status}.",
    55	                services_availed, continuity, rows,
    56	            )
    57	        if services_availed and continuity >= 4:
    58	            return ActiveMemberStatusResult(
    59	                calculated_as_of_date.isoformat(), "pass", "pending",
    60	                "Active-member status is supported by services availed and four continuous verified financial years of qualifying produce supply. Default, document, terms, purpose, and nominee checks are pending.",
    61	                services_availed, continuity, rows,
    62	            )
    63	        if member.active_member_status == "relaxation" and member.active_member_verified_at:
    64	            return ActiveMemberStatusResult(
    65	                calculated_as_of_date.isoformat(), "relaxation", "pending_manual_evidence",
    66	                "Active-member relaxation is recorded on the member profile. Manual evidence remains reviewable for BR-004 through BR-007.",
    67	                services_availed, continuity, rows,
    68	            )
    69	        return ActiveMemberStatusResult(
    70	            calculated_as_of_date.isoformat(), "manual_evidence_required", "pending_manual_evidence",
    71	            "BR-004 through BR-007 require persisted service usage and continuous qualifying verified supply history or relaxation evidence; manual evidence is required.",
    72	            services_availed, continuity, rows,
    73	        )
    74	
    75	    @staticmethod
    76	    def _services_availed(member):
    77	        if member.member_type == "individual_farmer":
    78	            profile = getattr(member, "individual_profile", None)
    79	        else:
    80	            profile = getattr(member, "producer_institution_profile", None)
    81	        return bool(profile and profile.services_availed_flag)
    82	
    83	    @staticmethod
    84	    def _project_row(record):
    85	        reason = None
    86	        if not record.verified_flag:
    87	            reason = "pending_verification"
    88	        elif canonical_financial_year_start(record.financial_year) is None:
    89	            reason = "malformed_financial_year"
    90	        elif record.supplied_to_entity_type not in QUALIFYING_ENTITY_TYPES:
    91	            reason = "ineligible_entity"
    92	        elif record.supply_route not in QUALIFYING_ROUTES:
    93	            reason = "ineligible_route"
    94	        elif record.supply_route == "direct" and record.producer_institution_member_id:
    95	            reason = "inconsistent_direct_route"
    96	        elif record.supply_route == "producer_institution" and not _eligible_producer_institution(record):
    97	            reason = "ineligible_producer_institution_route"
    98	        elif not record.evidence_reference.strip():
    99	            reason = "missing_evidence_reference"
   100	        return SupplyRowProjection(
   101	            str(record.produce_supply_record_id), record.financial_year,
   102	            record.verified_flag, reason is None, reason,
   103	        )
   104	
   105	
   106	def _eligible_producer_institution(record):
   107	    routed = record.producer_institution_member
   108	    return bool(
   109	        routed
   110	        and routed.member_id != record.member_id
   111	        and routed.member_type in {"fpc", "producer_institution"}
   112	        and routed.membership_status == "active"
   113	        and not routed.is_deleted
   114	    )
   115	
   116	
   117	def canonical_financial_year_start(value):
   118	    if not isinstance(value, str) or len(value) != 7 or value[4] != "-":
   119	        return None
   120	    try:
   121	        start = int(value[:4])
   122	    except ValueError:
   123	        return None
   124	    return start if value[5:] == str((start + 1) % 100).zfill(2) else None
   125	
   126	
   127	def longest_continuous_financial_years(values):
   128	    starts = {start for value in values if (start := canonical_financial_year_start(value)) is not None}
   129	    return max((sum(1 for offset in range(len(starts)) if start + offset in starts) for start in starts), default=0)

