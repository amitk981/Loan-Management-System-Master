   273	    if len(address) > 500:
   274	        raise WitnessValidationError("VALIDATION_ERROR", "Witness payload failed validation.", {"address": "Address must be 500 characters or fewer."})
   275	    if mobile and not re.fullmatch(r"[0-9]{7,15}", mobile):
   276	        raise WitnessValidationError("VALIDATION_ERROR", "Witness payload failed validation.", {"mobile": "Mobile must contain 7 to 15 digits."})
   277	    if not pan:
