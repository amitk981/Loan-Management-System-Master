     6	
     7	
     8	QUALIFYING_ENTITY_TYPES = frozenset({"sfpcl", "subsidiary", "step_down_subsidiary"})
     9	QUALIFYING_ROUTES = frozenset({"direct", "producer_institution"})
    10	
    11	
    12	@dataclass(frozen=True)
    13	class SupplyRowProjection:
    14	    produce_supply_record_id: str
    15	    financial_year: str
    16	    verified: bool
    17	    qualifying: bool
    18	    non_qualifying_reason: str | None
    19	
    20	
    21	@dataclass(frozen=True)
    22	class ActiveMemberStatusResult:
    23	    calculated_as_of_date: str
    24	    member_active_check: str
    25	    overall_result: str
    26	    assessment_notes: str
    27	    services_availed: bool
    28	    continuous_supply_years: int
    29	    supply_rows: tuple[SupplyRowProjection, ...]
