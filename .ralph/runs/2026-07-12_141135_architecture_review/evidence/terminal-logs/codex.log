   283	    if not re.fullmatch(r"[0-9]{12}", aadhaar):
   284	        raise WitnessValidationError("INVALID_AADHAAR_FORMAT", "Aadhaar format is invalid.", {"aadhaar": "Aadhaar must be a 12 digit number."})
   285	    verified_at = timezone.now()
