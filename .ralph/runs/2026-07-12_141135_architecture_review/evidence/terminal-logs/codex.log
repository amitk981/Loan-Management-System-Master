  1792	    document_type = (payload.get("document_type") or "").strip().lower()
  1793	    party_type = (payload.get("party_type") or "").strip().lower()
  1794	    document_file_id = _parse_uuid("document_file_id", payload.get("document_file_id"), errors)
  1795	    party_id = _optional_uuid("party_id", payload.get("party_id"), errors)
  1796	
  1797	    if not document_type:
  1798	        errors["document_type"] = "This field is required."
  1799	    elif document_type not in APPLICATION_DOCUMENT_TYPES:
  1800	        errors["document_type"] = "Unsupported application document type."
  1801	    if not party_type:
  1802	        errors["party_type"] = "This field is required."
  1803	    elif party_type not in APPLICATION_DOCUMENT_PARTY_TYPES:
  1804	        errors["party_type"] = "Must be one of borrower, nominee, witness."
  1805	
  1806	    document_file = None
  1807	    if document_file_id:
  1808	        document_file = DocumentFile.objects.filter(document_id=document_file_id).first()
  1809	        if document_file is None:
  1810	            errors["document_file_id"] = "Document file was not found."
  1811	
  1812	    if errors:
  1813	        raise LoanApplicationValidationError(errors)
  1814	    return {
  1815	        "document_type": document_type,
  1816	        "party_type": party_type,
  1817	        "party_id": party_id,
  1818	        "document_file": document_file,
  1819	        "remarks": _optional_text(payload.get("remarks")),
  1820	    }
