   267	    pan = str(payload.get("pan") or "").strip().upper()
   268	    aadhaar = str(payload.get("aadhaar") or "").replace(" ", "").strip()
   269	    address = str(payload.get("address") or "").strip()
   270	    mobile = str(payload.get("mobile") or "").replace(" ", "").strip()
   271	    if not address:
