                <span className="hidden sm:inline">Sign out</span>
              </button>
            )}
          </div>
        </header>
        <main className="flex-1 overflow-y-auto">
          <div className="w-full px-4 sm:px-6 py-6">
            {children}
          </div>
        </main>
      </div>
    </div>
  );
};

export default MemberPortalLayout;

