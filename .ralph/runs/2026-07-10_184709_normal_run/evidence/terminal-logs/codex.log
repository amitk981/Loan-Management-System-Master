+                from_state="review_pending",
+                to_state="rejected",
+            ).count(),
+            1,
+        )
+        self.assertEqual(
+            WorkflowEvent.objects.filter(
+                entity_type="rejection_note",
+                to_state="draft",
+            ).count(),
+            1,
+        )
