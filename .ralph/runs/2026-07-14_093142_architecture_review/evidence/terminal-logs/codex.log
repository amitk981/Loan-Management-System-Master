   156	def _validate_payload(payload):
   157	    errors = {}
   158	    unknown = set(payload.keys()) - _FIELDS
   159	    for field in sorted(unknown):
   160	        errors[field] = "Unknown field."
   161	    for field in sorted(_REQUIRED_FIELDS):
   162	        if payload.get(field) in (None, ""):
   163	            errors[field] = "This field is required."
   164	
   165	    cleaned = {}
   166	    string_limits = {
   167	        "template_code": 120,
   168	        "template_name": 255,
   169	        "document_type": 100,
   170	        "template_version": 40,
   171	    }
   172	    for field, max_length in string_limits.items():
   173	        value = payload.get(field)
   174	        if value is not None:
   175	            value = str(value).strip()
   176	        if field in payload and not value:
   177	            errors[field] = "This field is required."
   178	        elif value and len(value) > max_length:
   179	            errors[field] = f"Must be at most {max_length} characters."
   180	        cleaned[field] = value
   181	
   182	    borrower_type = payload.get("borrower_type")
   183	    if borrower_type not in (None, ""):
   184	        borrower_type = str(borrower_type).strip().lower()
   185	        if borrower_type not in DocumentTemplate.BORROWER_TYPES:
   186	            errors["borrower_type"] = "Must be individual_farmer, fpc, fpo, or null."
   187	    cleaned["borrower_type"] = borrower_type or None
   188	
   189	    approval_status = str(payload.get("approval_status") or "").strip().lower()
   190	    if approval_status not in DocumentTemplate.APPROVAL_STATUSES:
   191	        errors["approval_status"] = "Must be one of draft, approved, retired."
   192	    cleaned["approval_status"] = approval_status
   193	
   194	    for field in ("effective_from", "effective_to"):
   195	        value = payload.get(field)
   196	        parsed = None if value in (None, "") else parse_date(str(value))
   197	        if field == "effective_from" and value in (None, ""):
   198	            errors[field] = "This field is required."
   199	        elif value not in (None, "") and parsed is None:
   200	            errors[field] = "Must be a valid ISO date."
   201	        cleaned[field] = parsed
   202	    if (
   203	        cleaned.get("effective_from")
   204	        and cleaned.get("effective_to")
   205	        and cleaned["effective_to"] < cleaned["effective_from"]
   206	    ):
   207	        errors["effective_to"] = "Must be on or after effective_from."
   208	
   209	    merge_fields = payload.get("merge_fields", [])
   210	    if not isinstance(merge_fields, list) or any(
   211	        not isinstance(value, str) for value in merge_fields
   212	    ):
   213	        errors["merge_fields"] = "Must be a list of unique nonblank field names."
   214	    else:
   215	        normalized = [value.strip() for value in merge_fields]
   216	        if any(not value for value in normalized) or len(set(normalized)) != len(normalized):
   217	            errors["merge_fields"] = "Must be a list of unique nonblank field names."
   218	        cleaned["merge_fields_json"] = normalized
   219	    if "merge_fields_json" not in cleaned:
   220	        cleaned["merge_fields_json"] = []
   221	
   222	    template_file_id = payload.get("template_file_id")
   223	    if template_file_id not in (None, ""):
   224	        try:
   225	            template_file_id = uuid.UUID(str(template_file_id))
   226	        except (TypeError, ValueError, AttributeError):
   227	            errors["template_file_id"] = "Document file was not found or is inaccessible."
   228	    cleaned["template_file_id"] = template_file_id or None
   229	    if errors:
   230	        raise ValidationError(errors)
   231	    return cleaned
   232	
