    90	def create(*, actor, metadata, payload):
    91	    cleaned = _validate_payload(payload)
    92	    _resolve_template_file(actor, cleaned)
    93	    with transaction.atomic():
    94	        _lock_identity(cleaned)
    95	        replay = _exact_match(cleaned, supersedes=None)
    96	        if replay is not None:
    97	            return serialize(replay)
    98	        _validate_unique_and_effective(cleaned)
    99	        template = DocumentTemplate.objects.create(**cleaned)
   100	        _record_evidence(
   101	            actor=actor,
   102	            metadata=metadata,
   103	            action=CREATE_ACTION,
   104	            template=template,
   105	            old_value={},
   106	        )
   107	        return serialize(template)
