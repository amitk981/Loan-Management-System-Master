   712	def _loan_limit_provenance_is_complete(case):
   713	    """Validate approval-owned frozen provenance without consulting live credit rows."""
   714	    provenance = case.loan_limit_provenance_json
   715	    required = (
   716	        "loan_limit_assessment_id",
   717	        "loan_application_id",
   718	        "final_eligible_loan_amount",
   719	        "exception_required_flag",
   720	        "calculation_rule_version",
   721	        "policy_config_id",
   722	        "policy_name",
   723	        "calculated_at",
   724	    )
   725	    condition_requires_exception = bool(case.exception_condition_code)
   726	    complete = (
   727	        isinstance(provenance, dict)
   728	        and all(provenance.get(key) not in (None, "") for key in required)
   729	        and str(provenance["loan_application_id"]) == str(case.loan_application_id)
   730	        and isinstance(provenance["exception_required_flag"], bool)
   731	        and provenance["exception_required_flag"] == case.exception_required_flag
   732	        and (not provenance["exception_required_flag"] or condition_requires_exception)
   733	    )
   734	    if not complete:
   735	        return False
   736	    try:
   737	        final_eligible_amount = Decimal(
   738	            str(provenance["final_eligible_loan_amount"])
   739	        )
   740	        calculated_at = timezone.datetime.fromisoformat(
   741	            str(provenance["calculated_at"]).replace("Z", "+00:00")
   742	        )
   743	    except (InvalidOperation, TypeError, ValueError):
   744	        return False
   745	    return final_eligible_amount >= Decimal("0.00") and calculated_at is not None
