   698	def _amount_inside_projection(amount, matrix):
   699	    try:
   700	        amount = Decimal(str(amount))
   701	        minimum = Decimal(str(matrix["amount_min"]))
   702	        maximum = (
   703	            Decimal(str(matrix["amount_max"]))
   704	            if matrix.get("amount_max") is not None
   705	            else None
   706	        )
   707	    except (KeyError, InvalidOperation, TypeError, ValueError):
   708	        return False
   709	    return amount >= minimum and (maximum is None or amount <= maximum)
