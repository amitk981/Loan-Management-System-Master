    31	    def store(self, uploaded_file):
    32	        safe_name = safe_file_name(uploaded_file.name)
    33	        storage_key = f"document-files/{uuid.uuid4()}/{safe_name}"
    34	        target_path = self.root / storage_key
    35	        target_path.parent.mkdir(parents=True, exist_ok=True)
    36	
    37	        checksum = hashlib.sha256()
    38	        size = 0
    39	        with target_path.open("wb") as target:
    40	            for chunk in uploaded_file.chunks():
    41	                checksum.update(chunk)
    42	                size += len(chunk)
    43	                target.write(chunk)
    44	
    45	        return StoredFile(
    46	            storage_provider=self.storage_provider,
    47	            storage_key=storage_key,
    48	            file_size_bytes=size,
    49	            checksum_sha256=checksum.hexdigest(),
    50	        )
    51	
    52	    def delete(self, stored_file):
    53	        target_path = self.root / stored_file.storage_key
    54	        target_path.unlink(missing_ok=True)
    55	        parent = target_path.parent
    56	        if parent.exists() and not any(parent.iterdir()):
    57	            parent.rmdir()
    58	
    59	    def read_verified(self, document):
    60	        root = self.root.resolve()
    61	        target_path = (root / document.storage_key).resolve()
    62	        if root not in target_path.parents:
    63	            raise ValueError("Document storage key escapes the configured root.")
    64	        content = target_path.read_bytes()
    65	        checksum = hashlib.sha256(content).hexdigest()
    66	        if checksum != document.checksum_sha256 or len(content) != document.file_size_bytes:
    67	            raise ValueError("Document bytes do not match retained metadata.")
    68	        return content
    69	
    70	    def download_descriptor(self, document):
    71	        ttl_minutes = getattr(settings, "DOCUMENT_DOWNLOAD_URL_TTL_MINUTES", 15)
    72	        expires_at = timezone.now() + timezone.timedelta(minutes=ttl_minutes)
    73	        expires_value = expires_at.isoformat().replace("+00:00", "Z")
    74	        query = urlencode({"expires_at": expires_value})
    75	        return {
    76	            "download_url": (
    77	                f"/api/v1/local-document-files/{document.document_id}/download/?{query}"
    78	            ),
    79	            "expires_at": expires_value,
    80	        }
