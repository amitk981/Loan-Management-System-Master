   619	def _approver_snapshot_is_coherent(required, matrix, committee):
   620	    cfo_id = str(committee.get("cfo_user_id") or "")
   621	    director_ids = committee.get("director_user_ids")
   622	    if (
   623	        not cfo_id
   624	        or not isinstance(director_ids, list)
   625	        or len(director_ids) != 2
   626	        or any(not item for item in director_ids)
   627	    ):
   628	        return False
   629	    director_ids = [str(item) for item in director_ids]
   630	    committee_ids = [cfo_id, *director_ids]
   631	    if len(set(committee_ids)) != 3:
   632	        return False
   633	    expected = [("cfo", cfo_id)] + [
   634	        ("director", user_id)
   635	        for user_id in director_ids[: matrix["required_director_count"]]
   636	    ]
   637	    if len(required) != len(expected):
   638	        return False
   639	    actual = []
   640	    for item in required:
   641	        if (
   642	            not isinstance(item, dict)
   643	            or not isinstance(item.get("full_name"), str)
   644	            or not item["full_name"].strip()
   645	        ):
   646	            return False
   647	        actual.append((item.get("role_code"), str(item.get("user_id") or "")))
   648	    return actual == expected and len({user_id for _, user_id in actual}) == len(actual)
