    31	
    32	export async function captureReviewableEvidence(
    33	  page: Page,
    34	  evidence: Locator,
    35	  evidenceDir: string,
    36	  fileName: string,
    37	): Promise<void> {
    38	  await evidence.scrollIntoViewIfNeeded();
    39	  const box = await evidence.boundingBox();
    40	  expect(box).not.toBeNull();
    41	  expect(box!.y).toBeGreaterThanOrEqual(0);
    42	  expect(box!.y + box!.height).toBeLessThanOrEqual(720);
    43	  const screenshot = await page.screenshot({ path: path.join(evidenceDir, fileName), animations: 'disabled' });
    44	  const stats = await page.evaluate(async dataUrl => {
    45	    const image = new Image();
    46	    image.src = dataUrl;
    47	    await image.decode();
    48	    const canvas = document.createElement('canvas');
    49	    canvas.width = image.width; canvas.height = image.height;
    50	    const context = canvas.getContext('2d')!;
    51	    context.drawImage(image, 0, 0);
    52	    const pixels = context.getImageData(0, 0, image.width, image.height).data;
    53	    let opaqueDark = 0;
    54	    const buckets = new Set<number>();
    55	    for (let index = 0; index < pixels.length; index += 16) {
    56	      const red = pixels[index]; const green = pixels[index + 1]; const blue = pixels[index + 2];
    57	      if (red < 12 && green < 12 && blue < 12) opaqueDark += 1;
    58	      buckets.add((red >> 5) * 64 + (green >> 5) * 8 + (blue >> 5));
    59	    }
    60	    const tileSize = 64;
    61	    const columns = Math.ceil(image.width / tileSize);
    62	    const rows = Math.ceil(image.height / tileSize);
    63	    const uniform = Array<boolean>(columns * rows).fill(false);
    64	    for (let tileY = 0; tileY < rows; tileY += 1) {
    65	      for (let tileX = 0; tileX < columns; tileX += 1) {
    66	        let min = 255; let max = 0;
    67	        for (let y = tileY * tileSize; y < Math.min((tileY + 1) * tileSize, image.height); y += 4) {
    68	          for (let x = tileX * tileSize; x < Math.min((tileX + 1) * tileSize, image.width); x += 4) {
    69	            const offset = (y * image.width + x) * 4;
    70	            for (let channel = 0; channel < 3; channel += 1) {
    71	              min = Math.min(min, pixels[offset + channel]); max = Math.max(max, pixels[offset + channel]);
    72	            }
    73	          }
    74	        }
    75	        uniform[tileY * columns + tileX] = max - min <= 4;
    76	      }
    77	    }
    78	    const visited = Array<boolean>(uniform.length).fill(false);
    79	    let largestUniformRegion = 0;
    80	    for (let start = 0; start < uniform.length; start += 1) {
    81	      if (!uniform[start] || visited[start]) continue;
    82	      const queue = [start]; visited[start] = true; let size = 0;
    83	      while (queue.length) {
    84	        const current = queue.pop()!; size += 1;
    85	        const x = current % columns; const y = Math.floor(current / columns);
    86	        for (const next of [x > 0 ? current - 1 : -1, x + 1 < columns ? current + 1 : -1, y > 0 ? current - columns : -1, y + 1 < rows ? current + columns : -1]) {
    87	          if (next >= 0 && uniform[next] && !visited[next]) { visited[next] = true; queue.push(next); }
    88	        }
    89	      }
    90	      largestUniformRegion = Math.max(largestUniformRegion, size);
    91	    }
    92	    return { width: image.width, height: image.height, darkRatio: opaqueDark / (pixels.length / 16), colorBuckets: buckets.size, largestUniformRegionRatio: largestUniformRegion / uniform.length };
    93	  }, `data:image/png;base64,${screenshot.toString('base64')}`);
    94	  expect(stats).toMatchObject({ width: 1280, height: 720 });
    95	  expect(stats.darkRatio).toBeLessThan(0.2);
    96	  expect(stats.colorBuckets).toBeGreaterThan(16);
    97	  expect(stats.largestUniformRegionRatio).toBeLessThan(0.3);
    98	}

