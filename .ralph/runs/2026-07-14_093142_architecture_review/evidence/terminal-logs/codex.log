   246	def _validate_unique_and_effective(cleaned):
   247	    duplicate = DocumentTemplate.objects.filter(template_code=cleaned["template_code"])
   248	    if duplicate.exists():
   249	        raise ValidationError({"template_code": "Template code already exists."})
   250	    duplicate_version = DocumentTemplate.objects.filter(
   251	        document_type=cleaned["document_type"],
   252	        borrower_type=cleaned["borrower_type"],
   253	        template_version=cleaned["template_version"],
   254	    )
   255	    if duplicate_version.exists():
   256	        raise ValidationError(
   257	            {"template_version": "Template version already exists for this variant."}
   258	        )
   259	    if cleaned["approval_status"] != DocumentTemplate.STATUS_APPROVED:
   260	        return
   261	    candidates = DocumentTemplate.objects.select_for_update().filter(
   262	        document_type=cleaned["document_type"],
   263	        borrower_type=cleaned["borrower_type"],
   264	        approval_status=DocumentTemplate.STATUS_APPROVED,
   265	    )
   266	    start = cleaned["effective_from"]
   267	    end = cleaned["effective_to"]
   268	    for candidate in candidates:
   269	        if (candidate.effective_to is None or candidate.effective_to >= start) and (
   270	            end is None or candidate.effective_from <= end
   271	        ):
   272	            raise ValidationError(
   273	                {"effective_from": "Approved effective versions must not overlap."}
   274	            )
   275	
