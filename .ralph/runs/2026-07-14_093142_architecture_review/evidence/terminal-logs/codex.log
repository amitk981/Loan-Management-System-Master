   679	def _conflict_authority_state_is_coherent(case):
   680	    satisfiable = ConflictOfInterestModule.authority_is_satisfiable(case)
   681	    if case.current_status == ApprovalCase.STATUS_BLOCKED_CONFLICT:
   682	        return (
   683	            not satisfiable
   684	            and case.closed_at is not None
   685	            and case.conflict_block_reason
   686	            == ConflictOfInterestModule.authority_gap_reason(case)
   687	        )
   688	    return satisfiable and not case.conflict_block_reason
