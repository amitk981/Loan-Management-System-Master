    22	export async function staffLogin(page: Page, email: string, password: string): Promise<void> {
    23	  await page.goto('/');
    24	  await expect(page.getByRole('heading', { name: 'Sign in to your account' })).toBeVisible();
    25	  await page.getByPlaceholder('you@sfpcl.in').fill(email);
    26	  await page.locator('input[type="password"]').fill(password);
    27	  await page.getByRole('button', { name: 'Sign in' }).click();
