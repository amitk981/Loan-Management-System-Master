   320	            f"Created successor template version {template.template_version}."
   321	            if template.supersedes_id
   322	            else f"Created template version {template.template_version}."
   323	        ),
   324	        author_user=actor,
   325	        approver_user=(
   326	            actor if template.approval_status == DocumentTemplate.STATUS_APPROVED else None
   327	        ),
   328	        old_value_json=old_value,
   329	        new_value_json=new_value,
   330	        effective_from=template.effective_from,
   331	        effective_to=template.effective_to,
   332	    )
