    19	def list_document_templates(query_params):
    20	    """Shape the strict, bounded document-template catalogue query."""
    21	    unknown = set(query_params.keys()) - _LIST_PARAMS
    22	    if unknown:
    23	        raise ValidationError(
    24	            {key: "Unknown query parameter." for key in sorted(unknown)}
    25	        )
    26	    queryset = DocumentTemplate.objects.select_related("template_file")
    27	    for field in ("document_type", "approval_status"):
    28	        value = query_params.get(field)
    29	        if value:
    30	            if (
    31	                field == "approval_status"
    32	                and value not in DocumentTemplate.APPROVAL_STATUSES
    33	            ):
    34	                raise ValidationError(
    35	                    {"approval_status": "Must be one of draft, approved, retired."}
    36	                )
    37	            queryset = queryset.filter(**{field: value})
    38	    if "borrower_type" in query_params:
    39	        value = query_params.get("borrower_type")
    40	        if value in ("", "null"):
    41	            queryset = queryset.filter(borrower_type__isnull=True)
    42	        elif value not in DocumentTemplate.BORROWER_TYPES:
    43	            raise ValidationError(
    44	                {"borrower_type": "Must be individual_farmer, fpc, fpo, or null."}
    45	            )
    46	        else:
    47	            queryset = queryset.filter(borrower_type=value)
    48	    page = _positive_int("page", query_params.get("page"), 1)
    49	    page_size = min(
    50	        _positive_int("page_size", query_params.get("page_size"), _DEFAULT_PAGE_SIZE),
    51	        _MAX_PAGE_SIZE,
    52	    )
    53	    total_count = queryset.count()
    54	    total_pages = ceil(total_count / page_size) if total_count else 1
    55	    page = min(page, total_pages)
    56	    offset = (page - 1) * page_size
    57	    return list(queryset[offset : offset + page_size]), {
    58	        "page": page,
    59	        "page_size": page_size,
    60	        "total_count": total_count,
    61	        "total_pages": total_pages,
    62	        "has_next": page < total_pages,
    63	        "has_previous": page > 1,
    64	    }
    65	
    66	
    67	def _positive_int(field, value, default):
    68	    if value in (None, ""):
    69	        return default
    70	    try:
    71	        parsed = int(value)
    72	    except (TypeError, ValueError) as exc:
    73	        raise ValidationError({field: "Must be a positive integer."}) from exc
    74	    if parsed <= 0:
    75	        raise ValidationError({field: "Must be a positive integer."})
    76	    return parsed
