    97	        >
    98	          <option value="">All decisions</option>
    99	          <option value="sanctioned">Sanctioned</option>
   100	          <option value="rejected">Rejected</option>
   101	        </select>
   102	      </div>
   103	
   104	      {state === 'error' ? (
   105	        <AlertBanner type="error" title="Credit sanction register unavailable" message={message} />
   106	      ) : (
   107	        <div className="card p-0 overflow-hidden">
   108	          <div className="p-4 bg-slate-50 border-b border-slate-200">
   109	            <p className="text-sm font-semibold text-slate-900 flex items-center gap-2">
   110	              <Gavel size={14} className="text-green-600" /> Credit sanction register
   111	            </p>
   112	            <p className="text-xs text-slate-500 mt-0.5">
