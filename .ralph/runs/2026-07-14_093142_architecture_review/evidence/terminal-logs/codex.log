   277	def _lock_identity(cleaned):
   278	    borrower_variant_key = (
   279	        cleaned["borrower_type"] or DocumentTemplateIdentity.GLOBAL_VARIANT_KEY
   280	    )
   281	    identity, _ = DocumentTemplateIdentity.objects.get_or_create(
   282	        document_type=cleaned["document_type"],
   283	        borrower_variant_key=borrower_variant_key,
   284	    )
   285	    DocumentTemplateIdentity.objects.select_for_update().get(pk=identity.pk)
   286	
