   385	def _minimal_pdf(text):
   386	    escaped = text.replace("\\", "\\\\").replace("(", "\\(").replace(")", "\\)")
   387	    escaped = escaped.replace("\n", ") Tj 0 -16 Td (")
   388	    stream = f"BT /F1 11 Tf 72 760 Td ({escaped}) Tj ET".encode("utf-8")
   389	    objects = [
   390	        b"<< /Type /Catalog /Pages 2 0 R >>",
   391	        b"<< /Type /Pages /Kids [3 0 R] /Count 1 >>",
   392	        b"<< /Type /Page /Parent 2 0 R /MediaBox [0 0 612 792] /Resources << /Font << /F1 5 0 R >> >> /Contents 4 0 R >>",
   393	        b"<< /Length " + str(len(stream)).encode() + b" >>\nstream\n" + stream + b"\nendstream",
   394	        b"<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>",
   395	    ]
   396	    output = io.BytesIO(b"%PDF-1.4\n")
   397	    offsets = [0]
   398	    for index, obj in enumerate(objects, 1):
   399	        offsets.append(output.tell())
   400	        output.write(f"{index} 0 obj\n".encode() + obj + b"\nendobj\n")
   401	    xref = output.tell()
   402	    output.write(f"xref\n0 {len(objects) + 1}\n".encode())
   403	    output.write(b"0000000000 65535 f \n")
   404	    for offset in offsets[1:]:
   405	        output.write(f"{offset:010d} 00000 n \n".encode())
   406	    output.write(f"trailer << /Size {len(objects) + 1} /Root 1 0 R >>\nstartxref\n{xref}\n%%EOF".encode())
   407	    return output.getvalue()
   408	
