   234	def _resolve_template_file(actor, cleaned):
   235	    template_file_id = cleaned.pop("template_file_id")
   236	    if template_file_id is None:
   237	        cleaned["template_file"] = None
   238	        return
   239	    permissions = auth_service.effective_permission_codes(actor)
   240	    cleaned["template_file"] = document_services.resolve_template_source_reference(
   241	        actor_permissions=permissions,
   242	        document_id=template_file_id,
   243	    )
