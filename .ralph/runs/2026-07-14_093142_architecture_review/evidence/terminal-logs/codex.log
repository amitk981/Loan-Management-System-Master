     8	_DEFAULT_PAGE_SIZE = 20
     9	_MAX_PAGE_SIZE = 100
    10	_LIST_PARAMS = {
    11	    "page",
    12	    "page_size",
    13	    "document_type",
    14	    "borrower_type",
    15	    "approval_status",
    16	}
