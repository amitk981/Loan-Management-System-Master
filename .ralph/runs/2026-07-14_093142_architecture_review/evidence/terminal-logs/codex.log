   677	            actor = User.objects.get(pk=actor_id)
   678	            barrier.wait()
   679	            result = document_generation.generate(
   680	                actor=actor,
   681	                application_id=application_id,
   682	                payload=payload,
   683	                metadata=document_generation.RequestMetadata(
   684	                    request_id=f"req-race-{index}", ip_address="127.0.0.1", user_agent="test"
   685	                ),
   686	            )
   687	            close_old_connections()
   688	            return result
   689	
   690	        with ThreadPoolExecutor(max_workers=5) as pool:
   691	            results = list(pool.map(generate, range(5)))
   692	
   693	        self.assertEqual(len({row["loan_document_id"] for row in results}), 1)
   694	        from sfpcl_credit.documents.models import LoanDocument
