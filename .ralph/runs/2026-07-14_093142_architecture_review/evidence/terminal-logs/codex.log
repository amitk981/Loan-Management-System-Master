   364	def _replace_placeholders(source_text, fields):
   365	    merged = source_text
   366	    missing = {}
   367	    for field, value in fields.items():
   368	        pattern = re.compile(r"{{\s*" + re.escape(field) + r"\s*}}")
   369	        merged, replacements = pattern.subn(str(value), merged)
   370	        if replacements == 0:
   371	            missing[field] = "Declared merge field is absent from the retained template body."
   372	    if missing:
   373	        raise ValidationError(missing)
   374	    return merged
