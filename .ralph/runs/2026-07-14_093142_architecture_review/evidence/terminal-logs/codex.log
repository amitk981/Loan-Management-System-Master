   195	def resolve_template_source_reference(*, actor_permissions, document_id):
   196	    """Return a globally uploaded template source only with explicit reference authority."""
   197	    permissions = set(actor_permissions)
   198	    document = DocumentFile.objects.filter(document_id=document_id).first()
   199	    audits = list(
   200	        AuditLog.objects.filter(
   201	            action=DOCUMENT_UPLOAD_AUDIT_ACTION,
   202	            entity_type="document_file",
   203	            entity_id=document_id,
   204	        )
   205	        .order_by("-created_at", "-audit_log_id")
   206	        [:2]
   207	    )
   208	    audit = audits[0] if len(audits) == 1 else None
   209	    metadata = audit.new_value_json if audit and audit.new_value_json else {}
   210	    metadata_matches = bool(
   211	        document
   212	        and audit
   213	        and audit.actor_user_id == document.uploaded_by_user_id
   214	        and metadata.get("document_id") == str(document.document_id)
   215	        and metadata.get("file_name") == document.file_name
   216	        and metadata.get("file_extension") == document.file_extension
   217	        and metadata.get("mime_type") == document.mime_type
   218	        and metadata.get("file_size_bytes") == document.file_size_bytes
   219	        and metadata.get("storage_provider") == document.storage_provider
   220	        and metadata.get("storage_key") == document.storage_key
   221	        and metadata.get("checksum_sha256") == document.checksum_sha256
   222	        and metadata.get("sensitivity_level") == document.sensitivity_level
   223	        and metadata.get("document_category") == TEMPLATE_SOURCE_CATEGORY
   224	        and metadata.get("related_entity_type") == TEMPLATE_SOURCE_ENTITY_TYPE
   225	        and metadata.get("related_entity_id") is None
   226	        and document.sensitivity_level in ALLOWED_SENSITIVITY_LEVELS
   227	    )
   228	    if TEMPLATE_FILE_REFERENCE_PERMISSION not in permissions or not metadata_matches:
   229	        raise ValidationError({"template_file_id": _INACCESSIBLE_REFERENCE_MESSAGE})
   230	    return document
   231	
   232	
   233	def validate_upload_request(request):
   234	    field_errors = {}
   235	    uploaded_file = request.FILES.get("file")
   236	    document_category = (request.POST.get("document_category") or "").strip()
   237	    raw_sensitivity = (request.POST.get("sensitivity_level") or "").strip()
   238	    related_entity_type = (request.POST.get("related_entity_type") or "").strip()
   239	    raw_related_entity_id = (request.POST.get("related_entity_id") or "").strip()
   240	
   241	    if uploaded_file is None:
   242	        field_errors["file"] = "This field is required."
   243	    if not document_category:
   244	        field_errors["document_category"] = "This field is required."
   245	    if not raw_sensitivity:
   246	        field_errors["sensitivity_level"] = "This field is required."
   247	
   248	    sensitivity_level = raw_sensitivity.lower()
   249	    if raw_sensitivity and sensitivity_level not in ALLOWED_SENSITIVITY_LEVELS:
   250	        field_errors["sensitivity_level"] = (
   251	            "Must be one of public, internal, confidential, restricted."
   252	        )
   253	
   254	    related_entity_id = None
   255	    if raw_related_entity_id:
   256	        try:
   257	            related_entity_id = uuid.UUID(raw_related_entity_id)
   258	        except ValueError:
   259	            field_errors["related_entity_id"] = "Must be a valid UUID."
   260	
   261	    if field_errors:
   262	        raise ValidationError(field_errors)
   263	
   264	    return {
   265	        "file": uploaded_file,
   266	        "document_category": document_category,
   267	        "sensitivity_level": sensitivity_level,
   268	        "related_entity_type": related_entity_type or None,
   269	        "related_entity_id": related_entity_id,
   270	    }
   271	
   272	
   273	def serialize_document_file(document):
   274	    return {
   275	        "document_id": str(document.document_id),
   276	        "file_name": document.file_name,
   277	        "mime_type": document.mime_type,
   278	        "file_size_bytes": document.file_size_bytes,
   279	        "sensitivity_level": document.sensitivity_level,
   280	        "uploaded_at": document.uploaded_at.isoformat().replace("+00:00", "Z"),
   281	    }
   282	
   283	
   284	def validation_field_errors(exc):
   285	    if hasattr(exc, "message_dict"):
   286	        return {field: messages[0] for field, messages in exc.message_dict.items()}
   287	    return {"non_field_errors": str(exc)}
