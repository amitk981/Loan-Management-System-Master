   110	def create_successor(*, actor, metadata, document_template_id, payload):
   111	    cleaned = _validate_payload(payload)
   112	    _resolve_template_file(actor, cleaned)
   113	    with transaction.atomic():
   114	        _lock_identity(cleaned)
   115	        source = (
   116	            DocumentTemplate.objects.select_for_update(of=("self",))
   117	            .select_related("template_file")
   118	            .get(document_template_id=document_template_id)
   119	        )
   120	        if (
   121	            source.document_type != cleaned["document_type"]
   122	            or source.borrower_type != cleaned["borrower_type"]
   123	        ):
   124	            raise ValidationError(
   125	                {
   126	                    "non_field_errors": (
   127	                        "A successor must retain its document type and borrower variant."
   128	                    )
   129	                }
   130	            )
   131	        replay = _exact_match(cleaned, supersedes=source)
   132	        if replay is not None:
   133	            return serialize(replay)
   134	        if DocumentTemplate.objects.filter(supersedes=source).exists():
   135	            raise ValidationError(
   136	                {"non_field_errors": "This template version already has a successor."}
   137	            )
   138	        _validate_unique_and_effective(cleaned)
   139	        template = DocumentTemplate.objects.create(**cleaned, supersedes=source)
   140	        _record_evidence(
   141	            actor=actor,
   142	            metadata=metadata,
   143	            action=SUCCESSOR_ACTION,
   144	            template=template,
   145	            old_value=serialize(source),
   146	        )
   147	        return serialize(template)
