   651	def _exclusion_snapshot_is_coherent(exclusions, committee):
   652	    committee_ids = {
   653	        str(committee.get("cfo_user_id") or ""),
   654	        *(
   655	            str(user_id)
   656	            for user_id in committee.get("director_user_ids", [])
   657	            if user_id
   658	        ),
   659	    } - {""}
   660	    seen = set()
   661	    for item in exclusions:
   662	        if not isinstance(item, dict):
   663	            return False
   664	        user_id = str(item.get("user_id") or "")
   665	        if (
   666	            not user_id
   667	            or user_id not in committee_ids
   668	            or user_id in seen
   669	            or not isinstance(item.get("reason"), str)
   670	            or not item["reason"].strip()
   671	            or not isinstance(item.get("conflict_code"), str)
   672	            or not item["conflict_code"].strip()
   673	        ):
   674	            return False
   675	        seen.add(user_id)
   676	    return True
