   337	def _merge_docx_template(template_source, fields):
   338	    source = io.BytesIO(template_source)
   339	    output = io.BytesIO()
   340	    with zipfile.ZipFile(source) as input_archive, zipfile.ZipFile(
   341	        output, "w", zipfile.ZIP_DEFLATED
   342	    ) as output_archive:
   343	        names = input_archive.namelist()
   344	        if "word/document.xml" not in names:
   345	            raise ValidationError(
   346	                {"template_file_id": "Word template has no document body."}
   347	            )
   348	        document_xml = input_archive.read("word/document.xml").decode("utf-8")
   349	        merged_xml = _replace_placeholders(
   350	            document_xml,
   351	            {key: _xml_escape(str(value)) for key, value in fields.items()},
   352	        )
   353	        for name in names:
   354	            output_archive.writestr(
   355	                name,
   356	                merged_xml.encode("utf-8")
   357	                if name == "word/document.xml"
   358	                else input_archive.read(name),
   359	            )
   360	    text = html.unescape(re.sub(r"<[^>]+>", " ", merged_xml))
   361	    return output.getvalue(), re.sub(r"\s+", " ", text).strip()
