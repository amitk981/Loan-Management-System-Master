  {
    echo "# Diff Limits Results"
    echo
    echo "- Files changed (excluding .ralph/): $files_changed (limit $max_files)"
    echo "- Lines changed (tracked + new files, excluding .ralph/): $total_lines (limit $max_lines)"
  } > "$dl_file"
  if (( files_changed > max_files )); then
