    failures=$((failures + 1))
  fi
  if (( total_lines > max_lines )); then
    echo "- FAIL: changed-line count exceeds limits.max_lines_changed." >> "$dl_file"
    failures=$((failures + 1))
  fi
  if (( files_changed <= max_files && total_lines <= max_lines )); then
    echo "- PASS: within diff limits." >> "$dl_file"
  fi
fi

