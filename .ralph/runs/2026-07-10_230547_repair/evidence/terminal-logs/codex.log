  max_files="$(awk -F': *' '/^[[:space:]]*max_changed_files:/ {sub(/[[:space:]]*#.*$/, "", $2); print $2; exit}' "$config" | xargs || true)"
  max_lines="$(awk -F': *' '/^[[:space:]]*max_lines_changed:/ {sub(/[[:space:]]*#.*$/, "", $2); print $2; exit}' "$config" | xargs || true)"
  max_files="${max_files:-30}"
