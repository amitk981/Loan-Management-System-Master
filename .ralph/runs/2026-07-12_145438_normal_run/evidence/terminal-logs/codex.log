+                            "individual_profile": {"first_name": "Race", "last_name": f"Member {suffix}"},
+                        },
+                        thread_actor,
+                    )
+                    return ("success", str(member.member_id))
+                except ValidationError as exc:
+                    return ("validation", services.validation_field_errors(exc))
+            finally:
