+                    "required_role": None,
+                },
+            )
+            with self.assertRaises(PermissionDenied) as rejected:
+                MemberRegistry.approve_identity_change(
+                    change.identity_change_request_id, checker
+                )
+
+        self.assertEqual(str(rejected.exception), action["disabled_reason"])
+        self.assertEqual(
