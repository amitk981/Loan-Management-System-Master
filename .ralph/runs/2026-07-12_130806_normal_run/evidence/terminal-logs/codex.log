diff --git a/sfpcl_credit/tests/test_sanction_submission_api.py b/sfpcl_credit/tests/test_sanction_submission_api.py
index d34ae6cb533f0ab51edc6a8e3d8af760b5391c27..4128111c91b83e1a63139f10975cb107c66dceb3
--- a/sfpcl_credit/tests/test_sanction_submission_api.py
