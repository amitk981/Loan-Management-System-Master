+        ):
+            SanctionHandoffModule().submit_reviewed_appraisal(
+                actor=self.reviewer,
+                application_id=self.application.pk,
+                payload={"remarks": "Write from stale enabled projection."},
+                request_meta={"request_id": "projection-race-loser"},
+            )
+
