+        )
+        self.assertTrue(sanction_action["enabled"])
+
+        def competing_submit():
+            close_old_connections()
+            try:
+                actor = User.objects.get(pk=self.reviewer.pk)
+                return SanctionHandoffModule().submit_reviewed_appraisal(
