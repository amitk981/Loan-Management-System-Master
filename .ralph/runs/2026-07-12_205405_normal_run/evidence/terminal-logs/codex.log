+        actor,
+        permission_code,
+        actor_permissions,
+    )
+    if object_access.allowed or object_access.error_code != "OBJECT_ACCESS_DENIED":
+        return action
+    return {
+        **action,
+        "enabled": False,
+        "disabled_reason": "You do not have access to this loan application.",
+    }
