                    "reapply_allowed_flag",
                    "communication_mode",
                }
            )
        unknown = sorted(set(payload) - allowed_fields)
        errors.update({field: "Unknown field." for field in unknown})
        if decision not in {"reviewed", "returned", "rejected"}:

