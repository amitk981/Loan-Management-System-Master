from io import BytesIO
from reportlab.lib.enums import TA_LEFT
from reportlab.lib.pagesizes import A4
from reportlab.lib.styles import ParagraphStyle
from reportlab.lib.units import mm
from reportlab.pdfbase import pdfmetrics
from reportlab.pdfbase.ttfonts import TTFont
from reportlab.platypus import Paragraph, SimpleDocTemplate
from pypdf import PdfReader

font_path = '/System/Library/Fonts/Supplemental/Devanagari Sangam MN.ttc'
pdfmetrics.registerFont(TTFont('ProbeComplete', font_path))
value = 'कृषक ₹ ' + ('seasonal-crop-borrower ' * 500)
output = BytesIO()
doc = SimpleDocTemplate(output, pagesize=A4, rightMargin=20*mm, leftMargin=20*mm, topMargin=20*mm, bottomMargin=20*mm)
style = ParagraphStyle('Probe', fontName='ProbeComplete', fontSize=10, leading=14, alignment=TA_LEFT, shaping=True, splitLongWords=True, allowWidows=0, allowOrphans=0)
doc.build([Paragraph(value, style)])
reader = PdfReader(BytesIO(output.getvalue()), strict=True)
text = '\\n'.join(page.extract_text(extraction_mode='layout') or '' for page in reader.pages)
normalized = ' '.join(text.split())
expected = ' '.join(value.split())
print({'pages': len(reader.pages), 'count': normalized.count('seasonal-crop-borrower'), 'contains': expected in normalized, 'prefix': normalized[:60], 'rupee': '₹' in normalized, 'devanagari': 'कृषक' in normalized})
if expected not in normalized:
    for index, (left, right) in enumerate(zip(expected, normalized)):
        if left "'!= right:
            print('"'first_diff', index, repr(expected[index:index+80]), repr(normalized[index:index+80]))
            break
