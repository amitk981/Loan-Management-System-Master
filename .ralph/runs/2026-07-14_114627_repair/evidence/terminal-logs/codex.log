from io import BytesIO
from reportlab.lib.pagesizes import A4
from reportlab.lib.styles import ParagraphStyle
from reportlab.pdfbase import pdfmetrics
from reportlab.pdfbase.ttfonts import TTFont
from reportlab.platypus import Paragraph, SimpleDocTemplate
from pypdf import PdfReader

pdfmetrics.registerFont(TTFont('PrimaryArialUnicode', '/System/Library/Fonts/Supplemental/Arial Unicode.ttf'))
pdfmetrics.registerFont(TTFont('FallbackDevanagari', '/System/Library/Fonts/Supplemental/Devanagari Sangam MN.ttc'))
for markup in (
    'कृषक <font name=\"FallbackDevanagari\">₹</font>',
    'Document Borrower – कृषक &amp; Sons \\\\ Cooperative Amount (<font name=\"FallbackDevanagari\">₹</font>)',
):
    output=BytesIO(); SimpleDocTemplate(output,pagesize=A4).build([Paragraph(markup, ParagraphStyle('P',fontName='PrimaryArialUnicode',shaping=True))])
    page=PdfReader(BytesIO(output.getvalue())).pages[0]
    print('plain', repr(page.extract_text()))
    print('layout', repr(page.extract_text(extraction_mode='layout')))
