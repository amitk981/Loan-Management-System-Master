+                    )
+                }
             )
-        }
-    )
+        escaped = escape(token)
+        if font is primary_font:
+            markup.append(escaped)
+        else:
+            markup.append(f'<font name="{font.fontName}">{escaped}</font>')
+    return "".join(markup)
 
 
