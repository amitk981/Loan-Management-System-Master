+def validate_portal_session_authority(session):
+    account = (
+        PortalAccount.objects.select_related("member")
+        .filter(user=session.user)
+        .first()
+    )
+    if account is None:
+        return None
+    if account.status != PortalAccount.STATUS_ACTIVE or account.member.is_deleted:
