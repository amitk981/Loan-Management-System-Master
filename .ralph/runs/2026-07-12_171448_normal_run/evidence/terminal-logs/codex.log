+  await expect(page.getByRole('button', { name: 'Approve identity change' })).toHaveCount(0);
+  await capture(page, 'member-identity-requester-denied.png');
+
+  await signOut(page);
+  await staffLogin(page, MANAGER_EMAIL, E2E_PASSWORD);
