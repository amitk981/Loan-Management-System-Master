+                ('loan_application', models.OneToOneField(on_delete=django.db.models.deletion.PROTECT, related_name='loan_request_register_entry', to='applications.loanapplication')),
+                ('member', models.ForeignKey(on_delete=django.db.models.deletion.PROTECT, related_name='loan_request_register_entries', to='members.member')),
+                ('received_by_user', models.ForeignKey(on_delete=django.db.models.deletion.PROTECT, related_name='received_loan_request_register_entries', to='identity.user')),
+            ],
+            options={
+                'db_table': 'loan_request_register_entries',
+                'indexes': [models.Index(fields=['register_status', 'current_stage'], name='idx_lrr_status_stage'), models.Index(fields=['date_received'], name='idx_lrr_date_received'), models.Index(fields=['reference_generated_date'], name='idx_lrr_ref_gen_date')],
+            },
+        ),
+    ]
