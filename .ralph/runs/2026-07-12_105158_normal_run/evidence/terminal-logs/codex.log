            data=self._payload(),
            content_type="application/json",
            headers=self._headers(),
        )
        other_application = LoanApplication.objects.create(
            member=self.member,
            borrower_type=self.member.member_type,
            received_by_user=self.user,
            created_by_user=self.user,
        )
