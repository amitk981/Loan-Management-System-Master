const normalizeKycProfile = (profile: KycProfileDetail): KycProfileDetail => ({
  kyc_profile_id: String(profile?.kyc_profile_id ?? ''),
  party_type: String(profile?.party_type ?? ''),
  party_id: String(profile?.party_id ?? ''),
