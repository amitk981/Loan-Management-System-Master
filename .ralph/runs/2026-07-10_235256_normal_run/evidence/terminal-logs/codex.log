+    def _headers(self):
+        return self._headers_for("witness.creator@sfpcl.example", "CreatorPass123!")
+
+    def _headers_for(self, email, password):
+        response = self.client.post(
+            "/api/v1/auth/login/",
+            data={
+                "email": email,
+                "password": password,
+            },
+            content_type="application/json",
