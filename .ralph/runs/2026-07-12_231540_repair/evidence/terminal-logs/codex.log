   122	function identities(prefix: string, suffix: string, panPrefix: string) {
   123	  const pan = `${panPrefix}BCDE${suffix}F`;
   124	  const aadhaar = `12345678${suffix}`;
   125	  const legalName = prefix === 'IND' ? 'Complete Synthetic Farmer' : prefix === 'INS' ? 'Complete Synthetic FPC' : 'Complete Synthetic Producer Institution';
   126	  const common = {
   127	    member_type: prefix === 'IND' ? 'individual_farmer' : prefix === 'INS' ? 'fpc' : 'producer_institution', legal_name: legalName,
   128	    display_name: legalName, folio_number: `${prefix}-${Date.now()}-${suffix}`,
   129	    membership_start_date: '2024-04-01', pan, registered_address: {
   130	      line1: 'Synthetic Registry Road', line2: 'Evidence Block', village_city: 'Nashik',
   131	      district: 'Nashik', state: 'Maharashtra', pincode: '422001',
   132	    }, mobile_number: `+91910000${suffix}`, email: `${prefix.toLowerCase()}.${Date.now()}@example.test`,
   133	  };
   134	  const body = prefix === 'IND' ? { ...common, aadhaar, individual_profile: {
   135	    first_name: 'Complete', middle_name: 'Synthetic', last_name: 'Farmer', gender: 'female',
   136	    date_of_birth: '1980-01-15', occupation: 'Farmer', land_area_under_cultivation_acres: '5.25',
   137	    primary_crop: 'grapes', services_availed_flag: true, employment_or_service_years: '7',
   138	  } } : { ...common, producer_institution_profile: {
   139	    institution_type: 'farmer_producer_company', registration_number: `REG-${suffix}`,
   140	    authorised_signatory_name: 'Synthetic Signatory', authorised_signatory_pan: `ZBCDE${suffix}Y`,
   141	    authorised_signatory_aadhaar: `87654321${suffix}`, board_resolution_required_flag: true,
   142	    services_availed_flag: true, produce_supply_years: '6',
   143	  } };
   144	  return { pan, aadhaar, body };
   145	}
   146	
   147	async function registerIndividual(page: Page, fixture: ReturnType<typeof identities>) {
   148	  await startRegistration(page);
   149	  await fillCommon(page, fixture.body as Record<string, unknown>);
   150	  const profile = fixture.body.individual_profile as Record<string, string | boolean>;
   151	  for (const [label, key] of [['First Name', 'first_name'], ['Middle Name', 'middle_name'], ['Last Name', 'last_name'], ['Gender', 'gender'], ['Occupation', 'occupation'], ['Cultivation Area (acres)', 'land_area_under_cultivation_acres'], ['Primary Crop', 'primary_crop'], ['Employment / Service Years', 'employment_or_service_years']] as const) await page.getByLabel(label).fill(String(profile[key]));
   152	  await page.getByLabel('Date of Birth').fill(String(profile.date_of_birth));
   153	  await page.getByLabel('Services Availed').fill('true');
   154	  await page.getByLabel('Aadhaar').fill(fixture.aadhaar);
   155	  await saveMember(page, String(fixture.body.legal_name));
   156	}
   157	
   158	async function registerInstitution(page: Page, fixture: ReturnType<typeof identities>) {
   159	  await startRegistration(page);
   160	  await page.getByLabel('Member Type').selectOption(String(fixture.body.member_type));
   161	  await fillCommon(page, fixture.body as Record<string, unknown>);
   162	  const profile = fixture.body.producer_institution_profile as Record<string, string | boolean>;
   163	  for (const [label, key] of [['Institution Type', 'institution_type'], ['Registration Number', 'registration_number'], ['Authorised Signatory', 'authorised_signatory_name'], ['Signatory PAN', 'authorised_signatory_pan'], ['Signatory Aadhaar', 'authorised_signatory_aadhaar'], ['Produce Supply Years', 'produce_supply_years']] as const) await page.getByLabel(label).fill(String(profile[key]));
   164	  await page.getByLabel('Board Resolution Required').fill('true');
   165	  await page.getByLabel('Services Availed').fill('true');
   166	  await saveMember(page, String(fixture.body.legal_name));
   167	}
   168	
   169	async function startRegistration(page: Page) { await page.getByRole('button', { name: 'Register Member' }).click(); }
   170	async function fillCommon(page: Page, body: Record<string, unknown>) {
   171	  const address = body.registered_address as Record<string, string>;
   172	  for (const [label, key] of [['Legal Name', 'legal_name'], ['Display Name', 'display_name'], ['Folio Number', 'folio_number'], ['Membership Start Date', 'membership_start_date'], ['Mobile Number', 'mobile_number'], ['Email', 'email'], ['PAN', 'pan']] as const) await page.getByLabel(label, { exact: true }).fill(String(body[key]));
   173	  for (const [label, key] of [['Address Line 1', 'line1'], ['Address Line 2', 'line2'], ['Village / City', 'village_city'], ['District', 'district'], ['State', 'state'], ['Pincode', 'pincode']] as const) await page.getByLabel(label).fill(address[key]);
   174	}
   175	async function saveMember(page: Page, legalName: string) {
   176	  const saved = page.waitForResponse(response => response.request().method() === 'POST' && new URL(response.url()).pathname === '/api/v1/members/');
   177	  await page.getByRole('button', { name: 'Save member' }).click();
   178	  expect((await saved).status()).toBe(200);
   179	  await expect(page.getByRole('heading', { name: legalName })).toBeVisible();
   180	}
   181	async function openMembers(page: Page) {
   182	  await page.getByRole('button', { name: 'Members & Borrowers' }).click();
   183	  await expect(page.getByRole('heading', { name: 'Member Directory' })).toBeVisible();
   184	}
   185	async function openSeededVerifiedMember(page: Page) {
   186	  await openMembers(page);
   187	  await page.getByPlaceholder('Search by name or folio...').fill('Epic 006 Browser Member');
   188	  await page.getByRole('row').filter({ hasText: 'Epic 006 Browser Member' }).getByRole('button', { name: 'Profile' }).click();
   189	  await expect(page.getByRole('heading', { name: 'Epic 006 Browser Member' })).toBeVisible();
   190	}
   191	async function signOut(page: Page) {
   192	  await page.getByRole('button', { name: new RegExp(`^${FINANCE_NAME}`) }).click();
   193	  await page.getByRole('button', { name: 'Sign out' }).click();
   194	  await expect(page.getByRole('heading', { name: 'Sign in to your account' })).toBeVisible();
   195	}
   196	const projectedApproval = (page: Page) => page.locator('button.btn-secondary', { hasText: /^Approve identity change$/ });
   197	const maskPan = (pan: string) => `******${pan.slice(-4)}`;
   198	const maskAadhaar = (aadhaar: string) => `********${aadhaar.slice(-4)}`;
   199	const capture = (page: Page, name: string) => page.screenshot({ path: path.join(evidenceDir, name), fullPage: true, animations: 'disabled' });
   200	function nextRunSuffix() {
   201	  const counterPath = path.join(evidenceDir!, '.member-governance-run-counter');
   202	  const prior = fs.existsSync(counterPath) ? Number(fs.readFileSync(counterPath, 'utf8')) : 0;
   203	  const next = prior + 1;
   204	  if (next > 9999) throw new Error('Member governance run counter exhausted');
   205	  fs.writeFileSync(counterPath, String(next), 'utf8');
   206	  return String(next).padStart(4, '0');
   207	}
