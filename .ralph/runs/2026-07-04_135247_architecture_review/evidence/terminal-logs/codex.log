import { test, expect } from '@playwright/test';
import { E2E_PASSWORD, TRACER_EMAIL, ZERO_EMAIL, staffLogin } from './helpers';

const STAFF_NAV_LABELS = [
  'Task Inbox',
  'Applications',
  'Completeness',
  'Members & Borrowers',
  'Appraisal',
  'Sanction',
  'Documentation',
  'SAP & Disbursement',
  'Payment Authorisation',
  'Interest Management',
  'Loan Accounts',
  'Repayments',
  'Monitoring',
  'Default & Recovery',
  'Closure & Archive',
