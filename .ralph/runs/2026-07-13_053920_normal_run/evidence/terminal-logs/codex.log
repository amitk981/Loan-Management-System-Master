+        row = ApprovalMatrixRule.objects.create(**cleaned, status=ApprovalMatrixRule.STATUS_ACTIVE)
+        entity_type, after = "approval_matrix_rule", serialize_rule(row)
+    else:
+        cleaned = _validate_committee(proposal.payload_json)
