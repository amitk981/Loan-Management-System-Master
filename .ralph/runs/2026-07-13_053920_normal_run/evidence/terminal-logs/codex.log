+            old.effective_to = cleaned["effective_from"] - timedelta(days=1)
+            old.save(update_fields=["status", "effective_to"])
+        row = ApprovalMatrixRule.objects.create(**cleaned, status=ApprovalMatrixRule.STATUS_ACTIVE)
