    def test_staff_token_cannot_call_portal_application_apis(self):
        token = self._staff_token()
        for method, path in (
            ("get", "/api/v1/portal/applications/"),
            ("post", "/api/v1/portal/applications/"),
            ("get", f"/api/v1/portal/applications/{uuid4()}/"),
