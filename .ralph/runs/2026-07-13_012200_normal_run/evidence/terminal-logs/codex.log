+                    decision="active", reason="Concurrent evidence review.", version=version,
+                    as_of_date=as_of,
+                )
+                return "verify_won"
+            except ActiveMemberStatusConflict as exc:
+                return exc.code
+            finally:
+                close_old_connections()
+
+        def mutate():
+            close_old_connections()
+            gate.wait()
+            try:
+                mutation(version)
