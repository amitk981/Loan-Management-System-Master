+            int("verify_won" in outcomes),
+        )
+        self.assertEqual(
+            MemberChangeHistory.objects.filter(change_type="active_status_verified").count(),
+            int("verify_won" in outcomes),
+        )
+        self.assertEqual(WorkflowEvent.objects.count(), 0)
