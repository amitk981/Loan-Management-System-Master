class ActiveMemberStatusModuleTests(TestCase):
    def setUp(self):
        role = Role.objects.create(
            role_code="active_module_maker",
            role_name="Active Module Maker",
            status="active",
        )
        self.actor = User.objects.create(
            full_name="Synthetic Supply Maker",
