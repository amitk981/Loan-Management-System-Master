+            entity_id=assessment.loan_limit_assessment_id,
+        ).latest("created_at")
+        audit_projection = dict(final_audit.new_value_json)
+        self.assertEqual(audit_projection.pop("request_id"), "concurrency-second")
+        final_projection = dict(final)
