+    @classmethod
+    def _credit_boundary_violations(cls, source):
+        references = cls._resolved_import_references(ast.parse(source))
+        violations = set()
+        concrete_assessments = {
+            "sfpcl_credit.credit.models.EligibilityAssessment",
