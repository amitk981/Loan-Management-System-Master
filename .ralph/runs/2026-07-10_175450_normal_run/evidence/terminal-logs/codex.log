+        release_first = Event()
+        second_payload_entered = Event()
+        ordering = []
+        ordering_lock = Lock()
+
+        def record(step):
+            with ordering_lock:
+                ordering.append(step)
+
+        def first_payload():
+            record("first_locked_application")
+            first_locked.wait(timeout=10)
