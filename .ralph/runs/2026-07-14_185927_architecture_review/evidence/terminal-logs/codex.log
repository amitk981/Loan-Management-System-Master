   233	def resolve_immutable_upload_provenance(*, document_id):
   234	    """Return exact immutable upload facts without making workflow-policy decisions."""
   235	    document = DocumentFile.objects.filter(document_id=document_id).first()
   236	    audits = list(
   237	        AuditLog.objects.filter(
   238	            action=DOCUMENT_UPLOAD_AUDIT_ACTION,
   239	            entity_type="document_file",
   240	            entity_id=document_id,
   241	        ).order_by("-created_at", "-audit_log_id")[:2]
   242	    )
   243	    audit = audits[0] if len(audits) == 1 else None
   244	    metadata = audit.new_value_json if audit and audit.new_value_json else {}
   245	    related_entity_id = None
   246	    raw_related_entity_id = metadata.get("related_entity_id")
   247	    if raw_related_entity_id is not None:
   248	        try:
   249	            related_entity_id = uuid.UUID(str(raw_related_entity_id))
   250	        except (TypeError, ValueError, AttributeError):
   251	            related_entity_id = None
   252	    valid = bool(
   253	        document
   254	        and audit
   255	        and audit.actor_user_id == document.uploaded_by_user_id
   256	        and metadata.get("document_id") == str(document.pk)
   257	        and metadata.get("file_name") == document.file_name
   258	        and metadata.get("file_extension") == document.file_extension
   259	        and metadata.get("mime_type") == document.mime_type
   260	        and metadata.get("file_size_bytes") == document.file_size_bytes
   261	        and metadata.get("storage_provider") == document.storage_provider
   262	        and metadata.get("storage_key") == document.storage_key
   263	        and metadata.get("checksum_sha256") == document.checksum_sha256
   264	        and metadata.get("sensitivity_level") == document.sensitivity_level
   265	        and isinstance(metadata.get("document_category"), str)
   266	        and bool(metadata.get("document_category"))
   267	        and (raw_related_entity_id is None or related_entity_id is not None)
   268	        and document.sensitivity_level in ALLOWED_SENSITIVITY_LEVELS
   269	    )
   270	    if not valid:
   271	        raise ValidationError({"document_id": _INACCESSIBLE_REFERENCE_MESSAGE})
   272	    return ImmutableUploadProvenance(
   273	        document=document,
   274	        document_category=metadata["document_category"],
   275	        related_entity_type=metadata.get("related_entity_type"),
   276	        related_entity_id=related_entity_id,
   277	    )
