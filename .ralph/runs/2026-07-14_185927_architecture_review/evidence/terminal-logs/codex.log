   171	def resolve_mismatch(*, actor, signature_record_id, payload, metadata):
   172	    document_authority.require_mutation_actor(actor=actor, permission=RESOLVE_PERMISSION)
   173	    try:
   174	        document_authority.require_company_secretary(actor)
   175	    except document_authority.RoleAuthorityDenied:
   176	        raise AccessDenied
   177	    cleaned = _validate_resolution(payload)
   178	    with transaction.atomic():
   179	        signature_record = document_authority.resolve_current_stage4_signature(
   180	            actor=actor,
   181	            permission=RESOLVE_PERMISSION,
   182	            signature_record_id=signature_record_id,
   183	            for_update=True,
   184	        )
   185	        loan_document = signature_record.loan_document
   186	        if not signature_record.mismatch_resolution_type:
   187	            if (
   188	                signature_record.signature_status != "mismatch"
   189	                or not signature_record.signature_mismatch_flag
   190	            ):
   191	                raise InvalidState("Only an unresolved mismatch signature can be resolved.")
   192	            if signature_record.captured_by_user_id is None:
   193	                raise ValidationError(
   194	                    {
   195	                        "mismatch_resolution_type": (
   196	                            "A retained capture maker is required before mismatch resolution."
   197	                        )
   198	                    }
   199	                )
   200	            if signature_record.captured_by_user_id == actor.pk:
   201	                raise ValidationError(
   202	                    {
   203	                        "mismatch_resolution_type": (
   204	                            "The capture maker and resolver must be different users."
   205	                        )
   206	                    }
   207	                )
   208	        evidence = _resolve_evidence(
   209	            application_id=loan_document.loan_application_id,
   210	            resolution_type=cleaned["mismatch_resolution_type"],
   211	            document_id=cleaned["mismatch_resolution_document_id"],
   212	        )
   213	        requested = {
   214	            "mismatch_resolution_type": cleaned["mismatch_resolution_type"],
   215	            "mismatch_resolution_document_id": str(evidence.document_id),
   216	            "remarks": cleaned["remarks"],
   217	        }
   218	        current = {
   219	            "mismatch_resolution_type": signature_record.mismatch_resolution_type,
   220	            "mismatch_resolution_document_id": (
   221	                str(signature_record.mismatch_resolution_document_id)
   222	                if signature_record.mismatch_resolution_document_id
   223	                else None
   224	            ),
   225	            "remarks": signature_record.mismatch_resolution_remarks,
   226	        }
   227	        if signature_record.mismatch_resolution_type:
   228	            if current == requested:
   229	                return _resolution_action(signature_record)
   230	            raise InvalidState("A resolved mismatch cannot be replaced through this action.")
   231	
   232	        old = _snapshot(signature_record)
   233	        signature_record.mismatch_resolution_type = cleaned["mismatch_resolution_type"]
   234	        signature_record.mismatch_resolution_document = evidence
   235	        signature_record.mismatch_resolution_remarks = cleaned["remarks"]
   236	        signature_record.verified_by_user = actor
   237	        signature_record.verified_at = timezone.now()
   238	        signature_record.updated_at = timezone.now()
   239	        signature_record.save(
   240	            update_fields=[
   241	                "mismatch_resolution_type",
   242	                "mismatch_resolution_document",
   243	                "mismatch_resolution_remarks",
   244	                "verified_by_user",
   245	                "verified_at",
   246	                "updated_at",
   247	            ]
   248	        )
   249	        _project_signature_fact(actor, loan_document, metadata)
   250	        new = _snapshot(signature_record)
   251	        workflow_event = _record_evidence(
   252	            actor,
   253	            loan_document,
   254	            signature_record,
   255	            "documents.signature.mismatch_resolved",
   256	            old,
   257	            new,
   258	            metadata,
   259	            workflow_state="resolved",
   260	        )
   261	        signature_record.mismatch_resolution_workflow_event = workflow_event
   262	        signature_record.save(update_fields=["mismatch_resolution_workflow_event"])
   263	        return _resolution_action(signature_record)
   264	
