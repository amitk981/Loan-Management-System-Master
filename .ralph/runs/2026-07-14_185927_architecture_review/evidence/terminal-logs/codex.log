   278	def _resolve_evidence(*, application_id, resolution_type, document_id):
   279	    from sfpcl_credit.legal_documents.models import LoanDocument
   280	
   281	    required_type = (
   282	        "bank_verification_letter"
   283	        if resolution_type == "bank_verification_letter"
   284	        else "borrower_declaration"
   285	    )
   286	    evidence_loan_document = (
   287	        LoanDocument.objects.select_related("document")
   288	        .filter(
   289	            loan_application_id=application_id,
   290	            document_id=document_id,
   291	            document_type=required_type,
   292	        )
   293	        .first()
   294	    )
   295	    if (
   296	        evidence_loan_document is None
   297	        or evidence_loan_document.renderer_validation_status
   298	        != LoanDocument.RENDERER_CURRENT_VALIDATED
   299	    ):
   300	        raise EvidenceConflict(
   301	            "Resolution evidence was not found with retained legal provenance for this application."
   302	        )
   303	    if resolution_type == "borrower_declaration":
   304	        stamp = getattr(evidence_loan_document, "stamp_duty_record", None)
   305	        if stamp is None or stamp.status != "adequate":
   306	            raise EvidenceConflict(
   307	                "Borrower declaration resolution requires adequate non-judicial stamp evidence."
   308	            )
   309	    try:
   310	        return document_services.resolve_generated_legal_evidence_reference(
   311	            document_id=evidence_loan_document.document_id,
   312	            expected_checksum_sha256=(
   313	                evidence_loan_document.renderer_validated_checksum_sha256
   314	            ),
   315	        )
   316	    except ValidationError as exc:
   317	        raise EvidenceConflict(
   318	            "Resolution evidence was not found with retained legal provenance for this application."
   319	        ) from exc
