    18	_MONEY = re.compile(r"^(0|[1-9][0-9]{0,15})\.[0-9]{2}$")
    19	
    20	
    21	def _exact_fields(payload, allowed):
    22	    if not isinstance(payload, dict):
    23	        raise ValidationError({"body": "A JSON object is required."})
    24	    unknown = set(payload) - allowed
    25	    if unknown:
    26	        raise ValidationError({field: "Unknown field." for field in sorted(unknown)})
    27	    missing = allowed - set(payload)
    28	    if missing:
    29	        raise ValidationError(
    30	            {field: "This field is required." for field in sorted(missing)}
    31	        )
    32	
    33	
    34	def _date(field, value):
    35	    if value in (None, ""):
    36	        return None
    37	    if not isinstance(value, str):
    38	        raise ValidationError({field: "Must be a valid ISO date."})
    39	    try:
    40	        return date.fromisoformat(value)
    41	    except ValueError as exc:
    42	        raise ValidationError({field: "Must be a valid ISO date."}) from exc
    43	
    44	
    45	def _nullable_text(field, value, maximum):
    46	    if value is None:
    47	        return None
    48	    if not isinstance(value, str):
    49	        raise ValidationError({field: "Must be a string or null."})
    50	    value = value.strip()
    51	    if len(value) > maximum:
    52	        raise ValidationError({field: f"Must be at most {maximum} characters."})
    53	    return value or None
    54	
    55	
    56	def _uuid(field, value):
    57	    if value in (None, ""):
    58	        return None
    59	    try:
    60	        return uuid.UUID(str(value))
    61	    except (ValueError, TypeError, AttributeError) as exc:
    62	        raise ValidationError(
    63	            {field: "Document file was not found or is inaccessible."}
    64	        ) from exc
