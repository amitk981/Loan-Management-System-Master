+from django.test import TestCase
+from django.utils import timezone
+
+from sfpcl_credit.legal_documents.models import PowerOfAttorney
+from sfpcl_credit.tests.test_power_of_attorney_api import PowerOfAttorneyApiTests
+from sfpcl_credit.tests.test_tri_party_agreement_api import TriPartyAgreementApiTests
+
+
+class ArchitectureReviewRegressions(TestCase):
+    def _poa_fixture(self):
+        fixture = PowerOfAttorneyApiTests(
+            methodName="test_package_refresh_is_replay_safe_and_preserves_checklist_truth"
+        )
+        fixture.setUp()
+        self.addCleanup(fixture.document_storage.cleanup)
+        return fixture
+
+    def test_package_requires_canonical_final_sanction_not_mutable_status_only(self):
+        fixture = self._poa_fixture()
+        response = fixture.client.post(
+            f"/api/v1/loan-applications/{fixture.application.pk}/security-package/refresh/",
+            {},
+            content_type="application/json",
+            **fixture._auth(fixture.compliance),
+        )
+        self.assertEqual(response.status_code, 409, response.content)
+
+    def test_compliance_cannot_downgrade_active_poa_to_draft(self):
+        fixture = self._poa_fixture()
+        package = fixture._refresh_package()
+        attorney = fixture._user("company_secretary", "security.poa.manage")
+        document, stamp, notary = fixture._poa_evidence()
+        poa = PowerOfAttorney.objects.create(
+            security_package_id=package["security_package_id"],
+            borrower_member=fixture.member,
+            nominee=fixture.nominee,
+            attorney_user=attorney,
+            purpose_summary=(
+                "Authorise Company Secretary to initiate sale of shares on default."
+            ),
+            loan_document=document,
+            stamp_duty_record=stamp,
+            notarisation_record=notary,
+            execution_status="executed",
+            effective_from=timezone.localdate(),
+            status="active",
+            prepared_by_user=fixture.compliance,
+            verified_by_user=attorney,
+        )
+        response = fixture.client.patch(
+            f"/api/v1/power-of-attorneys/{poa.pk}/",
+            {
+                "borrower_member_id": str(fixture.member.pk),
+                "nominee_id": str(fixture.nominee.pk),
+                "attorney_user_id": str(attorney.pk),
+                "purpose_summary": poa.purpose_summary,
+                "loan_document_id": str(document.pk),
+                "stamp_duty_record_id": str(stamp.pk),
+                "notarisation_record_id": str(notary.pk),
+                "execution_status": "pending",
+                "effective_from": None,
+                "status": "draft",
+            },
+            content_type="application/json",
+            **fixture._auth(fixture.compliance),
+        )
+        self.assertEqual(response.status_code, 409, response.content)
+
+    def test_verified_tri_party_signatures_cannot_be_rewritten(self):
+        fixture = TriPartyAgreementApiTests(
+            methodName="test_company_secretary_verifies_applicable_current_signed_agreement"
+        )
+        fixture.setUp()
+        verified = fixture._verify("Verified execution evidence.")
+        self.assertEqual(verified.status_code, 200, verified.content)
+        signature = fixture.document.signature_records.get(signer_party_type="borrower")
+        response = fixture.client.post(
+            f"/api/v1/loan-documents/{fixture.document.pk}/signatures/",
+            {
+                "signer_party_type": "borrower",
+                "signer_party_id": str(signature.signer_party_id),
+                "signer_name_snapshot": signature.signer_name_snapshot,
+                "signature_method": "wet_ink",
+                "signature_status": "pending",
+                "signed_at": None,
+                "signature_mismatch_flag": False,
+            },
+            content_type="application/json",
+            **fixture._auth(fixture.compliance),
+        )
+        self.assertEqual(response.status_code, 409, response.content)

