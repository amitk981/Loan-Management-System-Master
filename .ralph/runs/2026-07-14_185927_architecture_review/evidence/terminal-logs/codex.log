   174	def _aware_datetime(field, value):
   175	    if value is None:
   176	        return None
   177	    if not isinstance(value, str):
   178	        raise ValidationError(
   179	            {field: "Must be an ISO-8601 datetime with timezone or null."}
   180	        )
   181	    parsed = parse_datetime(value)
   182	    if parsed is None or not timezone.is_aware(parsed):
   183	        raise ValidationError(
   184	            {field: "Must be an ISO-8601 datetime with timezone or null."}
   185	        )
   186	    return parsed
