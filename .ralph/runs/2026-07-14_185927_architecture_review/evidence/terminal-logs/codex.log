    66	def _record(*, actor, loan_document_id, cleaned, metadata, kind):
    67	    permission = STAMP_PERMISSION if kind == "stamp" else NOTARY_PERMISSION
    68	    with transaction.atomic():
    69	        loan_document = document_authority.resolve_current_stage4_target(
    70	            actor=actor,
    71	            permission=permission,
    72	            loan_document_id=loan_document_id,
    73	            for_update=True,
    74	        )
    75	
    76	        if kind == "notary":
    77	            cleaned = _resolve_notary_evidence(
    78	                cleaned, loan_document.loan_application_id, actor.role_codes()
    79	            )
    80	
    81	        model = StampDutyRecord if kind == "stamp" else NotarisationRecord
    82	        record = (
    83	            model.objects.select_for_update()
    84	            .filter(loan_document=loan_document)
    85	            .first()
    86	        )
    87	        old = _snapshot(record, kind) if record else {}
    88	        new = _snapshot_values(cleaned, kind)
    89	        if _business_facts(old) == new:
    90	            return _serialize(record, kind)
    91	
    92	        verification_statuses = (
    93	            {"adequate", "insufficient"}
    94	            if kind == "stamp"
    95	            else {"completed", "rejected"}
    96	        )
    97	        is_verification = cleaned["status"] in verification_statuses
    98	        if is_verification:
    99	            if record is None or record.prepared_by_user_id is None:
   100	                raise ValidationError(
   101	                    {
   102	                        "status": "A retained Compliance preparation is required before verification."
   103	                    }
   104	                )
   105	            if record.prepared_by_user_id == actor.pk:
   106	                raise ValidationError(
   107	                    {"status": "The preparer and verifier must be different users."}
   108	                )
   109	        elif record is not None and record.status in verification_statuses:
   110	            raise ValidationError(
   111	                {"status": "Compliance cannot replace or erase a verification outcome."}
   112	            )
   113	
   114	        _project_checklist_status(loan_document, kind, cleaned["status"])
   115	        verified_by = actor if is_verification else None
   116	        values = {
   117	            **cleaned,
   118	            "verified_by_user": verified_by,
   119	            "updated_at": timezone.now(),
   120	        }
   121	        if record is None:
   122	            record = model.objects.create(
   123	                loan_document=loan_document,
   124	                prepared_by_user=actor,
   125	                **values,
   126	            )
   127	            action = f"documents.{kind}.created"
   128	        else:
   129	            for field, value in values.items():
   130	                setattr(record, field, value)
   131	            record.save(update_fields=[*values.keys()])
   132	            action = f"documents.{kind}.changed"
   133	
   134	        projection_field = "stamp_status" if kind == "stamp" else "notarisation_status"
   135	        setattr(loan_document, projection_field, cleaned["status"])
   136	        loan_document.save(update_fields=[projection_field])
   137	        new = _snapshot(record, kind)
   138	        _record_evidence(actor, loan_document, record, kind, action, old, new, metadata)
   139	        return _serialize(record, kind)
