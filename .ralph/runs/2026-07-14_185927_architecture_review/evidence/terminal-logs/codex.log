   364	@skipUnless(connection.vendor == "postgresql", "PostgreSQL row-lock acceptance only")
   365	class TriPartyAgreementConcurrencyTests(TransactionTestCase):
   366	    reset_sequences = True
   367	
   368	    def test_five_concurrent_exact_verifications_retain_one_attributable_transition(self):
   369	        fixture = TriPartyAgreementApiTests(
   370	            methodName="test_company_secretary_verifies_applicable_current_signed_agreement"
   371	        )
   372	        fixture.setUp()
   373	        actor_id = fixture.secretary.pk
   374	        document_id = fixture.document.pk
   375	        gate = Barrier(5)
   376	
   377	        def worker(index):
   378	            close_old_connections()
   379	            try:
   380	                actor = User.objects.get(pk=actor_id)
   381	                gate.wait(timeout=10)
   382	                return loan_document_verification.verify(
   383	                    actor=actor,
   384	                    loan_document_id=document_id,
   385	                    payload={
   386	                        "verification_status": "verified",
   387	                        "remarks": "Concurrent exact execution verification.",
   388	                    },
   389	                    metadata=loan_document_verification.RequestMetadata(
   390	                        f"tri-party-race-{index}", f"203.0.113.{index + 1}", "Race"
   391	                    ),
   392	                )["loan_document_id"]
   393	            finally:
   394	                connections["default"].close()
   395	
   396	        with ThreadPoolExecutor(max_workers=5) as pool:
   397	            ids = list(pool.map(worker, range(5)))
   398	        self.assertEqual(set(ids), {str(document_id)})
   399	        self.assertEqual(
   400	            AuditLog.objects.filter(action="loan_document.tri_party_verified").count(), 1
   401	        )
   402	        self.assertEqual(
   403	            VersionHistory.objects.filter(
   404	                versioned_entity_type="loan_document_verification",
   405	                versioned_entity_id=document_id,
   406	            ).count(),
   407	            1,
   408	        )

