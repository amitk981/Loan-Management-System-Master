   142	def _validate_stamp(payload, actor):
   143	    request = (
   144	        payload
   145	        if isinstance(payload, StampDutyRecordRequest)
   146	        else StampDutyRecordRequest.parse(payload)
   147	    )
   148	    cleaned = request.as_values()
   149	    status = cleaned["status"]
   150	    errors = {}
   151	    executed = cleaned["executed_date"]
   152	    purchased = cleaned["stamp_purchase_date"]
   153	    if purchased and executed and purchased > executed:
   154	        errors["stamp_purchase_date"] = "Must be on or before the executed date."
   155	    if status == "adequate":
   156	        if executed is None:
   157	            errors["executed_date"] = "Adequate stamp duty requires an executed date."
   158	    if status in {"adequate", "insufficient"}:
   159	        try:
   160	            document_authority.require_company_secretary(actor)
   161	        except document_authority.RoleAuthorityDenied:
   162	            errors["status"] = (
   163	                "Only Company Secretary authority may record a verification outcome."
   164	            )
   165	    else:
   166	        try:
   167	            document_authority.require_compliance_preparer(actor)
   168	        except document_authority.RoleAuthorityDenied:
   169	            errors["status"] = "Only Compliance authority may prepare pending facts."
   170	    if errors:
   171	        raise ValidationError(errors)
   172	    return cleaned
   173	
   174	
   175	def _validate_notary(payload, actor):
   176	    request = (
   177	        payload
   178	        if isinstance(payload, NotarisationRecordRequest)
   179	        else NotarisationRecordRequest.parse(payload)
   180	    )
   181	    cleaned = request.as_values()
   182	    status = cleaned["status"]
   183	    errors = {}
   184	    if status == "completed":
   185	        for field in (
   186	            "notary_name",
   187	            "notary_registration_number",
   188	            "notarised_date",
   189	            "evidence_document_id",
   190	        ):
   191	            if not cleaned[field]:
   192	                errors[field] = "Completed notarisation requires this field."
   193	    if status in {"completed", "rejected"}:
   194	        try:
   195	            document_authority.require_company_secretary(actor)
   196	        except document_authority.RoleAuthorityDenied:
   197	            errors["status"] = (
   198	                "Only Company Secretary authority may record a verification outcome."
   199	            )
   200	    else:
   201	        try:
   202	            document_authority.require_compliance_preparer(actor)
   203	        except document_authority.RoleAuthorityDenied:
   204	            errors["status"] = "Only Compliance authority may prepare pending facts."
   205	    if errors:
   206	        raise ValidationError(errors)
   207	    return cleaned
