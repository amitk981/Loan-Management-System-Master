   257	def _validate_activation(poa, cleaned, actor):
   258	    errors = {}
   259	    if "company_secretary" not in actor.role_codes():
   260	        errors["status"] = "Only Company Secretary authority may activate a Power of Attorney."
   261	    if cleaned["attorney_user"].pk != actor.pk:
   262	        errors["attorney_user_id"] = (
   263	            "The activating Company Secretary must be the retained attorney."
   264	        )
   265	    if poa.prepared_by_user_id == actor.pk:
   266	        errors["status"] = "The preparer and activating verifier must be different users."
   267	    if cleaned["execution_status"] != "executed" or cleaned["effective_from"] is None:
   268	        errors["execution_status"] = (
   269	            "Active Power of Attorney requires executed status and effective_from."
   270	        )
   271	    stamp = cleaned["stamp_duty_record"]
   272	    if (
   273	        stamp.status != "adequate"
   274	        or stamp.prepared_by_user_id is None
   275	        or stamp.verified_by_user_id is None
   276	        or stamp.prepared_by_user_id == stamp.verified_by_user_id
   277	    ):
   278	        errors["stamp_duty_record_id"] = (
   279	            "Activation requires current adequate maker/checker stamp evidence."
   280	        )
   281	    notary = cleaned["notarisation_record"]
   282	    if (
   283	        notary.status != "completed"
   284	        or notary.prepared_by_user_id is None
   285	        or notary.verified_by_user_id is None
   286	        or notary.prepared_by_user_id == notary.verified_by_user_id
   287	    ):
   288	        errors["notarisation_record_id"] = (
   289	            "Activation requires current completed maker/checker notarisation evidence."
   290	        )
   291	    rows = selectors.execution_signature_facts_for_document(
   292	        application_id=poa.security_package.loan_application_id,
   293	        loan_document_id=cleaned["loan_document"].pk,
   294	        for_update=True,
   295	    )
   296	    expected = {
   297	        "borrower": (
   298	            cleaned["borrower_member_id"],
   299	            None,
   300	        ),
   301	        "nominee": (
   302	            cleaned["nominee_id"],
   303	            None,
   304	        ),
   305	    }
   306	    if len(rows) != 2:
   307	        errors["execution_status"] = "Distinct current borrower and nominee signatures are required."
   308	    else:
   309	        by_type = {row["signer_party_type"]: row for row in rows}
   310	        for party_type, (party_id, _name) in expected.items():
   311	            row = by_type.get(party_type)
   312	            if (
   313	                row is None
   314	                or row["signer_party_id"] != party_id
   315	                or not row["signer_name_snapshot"].strip()
   316	                or row["signature_status"] != "signed"
   317	                or row["signature_mismatch_flag"]
   318	                or row["mismatch_resolution_type"] is not None
   319	                or row["signed_at"] is None
   320	                or row["captured_by_user_id"] is None
   321	            ):
   322	                errors["execution_status"] = (
