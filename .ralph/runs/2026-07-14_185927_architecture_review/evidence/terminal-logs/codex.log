   127	        if record is not None and record.mismatch_resolution_type:
   128	            raise InvalidState(
   129	                "A resolved signature cannot be changed through the capture action."
   130	            )
   131	        if record is not None and record.captured_by_user_id is None:
   132	            raise ValidationError(
   133	                {
   134	                    "signature_status": (
   135	                        "Legacy signature evidence without a retained capture maker cannot be changed."
   136	                    )
   137	                }
   138	            )
   139	
   140	        verification_values = (
   141	            {"verified_by_user": actor, "verified_at": timezone.now()}
   142	            if cleaned["signature_status"] in {"signed", "mismatch"}
   143	            else {"verified_by_user": None, "verified_at": None}
   144	        )
   145	        values = {
   146	            **cleaned,
   147	            **verification_values,
   148	            "mismatch_resolution_type": None,
   149	            "mismatch_resolution_document": None,
   150	            "mismatch_resolution_remarks": None,
   151	            "updated_at": timezone.now(),
   152	        }
   153	        if record is None:
   154	            record = SignatureRecord.objects.create(
   155	                loan_document=loan_document,
   156	                captured_by_user=actor,
   157	                **values,
   158	            )
   159	            action = "documents.signature.created"
   160	        else:
   161	            for field, value in values.items():
   162	                setattr(record, field, value)
   163	            record.save(update_fields=list(values))
   164	            action = "documents.signature.changed"
   165	        _project_signature_fact(actor, loan_document, metadata)
   166	        new = _snapshot(record)
   167	        _record_evidence(actor, loan_document, record, action, old, new, metadata)
   168	        return _serialize(record)
