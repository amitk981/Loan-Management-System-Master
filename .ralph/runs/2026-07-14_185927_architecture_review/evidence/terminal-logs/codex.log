     9	@dataclass(frozen=True)
    10	class SignerIdentityFact:
    11	    party_type: str
    12	    party_id: object
    13	    name: str
    14	
    15	
    16	def resolve_signer_identity(*, application, party_type, party_id):
    17	    """Return the canonical signer only when the requested id belongs to its owner."""
    18	    if party_id is None:
    19	        return None
    20	    if party_type == "borrower":
    21	        if application.member_id != party_id:
    22	            return None
    23	        member = application.member
    24	        return SignerIdentityFact("borrower", member.member_id, member.legal_name)
    25	    if party_type == "nominee":
    26	        nominee = application.nominee
    27	        if nominee is None or nominee.nominee_id != party_id:
    28	            return None
    29	        return SignerIdentityFact("nominee", nominee.nominee_id, nominee.nominee_name)
    30	    if party_type == "witness":
    31	        witness = Witness.objects.filter(
    32	            loan_application_id=application.pk,
    33	            witness_id=party_id,
    34	        ).first()
    35	        if witness is None:
    36	            return None
    37	        return SignerIdentityFact("witness", witness.witness_id, witness.witness_name)
    38	    if party_type == "user":
    39	        user = User.objects.filter(user_id=party_id, status=User.ACTIVE_STATUS).first()
    40	        if user is None:
    41	            return None
    42	        return SignerIdentityFact("user", user.user_id, user.full_name)
    43	    return None

