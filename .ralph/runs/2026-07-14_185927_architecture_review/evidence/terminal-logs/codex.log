    67	@dataclass(frozen=True)
    68	class StampDutyRecordRequest:
    69	    stamp_paper_amount: Decimal
    70	    stamp_type: str
    71	    stamp_number: str | None
    72	    stamp_purchase_date: date | None
    73	    executed_date: date | None
    74	    status: str
    75	    remarks: str | None
    76	
    77	    FIELDS = {
    78	        "stamp_paper_amount",
    79	        "stamp_type",
    80	        "stamp_number",
    81	        "stamp_purchase_date",
    82	        "executed_date",
    83	        "status",
    84	        "remarks",
    85	    }
    86	
    87	    @classmethod
    88	    def parse(cls, payload):
    89	        _exact_fields(payload, cls.FIELDS)
    90	        errors = {}
    91	        raw_amount = payload.get("stamp_paper_amount")
    92	        if not isinstance(raw_amount, str) or not _MONEY.fullmatch(raw_amount):
    93	            errors["stamp_paper_amount"] = "Must be a non-negative two-decimal string."
    94	            amount = None
    95	        else:
    96	            try:
    97	                amount = Decimal(raw_amount)
    98	            except InvalidOperation:
    99	                errors["stamp_paper_amount"] = (
   100	                    "Must be a non-negative two-decimal string."
   101	                )
   102	                amount = None
   103	        stamp_type = payload.get("stamp_type")
   104	        if stamp_type not in StampDutyRecord.TYPES:
   105	            errors["stamp_type"] = "Must be one of physical, electronic."
   106	        status = payload.get("status")
   107	        if status not in StampDutyRecord.STATUSES:
   108	            errors["status"] = "Must be one of pending, adequate, insufficient."
   109	        if errors:
   110	            raise ValidationError(errors)
   111	        return cls(
   112	            stamp_paper_amount=amount,
   113	            stamp_type=stamp_type,
   114	            stamp_number=_nullable_text(
   115	                "stamp_number", payload.get("stamp_number"), 120
   116	            ),
   117	            stamp_purchase_date=_date(
   118	                "stamp_purchase_date", payload.get("stamp_purchase_date")
   119	            ),
   120	            executed_date=_date("executed_date", payload.get("executed_date")),
   121	            status=status,
   122	            remarks=_nullable_text("remarks", payload.get("remarks"), 4000),
   123	        )
   124	
   125	    def as_values(self):
   126	        return asdict(self)
   127	
