   280	def resolve_generated_legal_evidence_reference(
   281	    *, document_id, expected_checksum_sha256
   282	):
   283	    """Resolve a generated legal file only when its retained document facts still agree."""
   284	    document = DocumentFile.objects.filter(pk=document_id).first()
   285	    if (
