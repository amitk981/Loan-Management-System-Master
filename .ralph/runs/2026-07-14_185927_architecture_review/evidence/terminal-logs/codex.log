   210	def _resolve_notary_evidence(cleaned, application_id, actor_role_codes):
   211	    document_id = cleaned.pop("evidence_document_id")
   212	    if document_id is None:
   213	        return {**cleaned, "evidence_document": None}
   214	    try:
   215	        provenance = document_services.resolve_immutable_upload_provenance(
   216	            document_id=document_id
   217	        )
   218	    except ValidationError as exc:
   219	        raise ValidationError(
   220	            {"evidence_document_id": "Document file was not found or is inaccessible."}
   221	        ) from exc
   222	    legal_reference_allowed = (
   223	        bool(set(actor_role_codes) & {"compliance_team_member", "company_secretary"})
   224	        and provenance.document_category == "legal"
   225	        and provenance.related_entity_type == "application"
   226	        and provenance.related_entity_id == application_id
   227	    )
   228	    if not legal_reference_allowed:
   229	        raise ValidationError(
   230	            {"evidence_document_id": "Document file was not found or is inaccessible."}
   231	        )
   232	    return {**cleaned, "evidence_document": provenance.document}
