   300	def validate_upload_request(request):
   301	    field_errors = {}
   302	    uploaded_file = request.FILES.get("file")
   303	    document_category = (request.POST.get("document_category") or "").strip()
   304	    raw_sensitivity = (request.POST.get("sensitivity_level") or "").strip()
   305	    related_entity_type = (request.POST.get("related_entity_type") or "").strip()
   306	    raw_related_entity_id = (request.POST.get("related_entity_id") or "").strip()
   307	
   308	    if uploaded_file is None:
   309	        field_errors["file"] = "This field is required."
   310	    if not document_category:
   311	        field_errors["document_category"] = "This field is required."
   312	    if not raw_sensitivity:
   313	        field_errors["sensitivity_level"] = "This field is required."
   314	
   315	    sensitivity_level = raw_sensitivity.lower()
   316	    if raw_sensitivity and sensitivity_level not in ALLOWED_SENSITIVITY_LEVELS:
   317	        field_errors["sensitivity_level"] = (
   318	            "Must be one of public, internal, confidential, restricted."
   319	        )
   320	
   321	    related_entity_id = None
   322	    if raw_related_entity_id:
   323	        try:
   324	            related_entity_id = uuid.UUID(raw_related_entity_id)
   325	        except ValueError:
   326	            field_errors["related_entity_id"] = "Must be a valid UUID."
   327	
   328	    if field_errors:
   329	        raise ValidationError(field_errors)
