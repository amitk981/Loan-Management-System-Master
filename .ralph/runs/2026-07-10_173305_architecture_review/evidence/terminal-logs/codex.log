    12	def resolve_effective_loan_policy(*, calculation_date, for_update=False):
    13	    queryset = LoanPolicyConfig.objects
    14	    if for_update:
    15	        queryset = queryset.select_for_update()
    16	    policies = list(
    17	        queryset.filter(
    18	            status=LoanPolicyConfig.STATUS_ACTIVE,
    19	            effective_from__lte=calculation_date,
    20	        )
    21	        .filter(Q(effective_to__isnull=True) | Q(effective_to__gte=calculation_date))
    22	        .order_by("-effective_from", "-loan_policy_config_id")[:2]
    23	    )
    24	    if len(policies) != 1:
    25	        raise ConfigurationResolutionError(
    26	            {
    27	                "loan_policy_config": (
    28	                    "Exactly one active loan policy must apply on calculation_date."
    29	                )
    30	            }
    31	        )
    32	    policy = policies[0]
    33	    if not policy.board_approval_reference:
    34	        raise ConfigurationResolutionError(
    35	            {
    36	                "loan_policy_config": (
    37	                    "Active loan-limit policy requires Board approval metadata."
    38	                )
    39	            }
    40	        )
    41	    if policy.default_scale_of_finance_per_acre_amount <= 0:
    42	        raise ConfigurationResolutionError(
    43	            {"loan_policy_config": "Scale of finance must be greater than zero."}
    44	        )
    45	    configured_rules = [
    46	        value
    47	        for value in (policy.share_limit_percentage, policy.per_share_cap_amount)
    48	        if value is not None
    49	    ]
    50	    if not configured_rules or any(value <= 0 for value in configured_rules):
    51	        raise ConfigurationResolutionError(
    52	            {
    53	                "loan_policy_config": (
    54	                    "Configure a positive share percentage or per-share cap before calculation."
    55	                )
    56	            }
    57	        )
    58	    return policy

