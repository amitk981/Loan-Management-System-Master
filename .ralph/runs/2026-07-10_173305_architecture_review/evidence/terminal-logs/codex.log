  await page.getByText('PORTAL-SAFE').click();
  await page.getByRole('button', { name: 'Submitted Data & Deficiencies' }).click();

  for (const value of [
    'nominee-safe-portal-1',
    'Safe Portal Nominee',
    'Spouse',
    '42',
    'Adult',
    'verified',
    'Required',
  ]) {
