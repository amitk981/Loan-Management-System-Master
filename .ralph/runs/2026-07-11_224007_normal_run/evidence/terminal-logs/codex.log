   175	  const [messageType, setMessageType] = useState<'success' | 'error'>('error');
   176	  const [applications, setApplications] = useState<StaffApplication[]>([]); const [selectedId, setSelectedId] = useState(initialSelectedId ?? '');
   177	  const [eligibility, setEligibility] = useState<EligibilityAssessment | null>(null); const [loanLimit, setLoanLimit] = useState<LoanLimitAssessment | null>(null);
