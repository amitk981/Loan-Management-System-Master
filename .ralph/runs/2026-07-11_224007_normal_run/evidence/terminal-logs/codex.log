   199	  useEffect(() => {
   200	    let cancelled = false;
   201	    fetchStaffApplications({ ordering: 'application_date', pageSize: 100 }).then(result => {
   202	      if (cancelled) return;
   203	      const queue = result.items.filter(item => ['reference_generated', 'submitted_to_sanction_committee'].includes(item.application_status));
   204	      setApplications(queue); const id = queue.some(item => item.loan_application_id === initialSelectedId) ? initialSelectedId! : queue[0]?.loan_application_id ?? '';
   205	      setSelectedId(id); if (!id) setStatus('success'); else loadAssessments(id).catch(error => { setStatus(denied(error) ? 'denied' : 'error'); setMessage(errorText(error)); });
