   247	const selectField = (caption: string, name: string, value: string, options: string[], onField: ViewProps['onField']) => <label><span className="field-label">{caption}</span><select className="field-input" value={value} onChange={event => onField(name, event.target.value)}>{options.map(option => <option key={option || 'blank'} value={option}>{option ? label(option) : 'Select'}</option>)}</select></label>;
   248	
   249	export default AppraisalWorkbench;

