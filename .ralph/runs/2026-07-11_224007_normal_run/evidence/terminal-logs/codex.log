   181	  const [rejectionCategory, setRejectionCategory] = useState('eligibility'); const [rejectionMode, setRejectionMode] = useState('email');
   182	  const [detailedReason, setDetailedReason] = useState(''); const [reapplyAllowed, setReapplyAllowed] = useState(true);
   183	
   184	  const loadAssessments = async (id: string) => {
   185	    const values = await Promise.allSettled([fetchEligibilityAssessment(id), fetchLoanLimitAssessment(id), fetchAppraisal(id), fetchSanctionCase(id)]);
   186	    const failure = values.find(result => result.status === 'rejected' && !missing(result.reason));
   187	    if (failure?.status === 'rejected') throw failure.reason;
   188	    const nextEligibility = values[0].status === 'fulfilled' ? values[0].value : null;
   189	    const nextLimit = values[1].status === 'fulfilled' ? values[1].value : null;
   190	    const nextAppraisal = values[2].status === 'fulfilled' ? values[2].value : null;
   191	    const nextSanction = values[3].status === 'fulfilled' ? values[3].value : null;
   192	    setEligibility(nextEligibility); setLoanLimit(nextLimit); setAppraisal(nextAppraisal); setSanction(nextSanction);
   193	    if (nextSanction) setApplications(current => current.map(item => item.loan_application_id === id && nextSanction.application_status ? { ...item, application_status: nextSanction.application_status } : item));
   194	    const selected = applications.find(item => item.loan_application_id === id);
   195	    setForm(nextAppraisal ? projectAppraisalDraft(nextAppraisal) : emptyDraft(selected?.required_loan_amount ?? ''));
   196	    setLimitForm(emptyLimit(selected?.required_loan_amount ?? '')); setStatus('success');
   197	  };
