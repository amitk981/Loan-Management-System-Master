   239	    ...(appraisal?.available_actions ?? []),
   240	    ...(sanction?.available_actions ?? []),
   241	  ];
   242	  return <AppraisalWorkbenchView status={status} message={message} messageType={messageType} applications={applications} selectedApplication={applications.find(item => item.loan_application_id === selectedId) ?? null} eligibility={eligibility} loanLimit={loanLimit} appraisal={appraisal} sanctionSubmission={sanction} permissions={currentUser.permissions} roleCodes={currentUser.roleCodes} availableActions={availableActions} form={form} limitForm={limitForm} remarks={remarks} reviewDecision={reviewDecision} rejectionCategory={rejectionCategory} rejectionMode={rejectionMode} detailedReason={detailedReason} reapplyAllowed={reapplyAllowed} onSelect={select} onField={field} onAction={action} onOpenApplication={onOpenApplication} />;
   243	};
   244	
   245	const textField = (caption: string, name: string, value: string, onField: ViewProps['onField'], type = 'text') => <label><span className="field-label">{caption}</span><input className="field-input" type={type} value={value} onChange={event => onField(name, event.target.value)} /></label>;
