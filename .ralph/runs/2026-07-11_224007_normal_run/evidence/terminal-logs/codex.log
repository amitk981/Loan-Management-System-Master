   218	    if (name === 'detailedReason') return setDetailedReason(String(value)); if (name === 'reapplyAllowed') return setReapplyAllowed(Boolean(value));
   219	    setForm(current => ({ ...current, [name]: name === 'recommended_tenure_months' ? (value ? Number(value) : null) : value }));
   220	  };
   221	  const action = async (name: Action) => {
   222	    if (!selectedId) return; setMessage(''); setMessageType('error');
   223	    try {
